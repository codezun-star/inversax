---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Conversor de Divisas — Inversax"
  description="Convierte entre las monedas de los 22 países de Latinoamérica y España. USD, EUR, COP, MXN, CLP, ARS, HNL, NIO, VES, CAD, BZD, CUP y más. Tasas de referencia orientativas."
>
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a>
        <span>›</span>
        <a href="/calculadoras" style="text-decoration:none; color:#A8A29E;">Calculadoras</a>
        <span>›</span>
        <span style="color:#57534E;">Conversión de Divisas</span>
      </div>
      <h1 style="font-size:clamp(22px, 4vw, 32px); font-weight:800; color:#1A1A1A; margin:0 0 8px; letter-spacing:-0.3px;">
        Conversor de Divisas
      </h1>
      <p style="font-size:15px; color:#57534E; line-height:1.65; margin:0;">
        Convierte entre las principales monedas latinoamericanas y globales.
      </p>
    </div>
  </div>

  <div style="max-width:600px; margin:0 auto; padding:40px 20px;">

    <div style="background:#FFF8F3; border:1px solid #FFD4A8; border-radius:10px; padding:13px 17px; margin-bottom:24px; display:flex; gap:10px; align-items:flex-start;">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#FF8C42" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:1px;">
        <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"></path>
        <line x1="12" y1="9" x2="12" y2="13"></line>
        <line x1="12" y1="17" x2="12.01" y2="17"></line>
      </svg>
      <p style="font-size:12px; color:#78716C; line-height:1.6; margin:0;">
        Las tasas son de referencia aproximada y no representan cotizaciones en tiempo real. Para operaciones reales usa tu broker o banco.
      </p>
    </div>

    <div style="background:#fff; border:1px solid #E2DDD8; border-radius:14px; padding:28px;">

      <div style="display:flex; flex-direction:column; gap:16px;">
        <div>
          <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Monto a convertir</label>
          <input id="monto" type="number" value="100" min="0"
            style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:18px; font-weight:700; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;"
          />
        </div>

        <div style="display:grid; grid-template-columns:1fr auto 1fr; gap:10px; align-items:end;">
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Moneda origen</label>
            <select id="desde" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 12px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;"></select>
          </div>
          <button id="swap" style="background:#F0EDE7; border:1px solid #E2DDD8; border-radius:8px; padding:10px 12px; cursor:pointer; font-size:16px; margin-bottom:0;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#57534E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="17 1 21 5 17 9"></polyline>
              <path d="M3 11V9a4 4 0 014-4h14"></path>
              <polyline points="7 23 3 19 7 15"></polyline>
              <path d="M21 13v2a4 4 0 01-4 4H3"></path>
            </svg>
          </button>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Moneda destino</label>
            <select id="hasta" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 12px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;"></select>
          </div>
        </div>

        <!-- Resultado -->
        <div style="background:#FF8C42; border-radius:12px; padding:20px 24px; text-align:center; margin-top:4px;">
          <p style="font-size:13px; color:rgba(255,255,255,0.8); margin:0 0 4px; font-weight:500;">Resultado</p>
          <p id="resultado" style="font-size:30px; font-weight:800; color:#fff; margin:0; letter-spacing:-0.5px;">0</p>
          <p id="tasa-label" style="font-size:12px; color:rgba(255,255,255,0.7); margin:6px 0 0;">Tasa: 1 USD = 0</p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Tasas aproximadas con respecto al USD (referencia 2026)
  const tasasUSD: Record<string, number> = {
    USD: 1,
    EUR: 0.92,
    COP: 4200,
    MXN: 17.5,
    CLP: 950,
    ARS: 1200,
    PEN: 3.78,
    BOB: 6.91,
    PYG: 7600,
    UYU: 41,
    CRC: 530,
    GTQ: 7.8,
    DOP: 60,
    HNL: 25,
    NIO: 36.5,
    VES: 40,
    CAD: 1.38,
    BZD: 2.0,
    CUP: 24,
    GBP: 0.79,
    BRL: 5.1,
  };

  const nombres: Record<string, string> = {
    USD: 'USD — Dólar americano',
    EUR: 'EUR — Euro',
    COP: 'COP — Peso colombiano',
    MXN: 'MXN — Peso mexicano',
    CLP: 'CLP — Peso chileno',
    ARS: 'ARS — Peso argentino',
    PEN: 'PEN — Sol peruano',
    BOB: 'BOB — Boliviano',
    PYG: 'PYG — Guaraní paraguayo',
    UYU: 'UYU — Peso uruguayo',
    CRC: 'CRC — Colón costarricense',
    GTQ: 'GTQ — Quetzal guatemalteco',
    DOP: 'DOP — Peso dominicano',
    HNL: 'HNL — Lempira hondureño',
    NIO: 'NIO — Córdoba nicaragüense',
    VES: 'VES — Bolívar venezolano',
    CAD: 'CAD — Dólar canadiense',
    BZD: 'BZD — Dólar de Belice',
    CUP: 'CUP — Peso cubano',
    GBP: 'GBP — Libra esterlina',
    BRL: 'BRL — Real brasileño',
  };

  function poblarSelect(id: string, selected: string) {
    const sel = document.getElementById(id) as HTMLSelectElement;
    sel.innerHTML = Object.entries(nombres)
      .map(([code, label]) => `<option value="${code}" ${code === selected ? 'selected' : ''}>${label}</option>`)
      .join('');
  }

  poblarSelect('desde', 'USD');
  poblarSelect('hasta', 'COP');

  function convertir() {
    const monto = parseFloat((document.getElementById('monto') as HTMLInputElement).value) || 0;
    const desde = (document.getElementById('desde') as HTMLSelectElement).value;
    const hasta  = (document.getElementById('hasta')  as HTMLSelectElement).value;

    const enUSD = monto / tasasUSD[desde];
    const resultado = enUSD * tasasUSD[hasta];
    const tasa = tasasUSD[hasta] / tasasUSD[desde];

    const fmt = new Intl.NumberFormat('es-CO', { maximumFractionDigits: 2 });
    document.getElementById('resultado')!.textContent = fmt.format(resultado) + ' ' + hasta;
    document.getElementById('tasa-label')!.textContent = `Tasa: 1 ${desde} = ${fmt.format(tasa)} ${hasta}`;
  }

  document.getElementById('monto')?.addEventListener('input', convertir);
  document.getElementById('desde')?.addEventListener('change', convertir);
  document.getElementById('hasta')?.addEventListener('change', convertir);
  document.getElementById('swap')?.addEventListener('click', () => {
    const desde = document.getElementById('desde') as HTMLSelectElement;
    const hasta  = document.getElementById('hasta')  as HTMLSelectElement;
    const tmp = desde.value;
    desde.value = hasta.value;
    hasta.value = tmp;
    convertir();
  });

  convertir();
</script>
