---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Calculadora de Meta de Ahorro — Inversax" description="Calcula cuánto debes ahorrar por mes para alcanzar tu meta financiera en el tiempo deseado. Soporta todas las monedas de Latinoamérica y España.">
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a><span>›</span>
        <a href="/calculadoras" style="text-decoration:none; color:#A8A29E;">Calculadoras</a><span>›</span>
        <span style="color:#57534E;">Meta de Ahorro</span>
      </div>
      <h1 style="font-size:clamp(22px,4vw,32px); font-weight:800; color:#1A1A1A; margin:0 0 8px; letter-spacing:-0.3px;">Calculadora de Meta de Ahorro</h1>
      <p style="font-size:15px; color:#57534E; line-height:1.65; margin:0;">Descubre cuánto necesitas ahorrar cada mes para alcanzar tu objetivo financiero.</p>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:40px 20px;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
      <div style="background:#fff; border:1px solid #E2DDD8; border-radius:14px; padding:28px;">
        <h2 style="font-size:16px; font-weight:700; color:#1A1A1A; margin:0 0 20px;">Parámetros</h2>
        <div style="display:flex; flex-direction:column; gap:16px;">
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Moneda</label>
            <select id="moneda" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="USD">USD — Dólar (EC, PA, SV, PR)</option>
              <option value="COP">COP — Peso colombiano</option>
              <option value="MXN">MXN — Peso mexicano</option>
              <option value="ARS">ARS — Peso argentino</option>
              <option value="CLP">CLP — Peso chileno</option>
              <option value="PEN">PEN — Sol peruano</option>
              <option value="UYU">UYU — Peso uruguayo</option>
              <option value="BOB">BOB — Boliviano</option>
              <option value="PYG">PYG — Guaraní paraguayo</option>
              <option value="VES">VES — Bolívar venezolano</option>
              <option value="CRC">CRC — Colón costarricense</option>
              <option value="DOP">DOP — Peso dominicano</option>
              <option value="GTQ">GTQ — Quetzal guatemalteco</option>
              <option value="HNL">HNL — Lempira hondureño</option>
              <option value="NIO">NIO — Córdoba nicaragüense</option>
              <option value="CUP">CUP — Peso cubano</option>
              <option value="BZD">BZD — Dólar de Belice</option>
              <option value="CAD">CAD — Dólar canadiense</option>
              <option value="EUR">EUR — Euro (España)</option>
            </select>
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Meta a alcanzar</label>
            <input id="meta" type="number" value="50000" min="1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Ahorro inicial (ya tengo)</label>
            <input id="inicial" type="number" value="0" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Plazo (meses)</label>
            <input id="meses" type="number" value="24" min="1" max="600" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Rendimiento anual estimado (%)</label>
            <input id="tasa" type="number" value="0" min="0" step="0.1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:14px;">
        <div style="background:#FF8C42; border-radius:14px; padding:24px; color:#fff;">
          <p style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 6px; opacity:0.85;">Ahorro mensual necesario</p>
          <p id="cuota" style="font-size:28px; font-weight:800; margin:0; letter-spacing:-0.5px;">0</p>
        </div>
        <div style="background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:18px; display:flex; flex-direction:column; gap:10px;">
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Meta total</span>
            <span id="meta-label" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Falta por ahorrar</span>
            <span id="falta" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Total aportado (sin intereses)</span>
            <span id="aportado" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Intereses ganados</span>
            <span id="intereses" style="font-size:13px; font-weight:700; color:#22C55E;">0</span>
          </div>
        </div>
        <div style="background:#FFF4EC; border:1px solid #FFD4A8; border-radius:10px; padding:14px 16px;">
          <p style="font-size:12px; color:#78716C; line-height:1.6; margin:0;">Con rendimiento 0% calcula el ahorro puro. Agrega una tasa de interés si invertirás el ahorro en un instrumento financiero.</p>
        </div>
      </div>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:0 20px 60px;" class="prose">
    <h2>¿Para qué sirve esta calculadora?</h2>
    <p>La <strong>calculadora de meta de ahorro</strong> responde a la pregunta más concreta de las finanzas personales: "Quiero tener X en Y meses, ¿cuánto debo ahorrar cada mes?" Ya sea para el enganche de una casa, un viaje, un fondo universitario o cualquier otro objetivo, esta herramienta te da el número exacto.</p>

    <h2>¿Cómo usar esta calculadora?</h2>
    <ul>
      <li><strong>Meta a alcanzar:</strong> el monto total que necesitas al final del plazo.</li>
      <li><strong>Ahorro inicial:</strong> si ya tienes algo ahorrado hacia esa meta, ingrésalo aquí. La calculadora descontará esa cantidad y calculará cuánto te falta.</li>
      <li><strong>Plazo en meses:</strong> cuántos meses tienes para alcanzar la meta. Convierte años a meses (3 años = 36 meses).</li>
      <li><strong>Rendimiento anual estimado:</strong> si vas a poner ese ahorro en un instrumento financiero (cuenta de ahorro de alto rendimiento, CDT, fondo monetario), ingresa la tasa. Si lo guardarás en efectivo, déjalo en 0%.</li>
    </ul>

    <h2>¿Cómo interpretar los resultados?</h2>
    <p>El <strong>ahorro mensual necesario</strong> es la cuota que debes separar cada mes sin falta. Si el número te parece imposible con tu ingreso actual, tienes tres opciones: aumentar el plazo, reducir la meta, o buscar mayor rendimiento para tu ahorro.</p>
    <p>Los <strong>intereses ganados</strong> muestran cuánto dinero aportará el instrumento financiero a tu meta. Si inviertes en lugar de guardar en efectivo, necesitarás ahorrar menos de tu propio bolsillo.</p>

    <h2>Ejemplo: fondo universitario</h2>
    <p>Quieres tener <strong>15.000 USD</strong> para la universidad de tu hijo en <strong>10 años</strong> (120 meses). Ya tienes 2.000 USD ahorrados:</p>
    <ul>
      <li>Con 0% de rendimiento: necesitas ahorrar 108,33 USD/mes</li>
      <li>Con 6% anual (fondo moderado): necesitas ahorrar ~73 USD/mes</li>
      <li>Ahorro total en el segundo caso: ~10.760 USD — el resto lo pone el rendimiento</li>
    </ul>
    <p>Investir el ahorro mensual marca una diferencia de más de 35 USD al mes durante una década. Complementa con nuestra <a href="/calculadoras/interes-compuesto">calculadora de interés compuesto</a> para proyecciones más detalladas.</p>

    <h2>Consejos para cumplir tu meta</h2>
    <ul>
      <li><strong>Automatiza el ahorro:</strong> configura una transferencia automática el día que recibes tu salario, antes de gastar nada.</li>
      <li><strong>Usa una cuenta separada:</strong> no mezcles el fondo de tu meta con tu cuenta corriente. La fricción mental ayuda a no tocarlo.</li>
      <li><strong>Revisa trimestralmente:</strong> si tu ingreso sube, aumenta la cuota mensual para llegar antes o con más capital.</li>
    </ul>
  </div>
</Layout>

<script>
  const DEC: Record<string,number> = {USD:2,COP:0,MXN:2,ARS:0,CLP:0,PEN:2,UYU:2,BOB:2,PYG:0,VES:2,CRC:0,DOP:2,GTQ:2,HNL:2,NIO:2,CUP:2,BZD:2,CAD:2,EUR:2};
  function fmt(n: number, m: string) {
    const d = DEC[m] ?? 2;
    return new Intl.NumberFormat('es',{minimumFractionDigits:d,maximumFractionDigits:d}).format(n) + ' ' + m;
  }
  function calcular() {
    const m    = (document.getElementById('moneda')  as HTMLSelectElement).value;
    const meta = parseFloat((document.getElementById('meta')    as HTMLInputElement).value) || 0;
    const ini  = parseFloat((document.getElementById('inicial') as HTMLInputElement).value) || 0;
    const n    = parseFloat((document.getElementById('meses')   as HTMLInputElement).value) || 1;
    const r    = parseFloat((document.getElementById('tasa')    as HTMLInputElement).value) || 0;
    const falta = Math.max(0, meta - ini);
    let cuota = 0;
    let intereses = 0;
    if (r === 0) {
      cuota = falta / n;
    } else {
      const rm = r / 100 / 12;
      cuota = falta * rm / (Math.pow(1 + rm, n) - 1);
    }
    const aportado = cuota * n;
    intereses = Math.max(0, falta - aportado + ini);
    document.getElementById('cuota')!.textContent    = fmt(cuota, m);
    document.getElementById('meta-label')!.textContent = fmt(meta, m);
    document.getElementById('falta')!.textContent    = fmt(falta, m);
    document.getElementById('aportado')!.textContent = fmt(aportado + ini, m);
    document.getElementById('intereses')!.textContent = fmt(Math.max(0, meta - aportado - ini), m);
  }
  ['moneda','meta','inicial','meses','tasa'].forEach(id => document.getElementById(id)?.addEventListener('input', calcular));
  calcular();
</script>
<style>@media(max-width:600px){div[style*="grid-template-columns:1fr 1fr"]{display:flex!important;flex-direction:column!important;}}</style>
