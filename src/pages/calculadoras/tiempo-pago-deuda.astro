---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Calculadora: Cuánto Tardas en Pagar una Deuda — Inversax" description="Calcula en cuántos meses pagarás tu tarjeta de crédito o préstamo según tu pago mensual y la tasa de interés, y cuánto pagarás en total. Para LATAM y España, 19 monedas.">
  <Fragment slot="head">
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cómo se calcula cuánto tardo en pagar una deuda?",
          "acceptedAnswer": { "@type": "Answer", "text": "Se usa la fórmula n = −ln(1 − saldo × i / pago) / ln(1 + i), donde i es la tasa mensual. Indica cuántos meses tardarás en saldar la deuda con un pago mensual fijo, incluyendo los intereses que se generan cada mes." }
        },
        {
          "@type": "Question",
          "name": "¿Por qué mi tarjeta no baja aunque pago el mínimo?",
          "acceptedAnswer": { "@type": "Answer", "text": "Si tu pago mensual apenas cubre los intereses, casi nada va al capital y la deuda se eterniza. Por eso pagar solo el mínimo de la tarjeta puede tardar años y costar varias veces el monto original." }
        },
        {
          "@type": "Question",
          "name": "¿Cómo pago mi deuda más rápido?",
          "acceptedAnswer": { "@type": "Answer", "text": "Aumentar el pago mensual reduce drásticamente el tiempo y los intereses. Si tienes varias deudas, prioriza la de mayor tasa (método avalancha) o la de menor saldo (bola de nieve) para ganar impulso." }
        }
      ]
    }
    </script>
  </Fragment>
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a><span>›</span>
        <a href="/calculadoras" style="text-decoration:none; color:#A8A29E;">Calculadoras</a><span>›</span>
        <span style="color:#57534E;">Tiempo para Pagar una Deuda</span>
      </div>
      <h1 style="font-size:clamp(22px,4vw,32px); font-weight:800; color:#1A1A1A; margin:0 0 8px; letter-spacing:-0.3px;">¿Cuánto tardas en pagar tu deuda?</h1>
      <p style="font-size:15px; color:#57534E; line-height:1.65; margin:0;">Calcula en cuántos meses saldas tu tarjeta o préstamo y cuánto pagarás en intereses.</p>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:40px 20px;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
      <div style="background:#fff; border:1px solid #E2DDD8; border-radius:14px; padding:28px;">
        <h2 style="font-size:16px; font-weight:700; color:#1A1A1A; margin:0 0 20px;">Tu deuda</h2>
        <div style="display:flex; flex-direction:column; gap:16px;">
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Moneda</label>
            <select id="moneda" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="USD">USD — Dólar (EC, PA, SV, PR)</option>
              <option value="COP">COP — Peso colombiano</option>
              <option value="MXN">MXN — Peso mexicano</option>
              <option value="ARS">ARS — Peso argentino</option>
              <option value="CLP">CLP — Peso chileno</option>
              <option value="PEN">PEN — Sol peruano</option>
              <option value="UYU">UYU — Peso uruguayo</option>
              <option value="EUR">EUR — Euro (España)</option>
            </select>
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Saldo de la deuda</label>
            <input id="saldo" type="number" value="3000" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Tasa de interés anual (%)</label>
            <input id="tasa" type="number" value="36" min="0" step="0.1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Pago mensual</label>
            <input id="pago" type="number" value="200" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:14px;">
        <div style="background:#22C55E; border-radius:14px; padding:24px; color:#fff;">
          <p style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 6px; opacity:0.85;">Tiempo para pagarla</p>
          <p id="r-tiempo" style="font-size:30px; font-weight:800; margin:0; letter-spacing:-0.5px;">0</p>
        </div>
        <div style="background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:18px; display:flex; flex-direction:column; gap:10px;">
          <div style="display:flex; justify-content:space-between;"><span style="font-size:13px; color:#57534E;">Total que pagarás</span><span id="r-total" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span></div>
          <div style="display:flex; justify-content:space-between;"><span style="font-size:13px; color:#57534E;">Total de intereses</span><span id="r-intereses" style="font-size:13px; font-weight:700; color:#EF4444;">0</span></div>
          <div style="display:flex; justify-content:space-between;"><span style="font-size:13px; color:#57534E;">Interés del primer mes</span><span id="r-primer" style="font-size:13px; font-weight:700; color:#22C55E;">0</span></div>
        </div>
        <div style="background:#F0FDF4; border:1px solid #BBF7D0; border-radius:10px; padding:14px 16px;">
          <p id="hint" style="font-size:12px; color:#78716C; line-height:1.6; margin:0;">Si tu pago mensual no supera el interés del mes, la deuda nunca se termina de pagar. Aumenta el pago para reducir el tiempo.</p>
        </div>
      </div>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:0 20px 60px;" class="prose">
    <h2>¿Cuánto tardas en pagar una deuda?</h2>
    <p>El tiempo para saldar una deuda depende de tres cosas: el <strong>saldo</strong>, la <strong>tasa de interés</strong> y tu <strong>pago mensual</strong>. Como los intereses se generan sobre el saldo pendiente, cuanto más bajo sea tu pago, más larga y cara será la deuda.</p>

    <h2>¿Cómo usar esta calculadora?</h2>
    <ul>
      <li><strong>Saldo:</strong> lo que debes hoy.</li>
      <li><strong>Tasa anual:</strong> en tarjetas de LATAM suele ir del 25% al 50%.</li>
      <li><strong>Pago mensual:</strong> lo que destinas cada mes. Prueba subirlo para ver el efecto.</li>
    </ul>

    <h2>La trampa del pago mínimo</h2>
    <p>Pagar solo el mínimo puede convertir una deuda pequeña en años de pagos. Si tienes varias deudas, ordénalas con la <a href="/calculadoras/deuda-bola-nieve">calculadora de avalancha vs bola de nieve</a>, y si financiaste una compra a plazos, revisa su costo con la <a href="/calculadoras/cuotas-tarjeta">calculadora de cuotas con tarjeta</a>.</p>

    <h2>Preguntas frecuentes</h2>
    <h3>¿Conviene pagar la deuda o invertir?</h3>
    <p>Si tu deuda cuesta más que el rendimiento que esperas invertir (casi siempre con tarjetas), pagarla primero es la mejor "inversión". Compáralo con la <a href="/calculadoras/costo-oportunidad">calculadora de costo de oportunidad</a>.</p>
    <h3>¿Qué pasa si pago de más algunos meses?</h3>
    <p>Cada pago extra va directo al capital y reduce el tiempo y los intereses de forma notable. Aquí puedes simular un pago mensual mayor.</p>
  </div>
</Layout>

<script>
  const DEC: Record<string,number> = {USD:2,COP:0,MXN:2,ARS:0,CLP:0,PEN:2,UYU:2,BOB:2,PYG:0,VES:2,CRC:0,DOP:2,GTQ:2,HNL:2,NIO:2,CUP:2,BZD:2,CAD:2,EUR:2};
  function fmt(n: number, m: string) {
    const d = DEC[m] ?? 2;
    return new Intl.NumberFormat('es',{minimumFractionDigits:d,maximumFractionDigits:d}).format(n) + ' ' + m;
  }
  function calcular() {
    const m = (document.getElementById('moneda') as HTMLSelectElement).value;
    const saldo = parseFloat((document.getElementById('saldo') as HTMLInputElement).value) || 0;
    const tasa = (parseFloat((document.getElementById('tasa') as HTMLInputElement).value) || 0) / 100;
    const pago = parseFloat((document.getElementById('pago') as HTMLInputElement).value) || 0;
    const i = tasa / 12;
    const interesPrimer = saldo * i;
    document.getElementById('r-primer')!.textContent = fmt(interesPrimer, m);
    const tEl = document.getElementById('r-tiempo')!;
    if (pago <= interesPrimer) {
      tEl.textContent = 'Nunca';
      tEl.style.fontSize = '28px';
      document.getElementById('r-total')!.textContent = '∞';
      document.getElementById('r-intereses')!.textContent = '∞';
      return;
    }
    tEl.style.fontSize = '30px';
    const n = i > 0 ? -Math.log(1 - saldo * i / pago) / Math.log(1 + i) : saldo / pago;
    const meses = Math.ceil(n);
    const total = pago * n;
    const intereses = total - saldo;
    const anos = Math.floor(meses / 12);
    const resto = meses % 12;
    tEl.textContent = meses + ' meses' + (anos > 0 ? ' (' + anos + 'a ' + resto + 'm)' : '');
    document.getElementById('r-total')!.textContent = fmt(total, m);
    document.getElementById('r-intereses')!.textContent = fmt(intereses, m);
  }
  ['moneda','saldo','tasa','pago'].forEach(id => document.getElementById(id)?.addEventListener('input', calcular));
  calcular();
</script>
<style>@media(max-width:600px){div[style*="grid-template-columns:1fr 1fr"]{display:flex!important;flex-direction:column!important;}}</style>
</content>
