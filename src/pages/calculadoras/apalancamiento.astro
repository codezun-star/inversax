---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Calculadora de Apalancamiento y Margen — Inversax" description="Calcula el margen requerido para operar con apalancamiento en forex. Soporta todas las monedas de Latinoamérica y España.">
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a><span>›</span>
        <a href="/calculadoras" style="text-decoration:none; color:#A8A29E;">Calculadoras</a><span>›</span>
        <span style="color:#57534E;">Apalancamiento</span>
      </div>
      <h1 style="font-size:clamp(22px,4vw,32px); font-weight:800; color:#1A1A1A; margin:0 0 8px; letter-spacing:-0.3px;">Calculadora de Apalancamiento y Margen</h1>
      <p style="font-size:15px; color:#57534E; line-height:1.65; margin:0;">Calcula el margen requerido y el capital en riesgo según tu nivel de apalancamiento.</p>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:40px 20px;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
      <div style="background:#fff; border:1px solid #E2DDD8; border-radius:14px; padding:28px;">
        <h2 style="font-size:16px; font-weight:700; color:#1A1A1A; margin:0 0 20px;">Parámetros de la operación</h2>
        <div style="display:flex; flex-direction:column; gap:16px;">
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Moneda de la cuenta</label>
            <select id="moneda" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="USD">USD — Dólar</option>
              <option value="EUR">EUR — Euro</option>
              <option value="COP">COP — Peso colombiano</option>
              <option value="MXN">MXN — Peso mexicano</option>
              <option value="ARS">ARS — Peso argentino</option>
              <option value="CLP">CLP — Peso chileno</option>
              <option value="PEN">PEN — Sol peruano</option>
              <option value="BRL">BRL — Real brasileño</option>
            </select>
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Balance de la cuenta</label>
            <input id="balance" type="number" value="1000" min="1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Apalancamiento</label>
            <select id="apal" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="10">1:10</option>
              <option value="20">1:20</option>
              <option value="30">1:30</option>
              <option value="50">1:50</option>
              <option value="100" selected>1:100</option>
              <option value="200">1:200</option>
              <option value="500">1:500</option>
              <option value="1000">1:1000</option>
              <option value="2000">1:2000</option>
            </select>
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Tamaño de la operación (unidades)</label>
            <input id="unidades" type="number" value="100000" min="100" step="100" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Precio del par de divisas</label>
            <input id="precio" type="number" value="1.0850" min="0.0001" step="0.0001" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:14px;">
        <div id="card-margen" style="background:#FF8C42; border-radius:14px; padding:24px; color:#fff;">
          <p style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 6px; opacity:0.85;">Margen requerido</p>
          <p id="margen" style="font-size:32px; font-weight:800; margin:0; letter-spacing:-0.5px;">0</p>
        </div>
        <div style="background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:18px; display:flex; flex-direction:column; gap:10px;">
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Tamaño nocional</span>
            <span id="nocional" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">% del balance usado</span>
            <span id="pct-balance" style="font-size:13px; font-weight:700; color:#EF4444;">0%</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Margen libre</span>
            <span id="margen-libre" style="font-size:13px; font-weight:700; color:#22C55E;">0</span>
          </div>
          <div style="height:1px; background:#E2DDD8;"></div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Máx. lotes estándar posibles</span>
            <span id="max-lotes" style="font-size:13px; font-weight:700; color:#FF8C42;">0</span>
          </div>
        </div>
        <div style="background:#FFF4EC; border:1px solid #FFD4A8; border-radius:10px; padding:14px 16px;">
          <p style="font-size:12px; color:#78716C; line-height:1.6; margin:0;">Mayor apalancamiento = mayor exposición al riesgo. Nunca arriesgues más del 1-2% de tu cuenta por operación. El margen es el depósito de garantía, no el costo real de la operación.</p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const DEC: Record<string,number> = {USD:2,EUR:2,COP:0,MXN:2,ARS:0,CLP:0,PEN:2,BRL:2};
  function fmt(n: number, m: string) {
    const d = DEC[m] ?? 2;
    return new Intl.NumberFormat('es',{minimumFractionDigits:d,maximumFractionDigits:d}).format(n) + ' ' + m;
  }
  function calcular() {
    const m        = (document.getElementById('moneda')   as HTMLSelectElement).value;
    const balance  = parseFloat((document.getElementById('balance')  as HTMLInputElement).value) || 0;
    const apal     = parseFloat((document.getElementById('apal')     as HTMLSelectElement).value) || 100;
    const unidades = parseFloat((document.getElementById('unidades') as HTMLInputElement).value) || 0;
    const precio   = parseFloat((document.getElementById('precio')   as HTMLInputElement).value) || 1;
    const nocional   = unidades * precio;
    const margen     = nocional / apal;
    const pctBalance = balance > 0 ? (margen / balance) * 100 : 0;
    const margenLibre = Math.max(0, balance - margen);
    const maxLotes   = balance > 0 ? Math.floor((balance * apal) / (100000 * precio) * 100) / 100 : 0;
    const card = document.getElementById('card-margen')!;
    card.style.background = pctBalance > 50 ? '#EF4444' : '#FF8C42';
    document.getElementById('margen')!.textContent       = fmt(margen, m);
    document.getElementById('nocional')!.textContent     = fmt(nocional, m);
    document.getElementById('pct-balance')!.textContent  = pctBalance.toFixed(1) + '%';
    document.getElementById('margen-libre')!.textContent = fmt(margenLibre, m);
    document.getElementById('max-lotes')!.textContent    = maxLotes.toFixed(2) + ' lotes';
  }
  ['moneda','balance','apal','unidades','precio'].forEach(id => document.getElementById(id)?.addEventListener('input', calcular));
  calcular();
</script>
<style>@media(max-width:600px){div[style*="grid-template-columns:1fr 1fr"]{display:flex!important;flex-direction:column!important;}}</style>
