---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Calculadora de Ahorro para el Enganche o Pie de Casa — Inversax" description="Calcula cuánto ahorrar al mes para reunir el enganche, pie o entrada de tu vivienda en el plazo que quieras, con rendimiento incluido. Para LATAM y España, 19 monedas.">
  <Fragment slot="head">
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cuánto debo ahorrar para el enganche de una casa?",
          "acceptedAnswer": { "@type": "Answer", "text": "Lo habitual es reunir entre el 10% y el 20% del precio de la vivienda como enganche, pie o entrada. La calculadora reparte ese objetivo en aportes mensuales según el plazo que elijas y el rendimiento de tus ahorros." }
        },
        {
          "@type": "Question",
          "name": "¿Dónde guardo el dinero del enganche mientras ahorro?",
          "acceptedAnswer": { "@type": "Answer", "text": "Si comprarás en 1-2 años, prioriza instrumentos seguros y líquidos como un plazo fijo o cuenta remunerada. Para horizontes más largos puedes asumir algo de riesgo con fondos conservadores, pero evita activos volátiles para metas cercanas." }
        },
        {
          "@type": "Question",
          "name": "¿Conviene un enganche mayor?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sí. Un enganche mayor reduce el monto financiado, la cuota mensual y los intereses totales de la hipoteca. Además, muchos bancos ofrecen mejores tasas a partir de cierto porcentaje de entrada." }
        }
      ]
    }
    </script>
  </Fragment>
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a><span>›</span>
        <a href="/calculadoras" style="text-decoration:none; color:#A8A29E;">Calculadoras</a><span>›</span>
        <span style="color:#57534E;">Ahorro para el Enganche</span>
      </div>
      <h1 style="font-size:clamp(22px,4vw,32px); font-weight:800; color:#1A1A1A; margin:0 0 8px; letter-spacing:-0.3px;">Ahorro para el Enganche / Pie</h1>
      <p style="font-size:15px; color:#57534E; line-height:1.65; margin:0;">Calcula cuánto ahorrar al mes para reunir la entrada de tu vivienda en el plazo que quieras.</p>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:40px 20px;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
      <div style="background:#fff; border:1px solid #E2DDD8; border-radius:14px; padding:28px;">
        <h2 style="font-size:16px; font-weight:700; color:#1A1A1A; margin:0 0 20px;">Tu meta</h2>
        <div style="display:flex; flex-direction:column; gap:16px;">
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Moneda</label>
            <select id="moneda" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="USD">USD — Dólar (EC, PA, SV, PR)</option>
              <option value="COP">COP — Peso colombiano</option>
              <option value="MXN">MXN — Peso mexicano</option>
              <option value="ARS">ARS — Peso argentino</option>
              <option value="CLP">CLP — Peso chileno</option>
              <option value="PEN">PEN — Sol peruano</option>
              <option value="UYU">UYU — Peso uruguayo</option>
              <option value="EUR">EUR — Euro (España)</option>
            </select>
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Precio de la vivienda</label>
            <input id="precio" type="number" value="150000" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Enganche objetivo (%)</label>
            <input id="eng" type="number" value="20" min="1" max="100" step="1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Ahorro actual</label>
            <input id="actual" type="number" value="5000" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Plazo para comprar (años)</label>
            <input id="anos" type="number" value="4" min="1" step="1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Rendimiento anual de tus ahorros (%)</label>
            <input id="rend" type="number" value="5" min="0" step="0.1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:14px;">
        <div style="background:#22C55E; border-radius:14px; padding:24px; color:#fff;">
          <p style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 6px; opacity:0.85;">Debes ahorrar al mes</p>
          <p id="r-aporte" style="font-size:32px; font-weight:800; margin:0; letter-spacing:-0.5px;">0</p>
        </div>
        <div style="background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:18px; display:flex; flex-direction:column; gap:10px;">
          <div style="display:flex; justify-content:space-between;"><span style="font-size:13px; color:#57534E;">Meta de enganche</span><span id="r-meta" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span></div>
          <div style="display:flex; justify-content:space-between;"><span style="font-size:13px; color:#57534E;">Te falta hoy</span><span id="r-falta" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span></div>
          <div style="display:flex; justify-content:space-between;"><span style="font-size:13px; color:#57534E;">Aporte total que harás</span><span id="r-aportado" style="font-size:13px; font-weight:700; color:#22C55E;">0</span></div>
        </div>
        <div style="background:#F0FDF4; border:1px solid #BBF7D0; border-radius:10px; padding:14px 16px;">
          <p style="font-size:12px; color:#78716C; line-height:1.6; margin:0;">Considera el rendimiento de tu ahorro actual y de los aportes. No incluye la subida del precio de la vivienda durante el plazo.</p>
        </div>
      </div>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:0 20px 60px;" class="prose">
    <h2>¿Cuánto ahorrar para el enganche?</h2>
    <p>El <strong>enganche</strong>, <strong>pie</strong> o <strong>entrada</strong> es el porcentaje del precio que pagas de tu bolsillo al comprar vivienda. La calculadora toma tu objetivo, descuenta lo que ya tienes (que sigue creciendo) y reparte el resto en aportes mensuales.</p>

    <h2>¿Cómo usar esta calculadora?</h2>
    <ul>
      <li><strong>Precio y enganche objetivo:</strong> definen tu meta total.</li>
      <li><strong>Ahorro actual y rendimiento:</strong> tu punto de partida y cómo crece.</li>
      <li><strong>Plazo:</strong> en cuántos años quieres comprar.</li>
    </ul>

    <h2>El siguiente paso</h2>
    <p>Cuando tengas el enganche, simula la cuota de tu crédito con la <a href="/calculadoras/hipoteca">calculadora de hipoteca</a>. Y para una meta de ahorro genérica (no solo vivienda), usa la <a href="/calculadoras/meta-ahorro">calculadora de meta de ahorro</a>.</p>

    <h2>Preguntas frecuentes</h2>
    <h3>¿Y si el precio de la vivienda sube mientras ahorro?</h3>
    <p>Es un riesgo real. Considera un objetivo algo mayor o un plazo más corto. Mira el efecto de la inflación con la <a href="/calculadoras/inflacion">calculadora de inflación</a>.</p>
    <h3>¿Debo incluir los gastos de notaría e impuestos?</h3>
    <p>Sí, conviene. Súmalos a tu meta porque también se pagan al inicio, además del enganche.</p>
  </div>
</Layout>

<script>
  const DEC: Record<string,number> = {USD:2,COP:0,MXN:2,ARS:0,CLP:0,PEN:2,UYU:2,BOB:2,PYG:0,VES:2,CRC:0,DOP:2,GTQ:2,HNL:2,NIO:2,CUP:2,BZD:2,CAD:2,EUR:2};
  function fmt(n: number, m: string) {
    const d = DEC[m] ?? 2;
    return new Intl.NumberFormat('es',{minimumFractionDigits:d,maximumFractionDigits:d}).format(n) + ' ' + m;
  }
  function calcular() {
    const m = (document.getElementById('moneda') as HTMLSelectElement).value;
    const precio = parseFloat((document.getElementById('precio') as HTMLInputElement).value) || 0;
    const eng = (parseFloat((document.getElementById('eng') as HTMLInputElement).value) || 0) / 100;
    const actual = parseFloat((document.getElementById('actual') as HTMLInputElement).value) || 0;
    const anos = parseFloat((document.getElementById('anos') as HTMLInputElement).value) || 1;
    const rend = (parseFloat((document.getElementById('rend') as HTMLInputElement).value) || 0) / 100;
    const meta = precio * eng;
    const i = rend / 12;
    const n = anos * 12;
    const currentFV = actual * Math.pow(1 + i, n);
    const remaining = meta - currentFV;
    let aporte = 0;
    if (remaining > 0) aporte = i > 0 ? remaining * i / (Math.pow(1 + i, n) - 1) : remaining / n;
    document.getElementById('r-aporte')!.textContent = aporte > 0 ? fmt(aporte, m) : '¡Ya lo tienes!';
    document.getElementById('r-meta')!.textContent = fmt(meta, m);
    document.getElementById('r-falta')!.textContent = fmt(Math.max(meta - actual, 0), m);
    document.getElementById('r-aportado')!.textContent = fmt(aporte * n, m);
  }
  ['moneda','precio','eng','actual','anos','rend'].forEach(id => document.getElementById(id)?.addEventListener('input', calcular));
  calcular();
</script>
<style>@media(max-width:600px){div[style*="grid-template-columns:1fr 1fr"]{display:flex!important;flex-direction:column!important;}}</style>
</content>
