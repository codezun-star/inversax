---
import Layout from '../../layouts/Layout.astro';
import { grupos } from '../../lib/calculadoras';

const MAX_SHOWN = 12;
const total = grupos.reduce((sum, g) => sum + g.calculadoras.length, 0);
---

<Layout
  title="Calculadoras Financieras — Inversax"
  description={`${total} calculadoras financieras gratuitas: interés compuesto, ROI, CAGR, jubilación, FIRE, amortización, pips forex, remesas, cruce de divisas y más. Soporta todas las monedas de Latinoamérica y España.`}
>
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:1100px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a>
        <span>›</span>
        <span style="color:#57534E;">Calculadoras</span>
      </div>
      <h1 style="font-size:clamp(24px,4vw,36px); font-weight:800; color:#1A1A1A; margin:0 0 10px; letter-spacing:-0.3px;">
        Calculadoras financieras
      </h1>
      <p style="font-size:15px; color:#57534E; line-height:1.65; max-width:560px; margin:0 0 24px;">
        {total} herramientas gratuitas para invertir mejor, planificar tu dinero y operar en forex.
      </p>

      <!-- Tags de categoría -->
      <div style="display:flex; flex-wrap:wrap; gap:8px;">
        {grupos.map((g, i) => (
          <button
            data-tag={g.slug}
            style={i === 0
              ? 'font-family:\'DM Sans\',sans-serif; font-size:13px; font-weight:600; padding:7px 16px; border-radius:20px; border:1px solid #FF8C42; background:#FF8C42; color:#fff; cursor:pointer;'
              : 'font-family:\'DM Sans\',sans-serif; font-size:13px; font-weight:600; padding:7px 16px; border-radius:20px; border:1px solid transparent; background:#F0EDE7; color:#57534E; cursor:pointer;'}
          >
            {g.tagLabel}
          </button>
        ))}
      </div>
    </div>
  </div>

  <div style="max-width:1100px; margin:0 auto; padding:40px 20px; display:flex; flex-direction:column; gap:48px;">
    {grupos.map((grupo, i) => {
      const shown = grupo.calculadoras.slice(0, MAX_SHOWN);
      const hasMore = grupo.calculadoras.length > MAX_SHOWN;
      return (
        <div data-section={grupo.slug} style={i !== 0 ? 'display:none;' : ''}>
          <div style="display:flex; align-items:center; gap:10px; margin-bottom:20px; flex-wrap:wrap;">
            <div style={'width:3px; height:22px; background:' + grupo.color + '; border-radius:2px;'}></div>
            <h2 style="font-size:18px; font-weight:700; color:#1A1A1A; margin:0;">{grupo.categoria}</h2>
            <span style="font-size:12px; color:#A8A29E; font-weight:500;">{grupo.calculadoras.length} calculadoras</span>
          </div>

          <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:14px;">
            {shown.map((c) => {
              const hoverColor = grupo.color;
              const iconBg = grupo.color + '18';
              return (
                <a
                  href={c.href}
                  style="display:flex; flex-direction:column; background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:22px; text-decoration:none; transition:border-color 0.15s, box-shadow 0.15s;"
                  onmouseover={'this.style.borderColor=\'' + hoverColor + '\'; this.style.boxShadow=\'0 2px 12px rgba(0,0,0,0.07)\''}
                  onmouseout="this.style.borderColor='#E2DDD8'; this.style.boxShadow='none'"
                >
                  <div style={'width:40px; height:40px; background:' + iconBg + '; border-radius:10px; display:flex; align-items:center; justify-content:center; margin-bottom:14px;'}>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={grupo.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d={c.svgPath}></path>
                    </svg>
                  </div>
                  <h3 style="font-size:15px; font-weight:700; color:#1A1A1A; margin:0 0 7px;">{c.titulo}</h3>
                  <p style="font-size:13px; color:#57534E; line-height:1.6; margin:0 0 16px; flex:1;">{c.descripcion}</p>
                  <div style="display:flex; align-items:center; gap:5px;">
                    <span style={'font-size:13px; font-weight:600; color:' + grupo.color + ';'}>Calcular</span>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke={grupo.color} stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                      <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                  </div>
                </a>
              );
            })}
          </div>

          {hasMore && (
            <div style="margin-top:16px; text-align:center;">
              <a
                href={'/calculadoras/' + grupo.slug}
                style={'display:inline-flex; align-items:center; gap:6px; font-size:14px; font-weight:600; color:' + grupo.color + '; text-decoration:none; padding:10px 20px; border:1px solid ' + grupo.color + '; border-radius:8px;'}
              >
                Ver más de {grupo.tagLabel}
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            </div>
          )}
        </div>
      );
    })}
  </div>
</Layout>

<script is:inline>
  var tags = document.querySelectorAll('[data-tag]');
  var sections = document.querySelectorAll('[data-section]');

  tags.forEach(function (tag) {
    tag.addEventListener('click', function () {
      var selected = tag.dataset.tag;

      tags.forEach(function (t) {
        t.style.background = '#F0EDE7';
        t.style.color = '#57534E';
        t.style.borderColor = 'transparent';
      });
      tag.style.background = '#FF8C42';
      tag.style.color = '#fff';
      tag.style.borderColor = '#FF8C42';

      sections.forEach(function (s) {
        s.style.display = (selected === 'todas' || s.dataset.section === selected) ? '' : 'none';
      });
    });
  });
</script>
