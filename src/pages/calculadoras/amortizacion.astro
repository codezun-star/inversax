---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Tabla de Amortización — Inversax" description="Genera la tabla de amortización completa de tu préstamo mes a mes. Soporta todas las monedas de Latinoamérica y España.">
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a><span>›</span>
        <a href="/calculadoras" style="text-decoration:none; color:#A8A29E;">Calculadoras</a><span>›</span>
        <span style="color:#57534E;">Amortización</span>
      </div>
      <h1 style="font-size:clamp(22px,4vw,32px); font-weight:800; color:#1A1A1A; margin:0 0 8px; letter-spacing:-0.3px;">Tabla de Amortización</h1>
      <p style="font-size:15px; color:#57534E; line-height:1.65; margin:0;">Visualiza mes a mes cuánto pagas de capital e intereses en tu préstamo.</p>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:40px 20px; display:flex; flex-direction:column; gap:24px;">
    <div style="background:#fff; border:1px solid #E2DDD8; border-radius:14px; padding:28px;">
      <h2 style="font-size:16px; font-weight:700; color:#1A1A1A; margin:0 0 20px;">Datos del préstamo</h2>
      <div style="display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:16px;">
        <div>
          <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Moneda</label>
          <select id="moneda" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 12px; font-size:13px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
            <option value="USD">USD</option>
            <option value="COP">COP</option>
            <option value="MXN">MXN</option>
            <option value="ARS">ARS</option>
            <option value="CLP">CLP</option>
            <option value="PEN">PEN</option>
            <option value="UYU">UYU</option>
            <option value="BOB">BOB</option>
            <option value="PYG">PYG</option>
            <option value="VES">VES</option>
            <option value="CRC">CRC</option>
            <option value="DOP">DOP</option>
            <option value="GTQ">GTQ</option>
            <option value="HNL">HNL</option>
            <option value="NIO">NIO</option>
            <option value="CUP">CUP</option>
            <option value="BZD">BZD</option>
            <option value="CAD">CAD</option>
            <option value="EUR">EUR</option>
          </select>
        </div>
        <div>
          <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Monto</label>
          <input id="monto" type="number" value="10000" min="1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 12px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
        </div>
        <div>
          <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Tasa anual (%)</label>
          <input id="tasa" type="number" value="12" min="0" step="0.1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 12px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
        </div>
        <div>
          <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Plazo (meses)</label>
          <input id="plazo" type="number" value="24" min="1" max="360" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 12px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
        </div>
      </div>
    </div>

    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px;">
      <div style="background:#EF4444; border-radius:12px; padding:20px; color:#fff; text-align:center;">
        <p style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 4px; opacity:0.85;">Cuota mensual</p>
        <p id="cuota" style="font-size:22px; font-weight:800; margin:0;">0</p>
      </div>
      <div style="background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:20px; text-align:center;">
        <p style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 4px; color:#57534E;">Total intereses</p>
        <p id="total-int" style="font-size:22px; font-weight:800; margin:0; color:#EF4444;">0</p>
      </div>
      <div style="background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:20px; text-align:center;">
        <p style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 4px; color:#57534E;">Total a pagar</p>
        <p id="total-pago" style="font-size:22px; font-weight:800; margin:0; color:#1A1A1A;">0</p>
      </div>
    </div>

    <div style="background:#fff; border:1px solid #E2DDD8; border-radius:14px; overflow:hidden;">
      <div style="overflow-x:auto;">
        <table style="width:100%; border-collapse:collapse; font-size:13px;">
          <thead>
            <tr style="background:#F7F7F5;">
              <th style="padding:12px 16px; text-align:left; font-weight:700; color:#57534E; border-bottom:1px solid #E2DDD8;">Mes</th>
              <th style="padding:12px 16px; text-align:right; font-weight:700; color:#57534E; border-bottom:1px solid #E2DDD8;">Cuota</th>
              <th style="padding:12px 16px; text-align:right; font-weight:700; color:#57534E; border-bottom:1px solid #E2DDD8;">Capital</th>
              <th style="padding:12px 16px; text-align:right; font-weight:700; color:#57534E; border-bottom:1px solid #E2DDD8;">Interés</th>
              <th style="padding:12px 16px; text-align:right; font-weight:700; color:#57534E; border-bottom:1px solid #E2DDD8;">Saldo</th>
            </tr>
          </thead>
          <tbody id="tabla-body"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:0 20px 60px;" class="prose">
    <h2>¿Qué es una tabla de amortización?</h2>
    <p>Una <strong>tabla de amortización</strong> es el desglose completo, mes a mes, de cómo se reparte cada cuota entre capital e intereses, y cuánto saldo queda pendiente. Es el documento que debería darte tu banco al firmar un préstamo, y que te permite entender exactamente cómo evoluciona tu deuda.</p>

    <h2>¿Cómo leer la tabla?</h2>
    <ul>
      <li><strong>Cuota:</strong> el pago total que realizas ese mes. Es fijo durante todo el préstamo (sistema francés).</li>
      <li><strong>Capital:</strong> la parte de la cuota que reduce tu deuda. En verde porque es lo que va a tu favor.</li>
      <li><strong>Interés:</strong> la parte que se queda el banco. En rojo porque es el costo del crédito. Es más alto al inicio y cae cada mes.</li>
      <li><strong>Saldo:</strong> lo que debes al finalizar ese mes, después de aplicar el pago de capital.</li>
    </ul>

    <h2>¿Por qué el interés baja cada mes?</h2>
    <p>Porque los intereses se calculan sobre el <strong>saldo pendiente</strong>, no sobre el capital original. Cada mes que pagas, el saldo baja un poco, y el siguiente mes se calculan intereses sobre un número menor. Por eso al inicio casi todo es interés y al final casi todo es capital.</p>
    <p>Esto también explica por qué los prepagos son tan valiosos en los primeros meses: reducen el saldo sobre el que se calcularán los intereses de todas las cuotas restantes.</p>

    <h2>Caso práctico: 10.000 USD al 12% en 24 meses</h2>
    <ul>
      <li>Cuota mensual: 470,73 USD</li>
      <li>Mes 1: 100 USD de interés, 370,73 USD de capital, saldo 9.629,27 USD</li>
      <li>Mes 12: 55 USD de interés, 415 USD de capital, saldo 5.517 USD</li>
      <li>Mes 24: 4,67 USD de interés, 466 USD de capital, saldo 0</li>
    </ul>
    <p>Como ves, en el mes 1 el 21% de la cuota es interés. En el mes 24, solo el 1%. La estructura cambia radicalmente.</p>

    <h2>¿Cómo usar esta información para ahorrar dinero?</h2>
    <p>Identifica en la tabla el mes en el que el saldo supera el 50% del capital original. Si haces un prepago de capital en ese punto, reduces significativamente los intereses restantes. Cada unidad de moneda que reduces del saldo ahorra exactamente esa unidad multiplicada por la tasa mensual durante todos los meses restantes.</p>
    <p>Para calcular solo la cuota mensual sin el detalle completo, usa nuestra <a href="/calculadoras/prestamo">calculadora de préstamo</a>.</p>
  </div>
</Layout>

<script>
  const DEC: Record<string,number> = {USD:2,COP:0,MXN:2,ARS:0,CLP:0,PEN:2,UYU:2,BOB:2,PYG:0,VES:2,CRC:0,DOP:2,GTQ:2,HNL:2,NIO:2,CUP:2,BZD:2,CAD:2,EUR:2};
  function fmt(n: number, m: string) {
    const d = DEC[m] ?? 2;
    return new Intl.NumberFormat('es',{minimumFractionDigits:d,maximumFractionDigits:d}).format(n);
  }
  function calcular() {
    const m   = (document.getElementById('moneda') as HTMLSelectElement).value;
    const P   = parseFloat((document.getElementById('monto') as HTMLInputElement).value) || 0;
    const r   = parseFloat((document.getElementById('tasa')  as HTMLInputElement).value) || 0;
    const n   = Math.min(360, Math.max(1, parseFloat((document.getElementById('plazo') as HTMLInputElement).value) || 1));
    const rm  = r / 100 / 12;
    let cuota = 0;
    if (rm === 0) cuota = P / n;
    else cuota = P * rm * Math.pow(1 + rm, n) / (Math.pow(1 + rm, n) - 1);
    const totalPago = cuota * n;
    const totalInt  = totalPago - P;
    document.getElementById('cuota')!.textContent     = fmt(cuota, m) + ' ' + m;
    document.getElementById('total-int')!.textContent  = fmt(totalInt, m) + ' ' + m;
    document.getElementById('total-pago')!.textContent = fmt(totalPago, m) + ' ' + m;
    let saldo = P;
    const tbody = document.getElementById('tabla-body')!;
    tbody.innerHTML = '';
    for (let i = 1; i <= n; i++) {
      const interes  = saldo * rm;
      const capital  = cuota - interes;
      saldo = Math.max(0, saldo - capital);
      const row = document.createElement('tr');
      row.style.borderBottom = '1px solid #F0EDE7';
      row.innerHTML = '<td style="padding:10px 16px; color:#1A1A1A;">' + i + '</td>' +
        '<td style="padding:10px 16px; text-align:right; color:#1A1A1A;">' + fmt(cuota, m) + '</td>' +
        '<td style="padding:10px 16px; text-align:right; color:#22C55E;">' + fmt(capital, m) + '</td>' +
        '<td style="padding:10px 16px; text-align:right; color:#EF4444;">' + fmt(interes, m) + '</td>' +
        '<td style="padding:10px 16px; text-align:right; color:#57534E;">' + fmt(saldo, m) + '</td>';
      tbody.appendChild(row);
    }
  }
  ['moneda','monto','tasa','plazo'].forEach(id => document.getElementById(id)?.addEventListener('input', calcular));
  calcular();
</script>
<style>
  @media(max-width:600px){
    div[style*="grid-template-columns:1fr 1fr 1fr 1fr"]{display:flex!important;flex-direction:column!important;}
    div[style*="grid-template-columns:repeat(3"]{display:flex!important;flex-direction:column!important;}
  }
</style>
