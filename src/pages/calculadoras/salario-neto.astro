---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Calculadora de Salario Neto — Inversax" description="Calcula tu salario neto estimado después de deducciones según tu país. Cubre los 22 países de Latinoamérica y España con tasas aproximadas.">
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a>
        <span>›</span>
        <a href="/calculadoras" style="text-decoration:none; color:#A8A29E;">Calculadoras</a>
        <span>›</span>
        <span style="color:#57534E;">Salario Neto</span>
      </div>
      <h1 style="font-size:clamp(22px,4vw,32px); font-weight:800; color:#1A1A1A; margin:0 0 8px; letter-spacing:-0.3px;">Calculadora de Salario Neto</h1>
      <p style="font-size:15px; color:#57534E; line-height:1.65; margin:0;">Estima cuánto recibes realmente después de deducciones y aportes obligatorios.</p>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:40px 20px;">
    <div style="background:#FFF8F3; border:1px solid #FFD4A8; border-radius:10px; padding:14px 18px; margin-bottom:24px; display:flex; gap:10px; align-items:flex-start;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF8C42" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:1px;">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="8" x2="12" y2="12"></line>
        <line x1="12" y1="16" x2="12.01" y2="16"></line>
      </svg>
      <p style="font-size:13px; color:#78716C; line-height:1.6; margin:0;">Esta calculadora usa tasas aproximadas de referencia (2025-2026). Los valores reales dependen de tu situación fiscal específica, tramos de ingresos y beneficios. Consulta a un contador para cálculos exactos.</p>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
      <div style="background:#fff; border:1px solid #E2DDD8; border-radius:14px; padding:28px;">
        <h2 style="font-size:16px; font-weight:700; color:#1A1A1A; margin:0 0 20px;">Datos del salario</h2>
        <div style="display:flex; flex-direction:column; gap:16px;">
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">País</label>
            <select id="pais" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="co">Colombia</option>
              <option value="mx">México</option>
              <option value="ar">Argentina</option>
              <option value="cl">Chile</option>
              <option value="pe">Perú</option>
              <option value="ec">Ecuador</option>
              <option value="uy">Uruguay</option>
              <option value="bo">Bolivia</option>
              <option value="py">Paraguay</option>
              <option value="ve">Venezuela</option>
              <option value="cr">Costa Rica</option>
              <option value="pa">Panamá</option>
              <option value="do">Rep. Dominicana</option>
              <option value="gt">Guatemala</option>
              <option value="hn">Honduras</option>
              <option value="sv">El Salvador</option>
              <option value="ni">Nicaragua</option>
              <option value="cu">Cuba</option>
              <option value="pr">Puerto Rico</option>
              <option value="ca">Canadá</option>
              <option value="bz">Belice</option>
              <option value="es">España</option>
            </select>
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Salario bruto mensual</label>
            <input id="salario" type="number" value="3000000" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
            <p id="moneda-label" style="font-size:11px; color:#A8A29E; margin:5px 0 0;">Moneda: COP</p>
          </div>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:12px;">
        <div style="background:#22C55E; border-radius:14px; padding:24px; color:#fff;">
          <p style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 6px; opacity:0.85;">Salario neto estimado</p>
          <p id="neto" style="font-size:30px; font-weight:800; margin:0; letter-spacing:-0.5px;">0</p>
        </div>
        <div style="background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:18px; display:flex; flex-direction:column; gap:9px;">
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Salario bruto</span>
            <span id="bruto-label" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span>
          </div>
          <div id="deducciones-list" style="display:flex; flex-direction:column; gap:7px;"></div>
          <div style="height:1px; background:#E2DDD8;"></div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; font-weight:700; color:#57534E;">Total descuentos</span>
            <span id="total-desc" style="font-size:13px; font-weight:700; color:#EF4444;">0</span>
          </div>
        </div>
        <div style="background:#FFF4EC; border:1px solid #FFD4A8; border-radius:10px; padding:14px 16px;">
          <p id="nota-pais" style="font-size:12px; color:#78716C; line-height:1.6; margin:0;"></p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  interface ConfigPais {
    moneda: string;
    nota: string;
    items: { label: string; pct: number }[];
  }
  const tasas: Record<string, ConfigPais> = {
    co: {
      moneda: 'COP',
      nota: 'Colombia: salud (4%), pensión (4%) a cargo del empleado. Retención en la fuente varía según ingresos.',
      items: [
        { label: 'Salud (4%)', pct: 0.04 },
        { label: 'Pensión (4%)', pct: 0.04 },
        { label: 'Retención en la fuente (aprox.)', pct: 0.05 },
      ],
    },
    mx: {
      moneda: 'MXN',
      nota: 'México: el ISR varía según nivel salarial. Las tasas indicadas son aproximadas para salarios medios.',
      items: [
        { label: 'IMSS empleado (~1.65%)', pct: 0.0165 },
        { label: 'INFONAVIT (5%)', pct: 0.05 },
        { label: 'ISR (aprox. 20%)', pct: 0.20 },
      ],
    },
    ar: {
      moneda: 'ARS',
      nota: 'Argentina: las deducciones varían significativamente según sindicato y categoría laboral.',
      items: [
        { label: 'Jubilación (11%)', pct: 0.11 },
        { label: 'Obra social (3%)', pct: 0.03 },
        { label: 'Ganancias (aprox. 12%)', pct: 0.12 },
      ],
    },
    cl: {
      moneda: 'CLP',
      nota: 'Chile: la AFP puede variar entre 10% y 11.44%. El impuesto único depende del tramo de renta.',
      items: [
        { label: 'AFP (10%)', pct: 0.10 },
        { label: 'Salud FONASA/Isapre (7%)', pct: 0.07 },
        { label: 'Impuesto único (aprox.)', pct: 0.05 },
      ],
    },
    pe: {
      moneda: 'PEN',
      nota: 'Perú: EsSalud lo paga el empleador (9%). El empleado aporta a ONP (13%) o AFP (variable).',
      items: [
        { label: 'ONP o AFP (13% aprox.)', pct: 0.13 },
        { label: 'Impuesto 5.a categoría (aprox. 8%)', pct: 0.08 },
      ],
    },
    ec: {
      moneda: 'USD',
      nota: 'Ecuador: aporte al IESS del empleado es 9.45% sobre el salario.',
      items: [
        { label: 'IESS empleado (9.45%)', pct: 0.0945 },
        { label: 'Impuesto a la renta (aprox. 5%)', pct: 0.05 },
      ],
    },
    uy: {
      moneda: 'UYU',
      nota: 'Uruguay: las tasas varían según la categoría fiscal y si el trabajador está en el BPS.',
      items: [
        { label: 'BPS Jubilación (15%)', pct: 0.15 },
        { label: 'BPS Salud (3-8%)', pct: 0.06 },
        { label: 'IRPF (aprox. 10%)', pct: 0.10 },
      ],
    },
    bo: {
      moneda: 'BOB',
      nota: 'Bolivia: el RC-IVA se aplica sobre el total de ingresos menos aportes y mínimo no imponible.',
      items: [
        { label: 'AFP Jubilación (10%)', pct: 0.10 },
        { label: 'AFP Riesgo común (1.71%)', pct: 0.0171 },
        { label: 'RC-IVA (aprox. 3%)', pct: 0.03 },
      ],
    },
    py: {
      moneda: 'PYG',
      nota: 'Paraguay: el IPS incluye la jubilación y el seguro médico del empleado.',
      items: [
        { label: 'IPS empleado (9%)', pct: 0.09 },
        { label: 'IRP (aprox. 8%)', pct: 0.08 },
      ],
    },
    ve: {
      moneda: 'VES',
      nota: 'Venezuela: el sistema salarial es muy volátil. Los cálculos son orientativos sobre salario en bolívares.',
      items: [
        { label: 'IVSS empleado (4%)', pct: 0.04 },
        { label: 'ISLR (aprox. 6%)', pct: 0.06 },
      ],
    },
    cr: {
      moneda: 'CRC',
      nota: 'Costa Rica: las cargas sociales del empleado son del 10.67% del salario bruto.',
      items: [
        { label: 'CCSS enfermedad y maternidad (5.5%)', pct: 0.055 },
        { label: 'CCSS pensión (2.84%)', pct: 0.0284 },
        { label: 'Banco Popular (1%)', pct: 0.01 },
        { label: 'Impuesto sobre la renta (aprox. 5%)', pct: 0.05 },
      ],
    },
    pa: {
      moneda: 'USD',
      nota: 'Panamá: dolarizada. La CSS (Caja de Seguro Social) es el principal descuento del empleado.',
      items: [
        { label: 'CSS empleado (9.75%)', pct: 0.0975 },
        { label: 'Impuesto sobre la renta (aprox. 10%)', pct: 0.10 },
      ],
    },
    do: {
      moneda: 'DOP',
      nota: 'República Dominicana: los aportes a la TSS incluyen pensión y seguro de salud.',
      items: [
        { label: 'AFP pensión (2.87%)', pct: 0.0287 },
        { label: 'ARS salud (3.04%)', pct: 0.0304 },
        { label: 'ISR (aprox. 15%)', pct: 0.15 },
      ],
    },
    gt: {
      moneda: 'GTQ',
      nota: 'Guatemala: el IGSS es el seguro social obligatorio. El ISR se aplica según tramos.',
      items: [
        { label: 'IGSS empleado (4.83%)', pct: 0.0483 },
        { label: 'ISR (aprox. 7%)', pct: 0.07 },
      ],
    },
    hn: {
      moneda: 'HNL',
      nota: 'Honduras: el IHSS y el RAP son los aportes del empleado más relevantes.',
      items: [
        { label: 'IHSS empleado (2.5%)', pct: 0.025 },
        { label: 'RAP empleado (1.5%)', pct: 0.015 },
        { label: 'Impuesto sobre la renta (aprox. 10%)', pct: 0.10 },
      ],
    },
    sv: {
      moneda: 'USD',
      nota: 'El Salvador: dolarizado. Las AFP y el ISSS son los descuentos más comunes.',
      items: [
        { label: 'AFP (7.25%)', pct: 0.0725 },
        { label: 'ISSS salud (3%)', pct: 0.03 },
        { label: 'ISR (aprox. 10%)', pct: 0.10 },
      ],
    },
    ni: {
      moneda: 'NIO',
      nota: 'Nicaragua: el INSS del empleado varía. El IR (impuesto a la renta) tiene tramos progresivos.',
      items: [
        { label: 'INSS empleado (7%)', pct: 0.07 },
        { label: 'IR (aprox. 10%)', pct: 0.10 },
      ],
    },
    cu: {
      moneda: 'CUP',
      nota: 'Cuba: el sistema es estatal. Las deducciones son diferentes para el sector privado (cuentapropistas).',
      items: [
        { label: 'Seguridad Social (5%)', pct: 0.05 },
        { label: 'Impuesto sobre ingresos (aprox. 10%)', pct: 0.10 },
      ],
    },
    pr: {
      moneda: 'USD',
      nota: 'Puerto Rico: territorio de EE.UU. con sistema fiscal propio. Las tasas aplican para residentes locales.',
      items: [
        { label: 'Seguro Social federal (6.2%)', pct: 0.062 },
        { label: 'Medicare (1.45%)', pct: 0.0145 },
        { label: 'Contribución sobre ingresos PR (aprox. 12%)', pct: 0.12 },
      ],
    },
    ca: {
      moneda: 'CAD',
      nota: 'Canadá (Ontario): las tasas varían por provincia. EI y CPP son federales.',
      items: [
        { label: 'CPP (Canada Pension Plan 5.95%)', pct: 0.0595 },
        { label: 'EI (Employment Insurance 1.66%)', pct: 0.0166 },
        { label: 'Impuesto federal + provincial (aprox. 22%)', pct: 0.22 },
      ],
    },
    bz: {
      moneda: 'BZD',
      nota: 'Belice: el Social Security Board gestiona los aportes de empleados y empleadores.',
      items: [
        { label: 'Social Security empleado (5%)', pct: 0.05 },
        { label: 'Impuesto sobre la renta (aprox. 10%)', pct: 0.10 },
      ],
    },
    es: {
      moneda: 'EUR',
      nota: 'España: las cotizaciones a la Seguridad Social del empleado son aproximadamente el 6.47% del salario bruto.',
      items: [
        { label: 'Seguridad Social — contingencias comunes (4.7%)', pct: 0.047 },
        { label: 'Desempleo (1.55%)', pct: 0.0155 },
        { label: 'Formación Profesional (0.1%)', pct: 0.001 },
        { label: 'IRPF (aprox. 15%)', pct: 0.15 },
      ],
    },
  };

  const DEC: Record<string,number> = {USD:2,COP:0,MXN:2,ARS:0,CLP:0,PEN:2,UYU:2,BOB:2,PYG:0,VES:2,CRC:0,DOP:2,GTQ:2,HNL:2,NIO:2,CUP:2,BZD:2,CAD:2,EUR:2};
  function fmt(n: number, moneda: string) {
    const d = DEC[moneda] ?? 2;
    return new Intl.NumberFormat('es',{minimumFractionDigits:d,maximumFractionDigits:d}).format(n) + ' ' + moneda;
  }

  function calcular() {
    const pais = (document.getElementById('pais') as HTMLSelectElement).value;
    const salario = parseFloat((document.getElementById('salario') as HTMLInputElement).value) || 0;
    const config = tasas[pais];
    (document.getElementById('moneda-label') as HTMLElement).textContent = 'Moneda: ' + config.moneda;
    (document.getElementById('bruto-label') as HTMLElement).textContent = fmt(salario, config.moneda);
    (document.getElementById('nota-pais') as HTMLElement).textContent = config.nota;
    let totalDesc = 0;
    const lista = document.getElementById('deducciones-list')!;
    lista.innerHTML = '';
    for (const item of config.items) {
      if (item.pct === 0) continue;
      const monto = salario * item.pct;
      totalDesc += monto;
      const row = document.createElement('div');
      row.style.cssText = 'display:flex; justify-content:space-between;';
      row.innerHTML = '<span style="font-size:12px; color:#78716C;">' + item.label + '</span>' +
        '<span style="font-size:12px; font-weight:600; color:#EF4444;">-' + fmt(monto, config.moneda) + '</span>';
      lista.appendChild(row);
    }
    const neto = salario - totalDesc;
    (document.getElementById('neto') as HTMLElement).textContent = fmt(neto, config.moneda);
    (document.getElementById('total-desc') as HTMLElement).textContent = '-' + fmt(totalDesc, config.moneda);
  }

  document.getElementById('pais')?.addEventListener('change', calcular);
  document.getElementById('salario')?.addEventListener('input', calcular);
  calcular();
</script>
<style>
  @media(max-width:600px){
    div[style*="grid-template-columns:1fr 1fr"]{display:flex!important;flex-direction:column!important;}
  }
</style>
