---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Calculadora de Fondo de Emergencia — Inversax" description="Calcula cuánto dinero necesitas en tu fondo de emergencia según tus gastos mensuales. Soporta todas las monedas de Latinoamérica y España.">
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a><span>›</span>
        <a href="/calculadoras" style="text-decoration:none; color:#A8A29E;">Calculadoras</a><span>›</span>
        <span style="color:#57534E;">Fondo de Emergencia</span>
      </div>
      <h1 style="font-size:clamp(22px,4vw,32px); font-weight:800; color:#1A1A1A; margin:0 0 8px; letter-spacing:-0.3px;">Calculadora de Fondo de Emergencia</h1>
      <p style="font-size:15px; color:#57534E; line-height:1.65; margin:0;">Calcula el colchón financiero que necesitas para estar protegido ante imprevistos.</p>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:40px 20px;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
      <div style="background:#fff; border:1px solid #E2DDD8; border-radius:14px; padding:28px;">
        <h2 style="font-size:16px; font-weight:700; color:#1A1A1A; margin:0 0 20px;">Tus gastos mensuales</h2>
        <div style="display:flex; flex-direction:column; gap:16px;">
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Moneda</label>
            <select id="moneda" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="USD">USD — Dólar (EC, PA, SV, PR)</option>
              <option value="COP">COP — Peso colombiano</option>
              <option value="MXN">MXN — Peso mexicano</option>
              <option value="ARS">ARS — Peso argentino</option>
              <option value="CLP">CLP — Peso chileno</option>
              <option value="PEN">PEN — Sol peruano</option>
              <option value="UYU">UYU — Peso uruguayo</option>
              <option value="BOB">BOB — Boliviano</option>
              <option value="PYG">PYG — Guaraní paraguayo</option>
              <option value="VES">VES — Bolívar venezolano</option>
              <option value="CRC">CRC — Colón costarricense</option>
              <option value="DOP">DOP — Peso dominicano</option>
              <option value="GTQ">GTQ — Quetzal guatemalteco</option>
              <option value="HNL">HNL — Lempira hondureño</option>
              <option value="NIO">NIO — Córdoba nicaragüense</option>
              <option value="CUP">CUP — Peso cubano</option>
              <option value="BZD">BZD — Dólar de Belice</option>
              <option value="CAD">CAD — Dólar canadiense</option>
              <option value="EUR">EUR — Euro (España)</option>
            </select>
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Alquiler / Hipoteca</label>
            <input id="alquiler" type="number" value="500" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Alimentación</label>
            <input id="comida" type="number" value="300" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Transporte</label>
            <input id="transporte" type="number" value="100" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Servicios (agua, luz, internet)</label>
            <input id="servicios" type="number" value="80" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Otros gastos fijos</label>
            <input id="otros" type="number" value="120" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Meses de cobertura deseados</label>
            <select id="cobertura" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="3">3 meses (mínimo recomendado)</option>
              <option value="6" selected>6 meses (estándar)</option>
              <option value="9">9 meses (conservador)</option>
              <option value="12">12 meses (muy conservador)</option>
            </select>
          </div>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:14px;">
        <div style="background:#22C55E; border-radius:14px; padding:24px; color:#fff;">
          <p style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 6px; opacity:0.85;">Fondo de emergencia necesario</p>
          <p id="fondo" style="font-size:28px; font-weight:800; margin:0; letter-spacing:-0.5px;">0</p>
        </div>
        <div style="background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:18px; display:flex; flex-direction:column; gap:10px;">
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Gastos mensuales totales</span>
            <span id="total-mensual" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Cobertura elegida</span>
            <span id="cobertura-label" style="font-size:13px; font-weight:700; color:#1A1A1A;">6 meses</span>
          </div>
          <div style="height:1px; background:#E2DDD8;"></div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Mínimo recomendado (3 meses)</span>
            <span id="minimo" style="font-size:13px; font-weight:700; color:#78716C;">0</span>
          </div>
        </div>
        <div style="background:#FFF4EC; border:1px solid #FFD4A8; border-radius:10px; padding:14px 16px;">
          <p style="font-size:12px; color:#78716C; line-height:1.6; margin:0;">Guarda tu fondo de emergencia en una cuenta líquida y de bajo riesgo: cuenta de ahorro, CDT o fondo monetario. No lo inviertas en activos volátiles.</p>
        </div>
      </div>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:0 20px 60px;" class="prose">
    <h2>¿Qué es un fondo de emergencia?</h2>
    <p>Un <strong>fondo de emergencia</strong> es un colchón de dinero líquido reservado exclusivamente para gastos imprevistos: pérdida de empleo, emergencia médica, reparación urgente del carro o del hogar, o cualquier gasto que no podías anticipar. No es un fondo de inversión, no es para vacaciones, no es para oportunidades: es exclusivamente para emergencias.</p>
    <p>Sin fondo de emergencia, cualquier imprevisto te fuerza a endeudarte (a tasas altas) o a liquidar inversiones en mal momento. Es la base de toda estrategia financiera sólida.</p>

    <h2>¿Cómo usar esta calculadora?</h2>
    <ul>
      <li><strong>Ingresa cada categoría de gasto mensual</strong> con honestidad. Usa tus extractos bancarios reales, no estimaciones optimistas.</li>
      <li><strong>Elige los meses de cobertura:</strong> la regla general es 3-6 meses. Si tu trabajo es inestable, eres independiente o tienes dependientes a cargo, apunta a 9-12 meses.</li>
      <li>El resultado es el mínimo que debes mantener siempre líquido, sin importar qué pase en los mercados.</li>
    </ul>

    <h2>¿Cuántos meses debo tener?</h2>
    <ul>
      <li><strong>3 meses:</strong> empleado estable, sector público, pareja con doble ingreso y sin dependientes. El mínimo absoluto recomendado.</li>
      <li><strong>6 meses:</strong> empleado del sector privado, profesional independiente con clientes estables. El estándar más extendido.</li>
      <li><strong>9-12 meses:</strong> freelancer, emprendedor, sector económicamente volátil, único ingreso en el hogar con dependientes.</li>
    </ul>

    <h2>¿Dónde guardar el fondo de emergencia?</h2>
    <p>El fondo de emergencia debe ser <strong>líquido y de bajo riesgo</strong>. No lo pongas en acciones, criptomonedas ni inversiones de plazo fijo largo. Las opciones más comunes:</p>
    <ul>
      <li><strong>Cuenta de ahorro de alto rendimiento:</strong> ideal. Accesible inmediatamente y con algo de rendimiento.</li>
      <li><strong>CDT / Depósito a plazo fijo a 30 días:</strong> algo más de rendimiento con liquidez mensual.</li>
      <li><strong>Fondo monetario o del mercado de dinero:</strong> muy bajo riesgo, rendimiento modesto, acceso rápido.</li>
    </ul>
    <p>No lo guardes en efectivo físico (riesgo de robo o inflación) ni lo mezcles con tu cuenta corriente (tentación de gastarlo).</p>

    <h2>¿Cómo construir el fondo si no tienes nada?</h2>
    <p>Usa nuestra <a href="/calculadoras/meta-ahorro">calculadora de meta de ahorro</a>: pon el monto de tu fondo de emergencia como meta y calcula cuánto debes ahorrar mensualmente para alcanzarlo en 6-12 meses. Prioriza este objetivo antes de invertir en cualquier otra cosa.</p>
  </div>
</Layout>

<script>
  const DEC: Record<string,number> = {USD:2,COP:0,MXN:2,ARS:0,CLP:0,PEN:2,UYU:2,BOB:2,PYG:0,VES:2,CRC:0,DOP:2,GTQ:2,HNL:2,NIO:2,CUP:2,BZD:2,CAD:2,EUR:2};
  function fmt(n: number, m: string) {
    const d = DEC[m] ?? 2;
    return new Intl.NumberFormat('es',{minimumFractionDigits:d,maximumFractionDigits:d}).format(n) + ' ' + m;
  }
  function calcular() {
    const m   = (document.getElementById('moneda')     as HTMLSelectElement).value;
    const cob = parseFloat((document.getElementById('cobertura')  as HTMLSelectElement).value) || 6;
    const a   = parseFloat((document.getElementById('alquiler')   as HTMLInputElement).value) || 0;
    const c   = parseFloat((document.getElementById('comida')     as HTMLInputElement).value) || 0;
    const t   = parseFloat((document.getElementById('transporte') as HTMLInputElement).value) || 0;
    const s   = parseFloat((document.getElementById('servicios')  as HTMLInputElement).value) || 0;
    const o   = parseFloat((document.getElementById('otros')      as HTMLInputElement).value) || 0;
    const mensual = a + c + t + s + o;
    const fondo   = mensual * cob;
    const minimo  = mensual * 3;
    document.getElementById('fondo')!.textContent          = fmt(fondo, m);
    document.getElementById('total-mensual')!.textContent  = fmt(mensual, m);
    document.getElementById('cobertura-label')!.textContent = cob + ' meses';
    document.getElementById('minimo')!.textContent         = fmt(minimo, m);
  }
  ['moneda','alquiler','comida','transporte','servicios','otros','cobertura'].forEach(id => document.getElementById(id)?.addEventListener('input', calcular));
  calcular();
</script>
<style>@media(max-width:600px){div[style*="grid-template-columns:1fr 1fr"]{display:flex!important;flex-direction:column!important;}}</style>
