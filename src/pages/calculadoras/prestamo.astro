---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Calculadora de Préstamo — Inversax" description="Calcula la cuota mensual de tu préstamo y el total de intereses pagados. Soporta todas las monedas de Latinoamérica y España.">
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a><span>›</span>
        <a href="/calculadoras" style="text-decoration:none; color:#A8A29E;">Calculadoras</a><span>›</span>
        <span style="color:#57534E;">Préstamo</span>
      </div>
      <h1 style="font-size:clamp(22px,4vw,32px); font-weight:800; color:#1A1A1A; margin:0 0 8px; letter-spacing:-0.3px;">Calculadora de Préstamo</h1>
      <p style="font-size:15px; color:#57534E; line-height:1.65; margin:0;">Calcula tu cuota mensual y cuánto pagarás en total, incluyendo los intereses.</p>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:40px 20px;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
      <div style="background:#fff; border:1px solid #E2DDD8; border-radius:14px; padding:28px;">
        <h2 style="font-size:16px; font-weight:700; color:#1A1A1A; margin:0 0 20px;">Condiciones del préstamo</h2>
        <div style="display:flex; flex-direction:column; gap:16px;">
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Moneda</label>
            <select id="moneda" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="USD">USD — Dólar (EC, PA, SV, PR)</option>
              <option value="COP">COP — Peso colombiano</option>
              <option value="MXN">MXN — Peso mexicano</option>
              <option value="ARS">ARS — Peso argentino</option>
              <option value="CLP">CLP — Peso chileno</option>
              <option value="PEN">PEN — Sol peruano</option>
              <option value="UYU">UYU — Peso uruguayo</option>
              <option value="BOB">BOB — Boliviano</option>
              <option value="PYG">PYG — Guaraní paraguayo</option>
              <option value="VES">VES — Bolívar venezolano</option>
              <option value="CRC">CRC — Colón costarricense</option>
              <option value="DOP">DOP — Peso dominicano</option>
              <option value="GTQ">GTQ — Quetzal guatemalteco</option>
              <option value="HNL">HNL — Lempira hondureño</option>
              <option value="NIO">NIO — Córdoba nicaragüense</option>
              <option value="CUP">CUP — Peso cubano</option>
              <option value="BZD">BZD — Dólar de Belice</option>
              <option value="CAD">CAD — Dólar canadiense</option>
              <option value="EUR">EUR — Euro (España)</option>
            </select>
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Monto del préstamo</label>
            <input id="monto" type="number" value="10000" min="1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Tasa de interés anual (%)</label>
            <input id="tasa" type="number" value="12" min="0" step="0.1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Plazo (meses)</label>
            <input id="plazo" type="number" value="36" min="1" max="600" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:14px;">
        <div style="background:#EF4444; border-radius:14px; padding:24px; color:#fff;">
          <p style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 6px; opacity:0.85;">Cuota mensual</p>
          <p id="cuota" style="font-size:32px; font-weight:800; margin:0; letter-spacing:-0.5px;">0</p>
        </div>
        <div style="background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:18px; display:flex; flex-direction:column; gap:10px;">
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Capital prestado</span>
            <span id="capital" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Total de intereses</span>
            <span id="intereses" style="font-size:13px; font-weight:700; color:#EF4444;">0</span>
          </div>
          <div style="height:1px; background:#E2DDD8;"></div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Total a pagar</span>
            <span id="total" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Costo del crédito (%)</span>
            <span id="costo-pct" style="font-size:13px; font-weight:700; color:#EF4444;">0%</span>
          </div>
        </div>
        <div style="background:#FFF4EC; border:1px solid #FFD4A8; border-radius:10px; padding:14px 16px;">
          <p style="font-size:12px; color:#78716C; line-height:1.6; margin:0;">Usa el sistema de amortización francés (cuota fija). No incluye seguros ni comisiones adicionales que pueda cobrar el banco.</p>
        </div>
      </div>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:0 20px 60px;" class="prose">
    <h2>¿Cómo funciona el cálculo de un préstamo?</h2>
    <p>Esta calculadora usa el <strong>sistema de amortización francés</strong> (cuota fija), el más común en créditos de consumo, hipotecas y préstamos personales en Latinoamérica y España. En este sistema, pagas la misma cuota todos los meses, pero la proporción entre capital e intereses cambia: al inicio pagas más intereses y menos capital; al final, más capital y menos intereses.</p>

    <h2>¿Cómo usar esta calculadora?</h2>
    <ul>
      <li><strong>Monto del préstamo:</strong> el capital que solicitarás o que ya te aprobaron. No incluyas intereses ni costos adicionales.</li>
      <li><strong>Tasa de interés anual:</strong> la tasa nominal anual que cobra el banco o entidad financiera. Ojo: en algunos países se publica la tasa efectiva anual (TEA) y en otros la tasa nominal anual (TNA). Verifica cuál te están dando.</li>
      <li><strong>Plazo en meses:</strong> la duración del crédito. Un préstamo a 36 meses = 3 años.</li>
    </ul>

    <h2>¿Cómo interpretar los resultados?</h2>
    <p>Los dos números más importantes son la <strong>cuota mensual</strong> y el <strong>total de intereses</strong>. El total de intereses representa el costo real del crédito: es lo que pagas de más por no tener el dinero hoy. El <strong>costo del crédito en %</strong> expresa ese sobrecosto como porcentaje del capital prestado.</p>

    <h2>El impacto del plazo en el costo total</h2>
    <p>Ampliar el plazo reduce la cuota mensual, pero dispara el costo total. Ejemplo con un préstamo de <strong>10.000 USD al 12% anual</strong>:</p>
    <ul>
      <li>A <strong>12 meses:</strong> cuota 888 USD/mes — total intereses: 666 USD</li>
      <li>A <strong>36 meses:</strong> cuota 332 USD/mes — total intereses: 1.957 USD</li>
      <li>A <strong>60 meses:</strong> cuota 222 USD/mes — total intereses: 3.347 USD</li>
    </ul>
    <p>Un plazo 5 veces mayor paga 5 veces más en intereses. Siempre que puedas, elige el plazo más corto que puedas pagar cómodamente.</p>

    <h2>Tasas de préstamo de referencia por país (2026)</h2>
    <ul>
      <li><strong>Colombia:</strong> crédito de consumo ~24-30% E.A.</li>
      <li><strong>México:</strong> préstamo personal ~25-40% anual</li>
      <li><strong>Chile:</strong> crédito de consumo ~15-25% anual</li>
      <li><strong>Perú:</strong> préstamo personal ~30-50% E.A.</li>
      <li><strong>España:</strong> préstamo personal ~6-10% TAE</li>
    </ul>
    <p>Para ver el detalle mes a mes de tu préstamo, visita nuestra <a href="/calculadoras/amortizacion">tabla de amortización</a>.</p>

    <h2>Preguntas frecuentes</h2>
    <h3>¿La calculadora incluye seguros y comisiones?</h3>
    <p>No. Los bancos pueden añadir seguros de vida, comisiones de apertura y otros costos que elevan el costo real (APR o CAE). Para comparar préstamos de distintas entidades, pide siempre la <strong>Tasa Efectiva Anual (TEA)</strong> o el <strong>Costo Anual Efectivo (CAE)</strong>, que incluye todos los costos.</p>
    <h3>¿Puedo hacer pagos anticipados?</h3>
    <p>Depende del contrato. En muchos países, los prepagos parciales o totales tienen un cargo (penalidad). Si tu banco lo permite sin costo, siempre conviene: cada peso extra de capital que pagas reduce los intereses futuros.</p>
  </div>
</Layout>

<script>
  const DEC: Record<string,number> = {USD:2,COP:0,MXN:2,ARS:0,CLP:0,PEN:2,UYU:2,BOB:2,PYG:0,VES:2,CRC:0,DOP:2,GTQ:2,HNL:2,NIO:2,CUP:2,BZD:2,CAD:2,EUR:2};
  function fmt(n: number, m: string) {
    const d = DEC[m] ?? 2;
    return new Intl.NumberFormat('es',{minimumFractionDigits:d,maximumFractionDigits:d}).format(n) + ' ' + m;
  }
  function calcular() {
    const m     = (document.getElementById('moneda') as HTMLSelectElement).value;
    const P     = parseFloat((document.getElementById('monto') as HTMLInputElement).value) || 0;
    const tasa  = parseFloat((document.getElementById('tasa')  as HTMLInputElement).value) || 0;
    const n     = parseFloat((document.getElementById('plazo') as HTMLInputElement).value) || 1;
    const rm    = tasa / 100 / 12;
    let cuota = 0;
    if (rm === 0) {
      cuota = P / n;
    } else {
      cuota = P * rm * Math.pow(1 + rm, n) / (Math.pow(1 + rm, n) - 1);
    }
    const total     = cuota * n;
    const intereses = total - P;
    const costoPct  = P > 0 ? (intereses / P) * 100 : 0;
    document.getElementById('cuota')!.textContent     = fmt(cuota, m);
    document.getElementById('capital')!.textContent   = fmt(P, m);
    document.getElementById('intereses')!.textContent = fmt(intereses, m);
    document.getElementById('total')!.textContent     = fmt(total, m);
    document.getElementById('costo-pct')!.textContent = costoPct.toFixed(1) + '%';
  }
  ['moneda','monto','tasa','plazo'].forEach(id => document.getElementById(id)?.addEventListener('input', calcular));
  calcular();
</script>
<style>@media(max-width:600px){div[style*="grid-template-columns:1fr 1fr"]{display:flex!important;flex-direction:column!important;}}</style>
