---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Calculadora de Interés Compuesto — Inversax" description="Calculadora de interés compuesto gratis para Colombia, México y toda Latinoamérica. Proyecta capital final, ganancias y rentabilidad con aportes mensuales. Soporta 19 monedas.">
  <Fragment slot="head">
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Qué tasa anual debo usar en la calculadora de interés compuesto?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Depende del instrumento. Fondos indexados tipo S&P 500 han rendido ~10% anual histórico antes de inflación. Para cálculos conservadores en dólares usa 6–7%. Para monedas locales de alta inflación como el peso argentino o el bolívar, el rendimiento real descontada la inflación es lo que importa más que la tasa nominal."
          }
        },
        {
          "@type": "Question",
          "name": "¿La calculadora de interés compuesto incluye la inflación?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Los resultados son en términos nominales. Para obtener el valor real, resta la inflación esperada de tu tasa anual. Si esperas 8% de rendimiento y 4% de inflación, usa 4% en la calculadora para ver el crecimiento real del poder adquisitivo."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cómo funciona la capitalización mensual del interés compuesto?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "La calculadora usa capitalización mensual: divide la tasa anual entre 12 y aplica el interés cada mes. Los intereses de enero generan intereses en febrero y así sucesivamente. Fórmula: Capital × (1 + tasa/12)^(años×12) más el valor futuro de los aportes mensuales."
          }
        },
        {
          "@type": "Question",
          "name": "¿Desde cuánto capital puedo empezar a aprovechar el interés compuesto en Latinoamérica?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Puedes empezar con cualquier monto. Brokers como Exness, XTB o XM permiten abrir cuenta con 10–100 USD y acceder a ETFs o fondos indexados desde Colombia, México, Perú, Chile y el resto de Latinoamérica."
          }
        }
      ]
    }
    </script>
  </Fragment>
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a>
        <span>›</span>
        <a href="/calculadoras" style="text-decoration:none; color:#A8A29E;">Calculadoras</a>
        <span>›</span>
        <span style="color:#57534E;">Interés Compuesto</span>
      </div>
      <h1 style="font-size:clamp(22px,4vw,32px); font-weight:800; color:#1A1A1A; margin:0 0 8px; letter-spacing:-0.3px;">Calculadora de Interés Compuesto</h1>
      <p style="font-size:15px; color:#57534E; line-height:1.65; margin:0;">Descubre el poder del interés compuesto: el dinero que ganas genera más ganancias con el tiempo.</p>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:40px 20px;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
      <div style="background:#fff; border:1px solid #E2DDD8; border-radius:14px; padding:28px;">
        <h2 style="font-size:16px; font-weight:700; color:#1A1A1A; margin:0 0 20px;">Parámetros</h2>
        <div style="display:flex; flex-direction:column; gap:16px;">
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Moneda</label>
            <select id="moneda" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="USD">USD — Dólar (EC, PA, SV, PR)</option>
              <option value="COP">COP — Peso colombiano</option>
              <option value="MXN">MXN — Peso mexicano</option>
              <option value="ARS">ARS — Peso argentino</option>
              <option value="CLP">CLP — Peso chileno</option>
              <option value="PEN">PEN — Sol peruano</option>
              <option value="UYU">UYU — Peso uruguayo</option>
              <option value="BOB">BOB — Boliviano</option>
              <option value="PYG">PYG — Guaraní paraguayo</option>
              <option value="VES">VES — Bolívar venezolano</option>
              <option value="CRC">CRC — Colón costarricense</option>
              <option value="DOP">DOP — Peso dominicano</option>
              <option value="GTQ">GTQ — Quetzal guatemalteco</option>
              <option value="HNL">HNL — Lempira hondureño</option>
              <option value="NIO">NIO — Córdoba nicaragüense</option>
              <option value="CUP">CUP — Peso cubano</option>
              <option value="BZD">BZD — Dólar de Belice</option>
              <option value="CAD">CAD — Dólar canadiense</option>
              <option value="EUR">EUR — Euro (España)</option>
            </select>
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Capital inicial</label>
            <input id="capital" type="number" value="1000" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Aporte mensual</label>
            <input id="aporte" type="number" value="100" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Tasa anual (%)</label>
            <input id="tasa" type="number" value="8" min="0" max="100" step="0.1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Plazo (años)</label>
            <input id="anos" type="number" value="10" min="1" max="50" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:14px;">
        <div style="background:#FF8C42; border-radius:14px; padding:24px; color:#fff;">
          <p style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 6px; opacity:0.85;">Capital final</p>
          <p id="resultado-total" style="font-size:32px; font-weight:800; margin:0; letter-spacing:-0.5px;">0</p>
        </div>
        <div style="background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:18px; display:flex; flex-direction:column; gap:10px;">
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Capital invertido</span>
            <span id="resultado-invertido" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Ganancias por interés</span>
            <span id="resultado-ganancias" style="font-size:13px; font-weight:700; color:#22C55E;">0</span>
          </div>
          <div style="height:1px; background:#E2DDD8;"></div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Rentabilidad total</span>
            <span id="resultado-rentabilidad" style="font-size:13px; font-weight:700; color:#FF8C42;">0%</span>
          </div>
        </div>
        <div style="background:#FFF4EC; border:1px solid #FFD4A8; border-radius:10px; padding:14px 16px;">
          <p style="font-size:12px; color:#78716C; line-height:1.6; margin:0;">Cálculo con capitalización mensual. No incluye impuestos ni inflación. Es una estimación orientativa.</p>
        </div>
      </div>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:0 20px 60px;" class="prose">
    <h2>¿Qué es el interés compuesto?</h2>
    <p>El interés compuesto es el proceso por el cual los intereses generados por una inversión se reinvierten, de modo que en el siguiente período también generan intereses. A diferencia del interés simple (donde solo el capital original produce rendimientos), el interés compuesto hace que tu dinero crezca de forma <strong>exponencial</strong> con el tiempo.</p>
    <p>Albert Einstein lo llamó "la octava maravilla del mundo". Quien lo entiende, lo gana; quien no, lo paga. La clave es una sola: <strong>empezar cuanto antes</strong>.</p>

    <h2>¿Cómo usar esta calculadora?</h2>
    <ul>
      <li><strong>Moneda:</strong> elige la moneda de tu país. Los resultados se formatearán correctamente (pesos sin decimales, dólares con dos decimales, etc.).</li>
      <li><strong>Capital inicial:</strong> el dinero que ya tienes disponible para invertir hoy.</li>
      <li><strong>Aporte mensual:</strong> cuánto agregarás cada mes. Puedes dejarlo en 0 para calcular solo el crecimiento del capital inicial.</li>
      <li><strong>Tasa anual:</strong> el rendimiento anual esperado. Usa tasas conservadoras: 6–8% en dólares para carteras diversificadas, más alto para mercados locales con mayor inflación.</li>
      <li><strong>Plazo:</strong> los años que mantendrás la inversión. El impacto del tiempo es enorme: 20 años produce resultados radicalmente distintos a 10.</li>
    </ul>

    <h2>¿Cómo interpretar los resultados?</h2>
    <p>El resultado más importante no es el <strong>capital final</strong>, sino la diferencia entre "capital invertido" y "ganancias por interés". Esa diferencia representa el dinero que el mercado generó por ti sin que trabajaras por él.</p>
    <p>Si las ganancias superan ampliamente lo que aportaste, el interés compuesto está haciendo su magia. Si son similares o menores, probablemente el plazo es corto o la tasa baja. Ajusta y vuelve a calcular.</p>

    <h2>Ejemplo práctico</h2>
    <p>Imagina que inviertes <strong>5.000 USD</strong> hoy y aportas <strong>200 USD al mes</strong> durante <strong>25 años</strong> con una tasa del <strong>8% anual</strong>:</p>
    <ul>
      <li>Total aportado: 65.000 USD (5.000 inicial + 200 × 300 meses)</li>
      <li>Capital final: aprox. 193.000 USD</li>
      <li>Ganancias: aprox. 128.000 USD — casi el doble de lo que pusiste</li>
    </ul>
    <p>Esos 128.000 USD extra no requirieron trabajo adicional. Solo requirieron tiempo y consistencia. Este es el poder del interés compuesto.</p>

    <h2>Preguntas frecuentes</h2>
    <h3>¿Qué tasa debo usar?</h3>
    <p>Depende del instrumento. Fondos indexados tipo S&P 500 han rendido ~10% anual histórico (antes de inflación). Para cálculos conservadores en dólares usa 6–7%. Para monedas locales de alta inflación como el peso argentino o el bolívar, la tasa nominal puede ser muy alta, pero el rendimiento real (descontada inflación) importa más.</p>
    <h3>¿La calculadora incluye inflación?</h3>
    <p>No. Los resultados son en términos nominales. Para obtener el valor real, resta la inflación esperada de tu tasa anual. Si esperas 8% de rendimiento y 4% de inflación, usa 4% en la calculadora para ver el crecimiento real del poder adquisitivo.</p>
    <h3>¿Con qué brokers puedo invertir para aprovechar el interés compuesto?</h3>
    <p>Para invertir en ETFs o fondos indexados desde Latinoamérica, brokers como <a href="/brokers/co" style="color:#FF8C42;">Exness, XTB o Interactive Brokers</a> permiten acceder a mercados globales con comisiones bajas.</p>
  </div>
</Layout>

<script>
  const DEC: Record<string,number> = {USD:2,COP:0,MXN:2,ARS:0,CLP:0,PEN:2,UYU:2,BOB:2,PYG:0,VES:2,CRC:0,DOP:2,GTQ:2,HNL:2,NIO:2,CUP:2,BZD:2,CAD:2,EUR:2};
  function fmt(n: number, m: string) {
    const d = DEC[m] ?? 2;
    return new Intl.NumberFormat('es',{minimumFractionDigits:d,maximumFractionDigits:d}).format(n) + ' ' + m;
  }
  function calcular() {
    const m      = (document.getElementById('moneda') as HTMLSelectElement).value;
    const capital = parseFloat((document.getElementById('capital') as HTMLInputElement).value) || 0;
    const aporte  = parseFloat((document.getElementById('aporte')  as HTMLInputElement).value) || 0;
    const tasa    = parseFloat((document.getElementById('tasa')    as HTMLInputElement).value) || 0;
    const anos    = parseFloat((document.getElementById('anos')    as HTMLInputElement).value) || 0;
    const r = tasa / 100 / 12;
    const n = anos * 12;
    let total = 0;
    if (r === 0) {
      total = capital + aporte * n;
    } else {
      total = capital * Math.pow(1 + r, n) + aporte * ((Math.pow(1 + r, n) - 1) / r);
    }
    const invertido = capital + aporte * n;
    const ganancias = total - invertido;
    const rentabilidad = invertido > 0 ? (ganancias / invertido) * 100 : 0;
    document.getElementById('resultado-total')!.textContent       = fmt(total, m);
    document.getElementById('resultado-invertido')!.textContent   = fmt(invertido, m);
    document.getElementById('resultado-ganancias')!.textContent   = fmt(ganancias, m);
    document.getElementById('resultado-rentabilidad')!.textContent = rentabilidad.toFixed(1) + '%';
  }
  ['moneda','capital','aporte','tasa','anos'].forEach(id => document.getElementById(id)?.addEventListener('input', calcular));
  calcular();
</script>
<style>
  @media(max-width:600px){
    div[style*="grid-template-columns:1fr 1fr"]{display:flex!important;flex-direction:column!important;}
  }
</style>
