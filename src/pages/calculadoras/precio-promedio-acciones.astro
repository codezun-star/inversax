---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Calculadora de Precio Promedio de Acciones — Inversax" description="Calcula el precio promedio ponderado de tus compras de acciones o cripto. Ideal para promediar a la baja y conocer tu punto de equilibrio. Con ganancia/pérdida actual. 19 monedas.">
  <Fragment slot="head">
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cómo se calcula el precio promedio de acciones?",
          "acceptedAnswer": { "@type": "Answer", "text": "Se suma el dinero invertido en todas las compras y se divide entre el número total de acciones adquiridas. Es un promedio ponderado: las compras más grandes pesan más. El resultado es tu costo medio por acción." }
        },
        {
          "@type": "Question",
          "name": "¿Qué significa promediar a la baja?",
          "acceptedAnswer": { "@type": "Answer", "text": "Promediar a la baja es comprar más acciones cuando el precio ha caído para reducir tu precio promedio de compra. Baja tu punto de equilibrio, pero aumenta tu exposición: solo tiene sentido si sigues confiando en el activo." }
        },
        {
          "@type": "Question",
          "name": "¿El precio promedio es mi punto de equilibrio?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sí. Tu precio promedio es el valor al que tu inversión ni gana ni pierde (sin contar comisiones). Por encima de ese precio tienes ganancia; por debajo, pérdida." }
        }
      ]
    }
    </script>
  </Fragment>
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a><span>›</span>
        <a href="/calculadoras" style="text-decoration:none; color:#A8A29E;">Calculadoras</a><span>›</span>
        <span style="color:#57534E;">Precio Promedio de Acciones</span>
      </div>
      <h1 style="font-size:clamp(22px,4vw,32px); font-weight:800; color:#1A1A1A; margin:0 0 8px; letter-spacing:-0.3px;">Precio Promedio de Acciones</h1>
      <p style="font-size:15px; color:#57534E; line-height:1.65; margin:0;">Calcula tu costo promedio ponderado tras varias compras y tu ganancia o pérdida actual.</p>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:40px 20px;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
      <div style="background:#fff; border:1px solid #E2DDD8; border-radius:14px; padding:28px;">
        <h2 style="font-size:16px; font-weight:700; color:#1A1A1A; margin:0 0 20px;">Tus compras</h2>
        <div style="display:flex; flex-direction:column; gap:16px;">
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Moneda</label>
            <select id="moneda" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="USD">USD — Dólar (EC, PA, SV, PR)</option>
              <option value="COP">COP — Peso colombiano</option>
              <option value="MXN">MXN — Peso mexicano</option>
              <option value="ARS">ARS — Peso argentino</option>
              <option value="CLP">CLP — Peso chileno</option>
              <option value="PEN">PEN — Sol peruano</option>
              <option value="UYU">UYU — Peso uruguayo</option>
              <option value="EUR">EUR — Euro (España)</option>
            </select>
          </div>
          <div style="display:flex; gap:10px;">
            <div style="flex:1;"><label style="font-size:12px; font-weight:600; color:#78716C; display:block; margin-bottom:4px;">Compra 1 — cantidad</label><input id="q1" type="number" value="10" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:9px 12px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" /></div>
            <div style="flex:1;"><label style="font-size:12px; font-weight:600; color:#78716C; display:block; margin-bottom:4px;">Precio</label><input id="p1" type="number" value="50" min="0" step="0.01" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:9px 12px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" /></div>
          </div>
          <div style="display:flex; gap:10px;">
            <div style="flex:1;"><label style="font-size:12px; font-weight:600; color:#78716C; display:block; margin-bottom:4px;">Compra 2 — cantidad</label><input id="q2" type="number" value="10" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:9px 12px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" /></div>
            <div style="flex:1;"><label style="font-size:12px; font-weight:600; color:#78716C; display:block; margin-bottom:4px;">Precio</label><input id="p2" type="number" value="40" min="0" step="0.01" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:9px 12px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" /></div>
          </div>
          <div style="display:flex; gap:10px;">
            <div style="flex:1;"><label style="font-size:12px; font-weight:600; color:#78716C; display:block; margin-bottom:4px;">Compra 3 — cantidad</label><input id="q3" type="number" value="0" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:9px 12px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" /></div>
            <div style="flex:1;"><label style="font-size:12px; font-weight:600; color:#78716C; display:block; margin-bottom:4px;">Precio</label><input id="p3" type="number" value="0" min="0" step="0.01" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:9px 12px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" /></div>
          </div>
          <div style="display:flex; gap:10px;">
            <div style="flex:1;"><label style="font-size:12px; font-weight:600; color:#78716C; display:block; margin-bottom:4px;">Compra 4 — cantidad</label><input id="q4" type="number" value="0" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:9px 12px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" /></div>
            <div style="flex:1;"><label style="font-size:12px; font-weight:600; color:#78716C; display:block; margin-bottom:4px;">Precio</label><input id="p4" type="number" value="0" min="0" step="0.01" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:9px 12px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" /></div>
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Precio actual (opcional)</label>
            <input id="actual" type="number" value="55" min="0" step="0.01" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:14px;">
        <div style="background:#FF8C42; border-radius:14px; padding:24px; color:#fff;">
          <p style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 6px; opacity:0.85;">Precio promedio por acción</p>
          <p id="r-prom" style="font-size:32px; font-weight:800; margin:0; letter-spacing:-0.5px;">0</p>
        </div>
        <div style="background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:18px; display:flex; flex-direction:column; gap:10px;">
          <div style="display:flex; justify-content:space-between;"><span style="font-size:13px; color:#57534E;">Total de acciones</span><span id="r-acc" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span></div>
          <div style="display:flex; justify-content:space-between;"><span style="font-size:13px; color:#57534E;">Total invertido</span><span id="r-inv" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span></div>
          <div style="display:flex; justify-content:space-between;"><span style="font-size:13px; color:#57534E;">Ganancia/pérdida actual</span><span id="r-pl" style="font-size:13px; font-weight:700; color:#FF8C42;">0</span></div>
        </div>
        <div style="background:#FFF4EC; border:1px solid #FFD4A8; border-radius:10px; padding:14px 16px;">
          <p style="font-size:12px; color:#78716C; line-height:1.6; margin:0;">El precio promedio es tu punto de equilibrio (sin comisiones). Deja en 0 las compras que no uses.</p>
        </div>
      </div>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:0 20px 60px;" class="prose">
    <h2>¿Cómo se calcula el precio promedio?</h2>
    <p>El <strong>precio promedio</strong> de tus acciones es un promedio ponderado: se suma todo el dinero invertido y se divide entre el número total de acciones. Las compras de mayor tamaño influyen más en el resultado. Ese precio es tu <strong>punto de equilibrio</strong>: por encima ganas, por debajo pierdes.</p>

    <h2>¿Cómo usar esta calculadora?</h2>
    <ul>
      <li><strong>Cantidad y precio de cada compra:</strong> registra hasta cuatro operaciones.</li>
      <li><strong>Precio actual:</strong> opcional, para ver tu ganancia o pérdida latente.</li>
    </ul>

    <h2>Promediar a la baja: cuándo tiene sentido</h2>
    <p>Comprar más cuando el precio cae reduce tu promedio, pero aumenta tu exposición al activo. Solo conviene si tu tesis de inversión sigue intacta. Para evaluar el rendimiento final de la posición usa la <a href="/calculadoras/roi">calculadora de ROI</a>, y antes de comprar revisa el <a href="/calculadoras/precio-justo">precio justo de la acción</a>.</p>

    <h2>Preguntas frecuentes</h2>
    <h3>¿Funciona para criptomonedas?</h3>
    <p>Sí. El cálculo es idéntico para acciones, ETFs o cripto: cantidad por precio en cada compra.</p>
    <h3>¿Incluye comisiones?</h3>
    <p>No. Para un punto de equilibrio exacto, súmalas al precio de compra. Compara comisiones con la <a href="/calculadoras/comision-broker">calculadora de comisión de broker</a>.</p>
  </div>
</Layout>

<script>
  const DEC: Record<string,number> = {USD:2,COP:0,MXN:2,ARS:0,CLP:0,PEN:2,UYU:2,BOB:2,PYG:0,VES:2,CRC:0,DOP:2,GTQ:2,HNL:2,NIO:2,CUP:2,BZD:2,CAD:2,EUR:2};
  function fmt(n: number, m: string) {
    const d = DEC[m] ?? 2;
    return new Intl.NumberFormat('es',{minimumFractionDigits:d,maximumFractionDigits:d}).format(n) + ' ' + m;
  }
  function calcular() {
    const m = (document.getElementById('moneda') as HTMLSelectElement).value;
    let totalQ = 0, totalInv = 0;
    for (let i = 1; i <= 4; i++) {
      const q = parseFloat((document.getElementById('q' + i) as HTMLInputElement).value) || 0;
      const p = parseFloat((document.getElementById('p' + i) as HTMLInputElement).value) || 0;
      totalQ += q; totalInv += q * p;
    }
    const prom = totalQ > 0 ? totalInv / totalQ : 0;
    const actual = parseFloat((document.getElementById('actual') as HTMLInputElement).value) || 0;
    const pl = actual > 0 ? totalQ * actual - totalInv : 0;
    document.getElementById('r-prom')!.textContent = fmt(prom, m);
    document.getElementById('r-acc')!.textContent = new Intl.NumberFormat('es').format(totalQ);
    document.getElementById('r-inv')!.textContent = fmt(totalInv, m);
    const plEl = document.getElementById('r-pl')!;
    plEl.textContent = (pl >= 0 ? '+' : '') + fmt(pl, m);
    plEl.style.color = pl >= 0 ? '#16A34A' : '#EF4444';
  }
  ['moneda','q1','p1','q2','p2','q3','p3','q4','p4','actual'].forEach(id => document.getElementById(id)?.addEventListener('input', calcular));
  calcular();
</script>
<style>@media(max-width:600px){div[style*="grid-template-columns:1fr 1fr"]{display:flex!important;flex-direction:column!important;}}</style>
</content>
