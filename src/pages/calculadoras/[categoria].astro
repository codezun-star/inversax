---
import Layout from '../../layouts/Layout.astro';
import { grupos } from '../../lib/calculadoras';

export function getStaticPaths() {
  return grupos.map((g) => ({
    params: { categoria: g.slug },
    props: { grupo: g },
  }));
}

const { grupo } = Astro.props;
---

<Layout
  title={`Calculadoras de ${grupo.categoria} — Inversax`}
  description={`${grupo.calculadoras.length} calculadoras de ${grupo.categoria.toLowerCase()} gratuitas para inversores latinoamericanos.`}
>
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:1100px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a>
        <span>›</span>
        <a href="/calculadoras" style="text-decoration:none; color:#A8A29E;">Calculadoras</a>
        <span>›</span>
        <span style="color:#57534E;">{grupo.categoria}</span>
      </div>
      <div style="display:flex; align-items:center; gap:10px; margin-bottom:10px;">
        <div style={'width:4px; height:26px; background:' + grupo.color + '; border-radius:2px;'}></div>
        <h1 style="font-size:clamp(22px,4vw,34px); font-weight:800; color:#1A1A1A; margin:0; letter-spacing:-0.3px;">
          {grupo.categoria}
        </h1>
      </div>
      <p style="font-size:15px; color:#57534E; line-height:1.65; max-width:520px; margin:0;">
        {grupo.calculadoras.length} calculadoras gratuitas. Sin registro, sin APIs externas.
      </p>
    </div>
  </div>

  <div style="max-width:1100px; margin:0 auto; padding:40px 20px;">
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:14px;">
      {grupo.calculadoras.map((c) => {
        const hoverColor = grupo.color;
        const iconBg = grupo.color + '18';
        return (
          <a
            href={c.href}
            style="display:flex; flex-direction:column; background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:22px; text-decoration:none; transition:border-color 0.15s, box-shadow 0.15s;"
            onmouseover={'this.style.borderColor=\'' + hoverColor + '\'; this.style.boxShadow=\'0 2px 12px rgba(0,0,0,0.07)\''}
            onmouseout="this.style.borderColor='#E2DDD8'; this.style.boxShadow='none'"
          >
            <div style={'width:40px; height:40px; background:' + iconBg + '; border-radius:10px; display:flex; align-items:center; justify-content:center; margin-bottom:14px;'}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={grupo.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d={c.svgPath}></path>
              </svg>
            </div>
            <h2 style="font-size:15px; font-weight:700; color:#1A1A1A; margin:0 0 7px;">{c.titulo}</h2>
            <p style="font-size:13px; color:#57534E; line-height:1.6; margin:0 0 16px; flex:1;">{c.descripcion}</p>
            <div style="display:flex; align-items:center; gap:5px;">
              <span style={'font-size:13px; font-weight:600; color:' + grupo.color + ';'}>Calcular</span>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke={grupo.color} stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </div>
          </a>
        );
      })}
    </div>

    <div style="margin-top:32px;">
      <a href="/calculadoras" style="display:inline-flex; align-items:center; gap:6px; font-size:13px; color:#78716C; text-decoration:none;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Ver todas las calculadoras
      </a>
    </div>
  </div>
</Layout>
