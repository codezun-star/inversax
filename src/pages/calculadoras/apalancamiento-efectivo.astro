---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Calculadora de Apalancamiento Efectivo Forex — Inversax" description="Calcula el apalancamiento efectivo real de tus posiciones abiertas en forex. Diferencia entre el apalancamiento máximo del broker y el que realmente estás usando.">
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a><span>›</span>
        <a href="/calculadoras" style="text-decoration:none; color:#A8A29E;">Calculadoras</a><span>›</span>
        <span style="color:#57534E;">Apalancamiento Efectivo</span>
      </div>
      <h1 style="font-size:clamp(22px,4vw,32px); font-weight:800; color:#1A1A1A; margin:0 0 8px; letter-spacing:-0.3px;">Calculadora de Apalancamiento Efectivo</h1>
      <p style="font-size:15px; color:#57534E; line-height:1.65; margin:0;">El broker ofrece 1:500, pero ¿cuánto apalancamiento estás usando realmente? Calcula tu exposición real.</p>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:40px 20px;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
      <div style="background:#fff; border:1px solid #E2DDD8; border-radius:14px; padding:28px;">
        <h2 style="font-size:16px; font-weight:700; color:#1A1A1A; margin:0 0 20px;">Tu cuenta y posiciones</h2>
        <div style="display:flex; flex-direction:column; gap:16px;">
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Equity de la cuenta (USD)</label>
            <input id="equity" type="number" value="5000" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Lotes totales abiertos</label>
            <input id="lotes" type="number" value="0.5" min="0" step="0.01" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Tamaño del lote estándar (unidades)</label>
            <select id="tam-lote" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="100000">100,000 unidades (lote estándar)</option>
              <option value="10000">10,000 unidades (mini lote)</option>
              <option value="1000">1,000 unidades (micro lote)</option>
            </select>
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Precio de mercado del par (ej: 1.0850 para EUR/USD)</label>
            <input id="precio" type="number" value="1.0850" min="0" step="0.0001" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Apalancamiento máximo del broker</label>
            <select id="apal-max" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="500">1:500</option>
              <option value="400">1:400</option>
              <option value="200">1:200</option>
              <option value="100">1:100</option>
              <option value="50">1:50</option>
              <option value="30">1:30</option>
            </select>
          </div>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:14px;">
        <div id="apal-card" style="background:#3B82F6; border-radius:14px; padding:24px; color:#fff;">
          <p style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 6px; opacity:0.85;">Apalancamiento efectivo</p>
          <p id="apal-efectivo" style="font-size:36px; font-weight:800; margin:0; letter-spacing:-0.5px;">1:0</p>
          <p id="apal-rating" style="font-size:13px; font-weight:700; margin:8px 0 0; opacity:0.9;">—</p>
        </div>
        <div style="background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:18px; display:flex; flex-direction:column; gap:10px;">
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Valor nocional total</span>
            <span id="nocional" style="font-size:13px; font-weight:700; color:#3B82F6;">$0</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">% del equity comprometido</span>
            <span id="pct-equity" style="font-size:13px; font-weight:700; color:#1A1A1A;">0%</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Apalancamiento máximo disponible</span>
            <span id="apal-disponible" style="font-size:13px; font-weight:700; color:#1A1A1A;">1:0</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Lotes máximos posibles</span>
            <span id="lotes-max" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span>
          </div>
        </div>
        <div style="background:#EFF6FF; border:1px solid #BFDBFE; border-radius:10px; padding:14px 16px;">
          <p style="font-size:12px; color:#1e40af; line-height:1.6; margin:0;">Traders profesionales rara vez usan más de 1:10 efectivo, aunque el broker ofrezca 1:500.</p>
        </div>
      </div>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:0 20px 60px;" class="prose">
    <h2>Apalancamiento máximo vs efectivo</h2>
    <p>El <strong>apalancamiento máximo</strong> es lo que el broker te ofrece (1:500 significa que por cada 1 USD en cuenta puedes controlar 500 USD). El <strong>apalancamiento efectivo</strong> es el que realmente estás usando según tus posiciones abiertas en este momento.</p>
    <p>Un broker con 1:500 no significa que debas usar 1:500. Usar todo el apalancamiento disponible equivale a apostar todo el capital con un riesgo de quiebra extremo. El apalancamiento efectivo recomendado para traders con sistema probado es entre 5:1 y 20:1.</p>
    <h2>Cómo usarlo</h2>
    <p>Combina este dato con la <a href="/calculadoras/margen-libre">calculadora de margen libre</a> para saber tu exposición total. Si tu apalancamiento efectivo supera 1:50, estás tomando un riesgo significativo y deberías reducir el tamaño de tus posiciones o cerrar algunas. Usa la <a href="/calculadoras/tamano-posicion">calculadora de tamaño de posición</a> para planificar correctamente antes de abrir cualquier trade.</p>
  </div>
</Layout>

<script>
  function calcular() {
    const equity = parseFloat((document.getElementById('equity') as HTMLInputElement).value) || 0;
    const lotes = parseFloat((document.getElementById('lotes') as HTMLInputElement).value) || 0;
    const tamLote = parseFloat((document.getElementById('tam-lote') as HTMLSelectElement).value) || 100000;
    const precio = parseFloat((document.getElementById('precio') as HTMLInputElement).value) || 1;
    const apalMax = parseFloat((document.getElementById('apal-max') as HTMLSelectElement).value) || 500;
    const nocional = lotes * tamLote * precio;
    const apalEfectivo = equity > 0 ? nocional / equity : 0;
    const pctEquity = equity > 0 ? (nocional / equity) * 100 : 0;
    const lotesMax = equity > 0 ? (equity * apalMax) / (tamLote * precio) : 0;
    const card = document.getElementById('apal-card')!;
    let rating = '';
    if (apalEfectivo <= 5) { card.style.background = '#22C55E'; rating = 'Muy conservador'; }
    else if (apalEfectivo <= 20) { card.style.background = '#3B82F6'; rating = 'Moderado'; }
    else if (apalEfectivo <= 50) { card.style.background = '#FF8C42'; rating = 'Agresivo — cuidado'; }
    else { card.style.background = '#EF4444'; rating = 'Muy agresivo — alto riesgo'; }
    document.getElementById('apal-efectivo')!.textContent = '1:' + apalEfectivo.toFixed(1);
    document.getElementById('apal-rating')!.textContent = rating;
    document.getElementById('nocional')!.textContent = '$' + nocional.toLocaleString('es', {maximumFractionDigits:2});
    document.getElementById('pct-equity')!.textContent = pctEquity.toFixed(0) + '%';
    document.getElementById('apal-disponible')!.textContent = '1:' + apalMax;
    document.getElementById('lotes-max')!.textContent = lotesMax.toFixed(2) + ' lotes';
  }
  ['equity','lotes','tam-lote','precio','apal-max'].forEach(id => document.getElementById(id)?.addEventListener('input', calcular));
  calcular();
</script>
<style>@media(max-width:600px){div[style*="grid-template-columns:1fr 1fr"]{display:flex!important;flex-direction:column!important;}}</style>
