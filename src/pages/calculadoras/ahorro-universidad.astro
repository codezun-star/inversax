---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Calculadora de Ahorro para Universidad — Fondo Educativo | Inversax" description="Calcula cuánto ahorrar mensualmente para la universidad de tus hijos. Con inflación educativa y rendimiento de inversión. Para Colombia, México, Chile y toda Latinoamérica. 19 monedas.">
  <Fragment slot="head">
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cuánto cuesta la universidad en Latinoamérica?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Los costos varían enormemente. Colombia: universidades privadas 5.000-15.000 USD/año; públicas prácticamente gratuitas con matrícula simbólica. México: privadas 5.000-20.000 USD/año; UNAM y politécnicas casi gratuitas. Chile: 5.000-12.000 USD/año con aranceles y derechos básicos. Considera además gastos de vivienda, transporte y materiales."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto sube el costo de la universidad cada año?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "La inflación universitaria suele superar la inflación general. En Latinoamérica oscila entre 4% y 8% anual según el país. Colombia: aranceles de universidades privadas han subido 5-7% anual. México: privadas 6-8%. Chile: universidades ajustan según UF que sigue la inflación (~4-6%). Usa 5% como estimación conservadora."
          }
        },
        {
          "@type": "Question",
          "name": "¿Dónde invertir el ahorro para la universidad de los hijos?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Depende del horizonte. Si faltan más de 10 años, puedes asumir más riesgo con ETFs globales (rendimiento histórico ~7-9%). Con 5-10 años, mezcla acciones y bonos (5-7%). Con menos de 5 años, instrumentos de bajo riesgo: CDTs, depósitos a plazo, CETES (3-5%). A menor tiempo restante, más conservador debe ser el instrumento."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué pasa si empiezo a ahorrar para la universidad cuando mi hijo tiene 10 años?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Con 8 años de ahorro (ingreso a los 18), aún es tiempo razonable para construir un fondo universitario. Por ejemplo, para una universidad de 6.000 USD/año durante 5 años con 5% de inflación y 7% de rendimiento, necesitas ahorrar aproximadamente 450-550 USD/mes. Empezar a los 5 años del niño reduciría esa cifra a ~250 USD/mes."
          }
        }
      ]
    }
    </script>
  </Fragment>
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a><span>›</span>
        <a href="/calculadoras" style="text-decoration:none; color:#A8A29E;">Calculadoras</a><span>›</span>
        <span style="color:#57534E;">Ahorro para Universidad</span>
      </div>
      <h1 style="font-size:clamp(22px,4vw,32px); font-weight:800; color:#1A1A1A; margin:0 0 8px; letter-spacing:-0.3px;">Calculadora de Ahorro para Universidad</h1>
      <p style="font-size:15px; color:#57534E; line-height:1.65; margin:0;">Proyecta el costo futuro de la universidad y calcula el ahorro mensual necesario para llegar con el capital completo.</p>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:40px 20px;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
      <div style="background:#fff; border:1px solid #E2DDD8; border-radius:14px; padding:28px;">
        <h2 style="font-size:16px; font-weight:700; color:#1A1A1A; margin:0 0 20px;">Datos de proyección</h2>
        <div style="display:flex; flex-direction:column; gap:16px;">
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Moneda</label>
            <select id="moneda" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="USD">USD — Dólar (EC, PA, SV, PR)</option>
              <option value="COP">COP — Peso colombiano</option>
              <option value="MXN">MXN — Peso mexicano</option>
              <option value="ARS">ARS — Peso argentino</option>
              <option value="CLP">CLP — Peso chileno</option>
              <option value="PEN">PEN — Sol peruano</option>
              <option value="UYU">UYU — Peso uruguayo</option>
              <option value="BOB">BOB — Boliviano</option>
              <option value="PYG">PYG — Guaraní paraguayo</option>
              <option value="VES">VES — Bolívar venezolano</option>
              <option value="CRC">CRC — Colón costarricense</option>
              <option value="DOP">DOP — Peso dominicano</option>
              <option value="GTQ">GTQ — Quetzal guatemalteco</option>
              <option value="HNL">HNL — Lempira hondureño</option>
              <option value="NIO">NIO — Córdoba nicaragüense</option>
              <option value="CUP">CUP — Peso cubano</option>
              <option value="BZD">BZD — Dólar de Belice</option>
              <option value="CAD">CAD — Dólar canadiense</option>
              <option value="EUR">EUR — Euro (España)</option>
            </select>
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Costo anual actual de la universidad</label>
            <input id="costo" type="number" value="5000" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Duración de la carrera (años)</label>
            <input id="duracion" type="number" value="5" min="1" max="10" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Años hasta el ingreso</label>
            <input id="anos" type="number" value="10" min="1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Inflación universitaria anual (%)</label>
            <input id="inflacion" type="number" value="5" min="0" step="0.1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Rendimiento anual del ahorro (%)</label>
            <input id="rendimiento" type="number" value="7" min="0" step="0.1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:14px;">
        <div style="background:#22C55E; border-radius:14px; padding:24px; color:#fff;">
          <p style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 6px; opacity:0.85;">Ahorro mensual necesario</p>
          <p id="ahorro-mensual" style="font-size:32px; font-weight:800; margin:0; letter-spacing:-0.5px;">0</p>
        </div>
        <div style="background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:18px; display:flex; flex-direction:column; gap:10px;">
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Costo total proyectado</span>
            <span id="costo-total" style="font-size:13px; font-weight:700; color:#22C55E;">0</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Costo primer año (futuro)</span>
            <span id="costo-primer" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Total aportado</span>
            <span id="total-aportado" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span>
          </div>
        </div>
        <div style="background:#F0FDF4; border:1px solid #BBF7D0; border-radius:10px; padding:14px 16px;">
          <p style="font-size:12px; color:#166534; line-height:1.6; margin:0;">La inflación universitaria suele superar la inflación general. En Latinoamérica oscila entre 4% y 8% anual.</p>
        </div>
      </div>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:0 20px 60px;" class="prose">
    <h2>Por qué ahorrar para la universidad desde temprano</h2>
    <p>El costo de la educación universitaria crece a una tasa mayor que la inflación general. Empezar a ahorrar cuando el niño tiene pocos años permite que el interés compuesto trabaje a tu favor. Esperar hasta los 15 años puede triplicar el ahorro mensual necesario comparado con empezar a los 5 años de edad.</p>

    <h2>¿Cómo usar esta calculadora?</h2>
    <ul>
      <li><strong>Costo anual actual:</strong> el precio en hoy de la universidad que tienes en mente. Si no sabes, usa 5.000-8.000 USD/año para universidades privadas latinoamericanas, o 1.500-3.000 USD para semipúblicas.</li>
      <li><strong>Duración de la carrera:</strong> la mayoría de licenciaturas son 4-5 años. Ingeniería y medicina pueden ser 5-7 años.</li>
      <li><strong>Años hasta el ingreso:</strong> si tu hijo tiene 8 años y entrará a los 18, son 10 años.</li>
      <li><strong>Inflación universitaria:</strong> usa 5% como estimación conservadora para Latinoamérica.</li>
      <li><strong>Rendimiento del ahorro:</strong> depende del instrumento. Con +10 años, considera 6-8% en ETFs. Con 5-10 años, 4-6%. Con menos de 5 años, 3-4%.</li>
    </ul>

    <h2>Ejemplo: fondo universitario en México</h2>
    <p>Tu hija tiene 7 años. Planeas enviarla a una universidad privada con costo actual de <strong>80.000 MXN/año</strong> durante 5 años, con 6% de inflación universitaria y rendimiento del ahorro del 7%.</p>
    <ul>
      <li>Años hasta el ingreso: 11</li>
      <li>Costo proyectado primer año: ~143.000 MXN</li>
      <li>Costo total proyectado de la carrera: ~800.000 MXN</li>
      <li>Ahorro mensual necesario: aproximadamente <strong>3.800 MXN/mes</strong></li>
    </ul>
    <p>Si hubieras empezado cuando tenía 2 años (16 años de plazo), el ahorro mensual necesario sería solo ~1.800 MXN/mes. El tiempo reduce el esfuerzo a menos de la mitad.</p>

    <h2>Opciones de inversión para el fondo universitario</h2>
    <p>Con más de 10 años de horizonte, puedes invertir en ETFs de acciones globales a través de un broker internacional. Con menos tiempo, migra gradualmente a instrumentos más seguros: bonos, fondos mixtos, depósitos a plazo. Nunca pongas el fondo universitario completo en activos volátiles cuando falten menos de 3 años para el ingreso.</p>
    <p>Combina esta proyección con la <a href="/calculadoras/meta-ahorro">calculadora de meta de ahorro</a> para ver el impacto del rendimiento en el ahorro mensual. Para planificar tanto la educación de los hijos como tu propio retiro, usa la <a href="/calculadoras/jubilacion">calculadora de jubilación</a>.</p>

    <h2>Preguntas frecuentes</h2>
    <h3>¿Qué pasa si la universidad es pública y gratuita?</h3>
    <p>Si tu hijo accede a una universidad pública de bajo costo, el fondo que hayas construido puede usarse para gastos de vida (vivienda, transporte, libros) o puede redirigirse a tu propio retiro. No es dinero perdido: es capital acumulado que sigue siendo tuyo y de tu familia.</p>
    <h3>¿Debo ahorrar en moneda local o en dólares para la universidad?</h3>
    <p>Si la universidad es local y los costos están en moneda local, ahorra en la misma moneda para evitar riesgo cambiario. Si consideras enviar a tu hijo al exterior (EE.UU., España, Canadá), ahorra en USD o EUR para estar cubierto frente a devaluaciones.</p>
  </div>
</Layout>

<script>
  const DEC: Record<string,number> = {USD:2,COP:0,MXN:2,ARS:0,CLP:0,PEN:2,UYU:2,BOB:2,PYG:0,VES:2,CRC:0,DOP:2,GTQ:2,HNL:2,NIO:2,CUP:2,BZD:2,CAD:2,EUR:2};
  function fmt(n: number, m: string) {
    const d = DEC[m] ?? 2;
    return new Intl.NumberFormat('es',{minimumFractionDigits:d,maximumFractionDigits:d}).format(n) + ' ' + m;
  }
  function calcular() {
    const m = (document.getElementById('moneda') as HTMLSelectElement).value;
    const costo = parseFloat((document.getElementById('costo') as HTMLInputElement).value) || 0;
    const dur = parseFloat((document.getElementById('duracion') as HTMLInputElement).value) || 5;
    const n = parseFloat((document.getElementById('anos') as HTMLInputElement).value) || 0;
    const inf = parseFloat((document.getElementById('inflacion') as HTMLInputElement).value) / 100 || 0;
    const rend = parseFloat((document.getElementById('rendimiento') as HTMLInputElement).value) / 100 || 0;
    // Costo en el año de ingreso
    const costoInicio = costo * Math.pow(1 + inf, n);
    // Costo total sumando los años de carrera con inflación
    let costoTotal = 0;
    for (let i = 0; i < dur; i++) costoTotal += costoInicio * Math.pow(1 + inf, i);
    // Ahorro mensual necesario (aporte fijo mensual que alcanza costoTotal al inicio de la carrera)
    const r = rend / 12;
    const meses = n * 12;
    const ahorro = r > 0 && meses > 0 ? costoTotal * r / (Math.pow(1 + r, meses) - 1) : (meses > 0 ? costoTotal / meses : 0);
    document.getElementById('ahorro-mensual')!.textContent = fmt(ahorro, m);
    document.getElementById('costo-total')!.textContent = fmt(costoTotal, m);
    document.getElementById('costo-primer')!.textContent = fmt(costoInicio, m);
    document.getElementById('total-aportado')!.textContent = fmt(ahorro * meses, m);
  }
  ['moneda','costo','duracion','anos','inflacion','rendimiento'].forEach(id => document.getElementById(id)?.addEventListener('input', calcular));
  calcular();
</script>
<style>@media(max-width:600px){div[style*="grid-template-columns:1fr 1fr"]{display:flex!important;flex-direction:column!important;}}</style>
