---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Calculadora de Rentabilidad Real (ajustada por inflación) — Inversax" description="Calcula tu rentabilidad real descontando la inflación de tu rendimiento nominal con la fórmula de Fisher. Descubre cuánto ganas de verdad. Para LATAM y España, 19 monedas.">
  <Fragment slot="head">
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cómo se calcula la rentabilidad real?",
          "acceptedAnswer": { "@type": "Answer", "text": "La rentabilidad real se calcula con la fórmula de Fisher: (1 + tasa nominal) / (1 + inflación) − 1. La aproximación rápida es simplemente restar la inflación a la tasa nominal, pero es menos exacta cuando las cifras son altas." }
        },
        {
          "@type": "Question",
          "name": "¿Qué diferencia hay entre rentabilidad nominal y real?",
          "acceptedAnswer": { "@type": "Answer", "text": "La rentabilidad nominal es el porcentaje que crece tu dinero en cifras. La rentabilidad real descuenta la inflación y mide cuánto aumenta tu poder de compra. Si ganas 10% nominal con 8% de inflación, tu rentabilidad real es de apenas 1,85%." }
        },
        {
          "@type": "Question",
          "name": "¿Puede ser negativa la rentabilidad real?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sí. Si la inflación supera tu rendimiento nominal, tu rentabilidad real es negativa: aunque tengas más dinero, compras menos cosas que antes. Es lo que ocurre con muchas cuentas de ahorro en países con inflación alta." }
        }
      ]
    }
    </script>
  </Fragment>
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a><span>›</span>
        <a href="/calculadoras" style="text-decoration:none; color:#A8A29E;">Calculadoras</a><span>›</span>
        <span style="color:#57534E;">Rentabilidad Real</span>
      </div>
      <h1 style="font-size:clamp(22px,4vw,32px); font-weight:800; color:#1A1A1A; margin:0 0 8px; letter-spacing:-0.3px;">Calculadora de Rentabilidad Real</h1>
      <p style="font-size:15px; color:#57534E; line-height:1.65; margin:0;">Descuenta la inflación de tu rendimiento nominal y descubre cuánto crece de verdad tu poder de compra.</p>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:40px 20px;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
      <div style="background:#fff; border:1px solid #E2DDD8; border-radius:14px; padding:28px;">
        <h2 style="font-size:16px; font-weight:700; color:#1A1A1A; margin:0 0 20px;">Datos</h2>
        <div style="display:flex; flex-direction:column; gap:16px;">
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Moneda</label>
            <select id="moneda" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="USD">USD — Dólar (EC, PA, SV, PR)</option>
              <option value="COP">COP — Peso colombiano</option>
              <option value="MXN">MXN — Peso mexicano</option>
              <option value="ARS">ARS — Peso argentino</option>
              <option value="CLP">CLP — Peso chileno</option>
              <option value="PEN">PEN — Sol peruano</option>
              <option value="UYU">UYU — Peso uruguayo</option>
              <option value="BOB">BOB — Boliviano</option>
              <option value="PYG">PYG — Guaraní paraguayo</option>
              <option value="VES">VES — Bolívar venezolano</option>
              <option value="CRC">CRC — Colón costarricense</option>
              <option value="DOP">DOP — Peso dominicano</option>
              <option value="GTQ">GTQ — Quetzal guatemalteco</option>
              <option value="HNL">HNL — Lempira hondureño</option>
              <option value="NIO">NIO — Córdoba nicaragüense</option>
              <option value="CUP">CUP — Peso cubano</option>
              <option value="BZD">BZD — Dólar de Belice</option>
              <option value="CAD">CAD — Dólar canadiense</option>
              <option value="EUR">EUR — Euro (España)</option>
            </select>
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Capital invertido</label>
            <input id="capital" type="number" value="10000" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Rendimiento nominal anual (%)</label>
            <input id="nom" type="number" value="10" step="0.1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Inflación anual (%)</label>
            <input id="inf" type="number" value="8" step="0.1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Plazo (años)</label>
            <input id="anos" type="number" value="10" min="1" step="1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:14px;">
        <div id="card" style="background:#FF8C42; border-radius:14px; padding:24px; color:#fff;">
          <p style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 6px; opacity:0.85;">Rentabilidad real anual</p>
          <p id="r-real" style="font-size:36px; font-weight:800; margin:0; letter-spacing:-0.5px;">0%</p>
        </div>
        <div style="background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:18px; display:flex; flex-direction:column; gap:10px;">
          <div style="display:flex; justify-content:space-between;"><span style="font-size:13px; color:#57534E;">Aproximación simple (nominal − inflación)</span><span id="r-aprox" style="font-size:13px; font-weight:700; color:#1A1A1A;">0%</span></div>
          <div style="display:flex; justify-content:space-between;"><span style="font-size:13px; color:#57534E;">Valor nominal a N años</span><span id="r-nominal" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span></div>
          <div style="display:flex; justify-content:space-between;"><span style="font-size:13px; color:#57534E;">Valor real (poder de compra) a N años</span><span id="r-valreal" style="font-size:13px; font-weight:700; color:#FF8C42;">0</span></div>
        </div>
        <div style="background:#FFF4EC; border:1px solid #FFD4A8; border-radius:10px; padding:14px 16px;">
          <p style="font-size:12px; color:#78716C; line-height:1.6; margin:0;">Fórmula de Fisher: (1 + nominal) / (1 + inflación) − 1. El valor real expresa el saldo futuro en poder de compra de hoy.</p>
        </div>
      </div>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:0 20px 60px;" class="prose">
    <h2>¿Qué es la rentabilidad real?</h2>
    <p>La <strong>rentabilidad real</strong> es lo que ganas después de descontar la inflación. Mientras la rentabilidad nominal mide cuánto crece tu dinero en cifras, la real mide cuánto crece tu <strong>poder de compra</strong>, que es lo único que importa para tu bolsillo.</p>

    <h2>¿Cómo usar esta calculadora?</h2>
    <ul>
      <li><strong>Rendimiento nominal:</strong> la tasa que te promete el banco, el bono o tu cartera.</li>
      <li><strong>Inflación:</strong> el aumento esperado de precios en tu país.</li>
      <li><strong>Plazo:</strong> para ver el valor futuro nominal y en poder de compra de hoy.</li>
    </ul>

    <h2>Por qué importa en Latinoamérica</h2>
    <p>En países con inflación alta, una tasa nominal atractiva puede esconder una rentabilidad real negativa. Antes de dejar tu dinero en un <a href="/calculadoras/plazo-fijo">plazo fijo o CDT</a>, comprueba aquí si realmente le ganas a la inflación. Para proyectar la pérdida de poder adquisitivo, usa la <a href="/calculadoras/inflacion">calculadora de inflación</a>.</p>

    <h2>Preguntas frecuentes</h2>
    <h3>¿Por qué no basta con restar la inflación?</h3>
    <p>La resta simple (nominal − inflación) es una aproximación. La fórmula de Fisher es exacta y la diferencia se nota cuando las tasas son de dos dígitos, algo común en la región.</p>
    <h3>¿Qué rentabilidad real es buena?</h3>
    <p>Cualquier valor positivo ya preserva tu poder de compra. Históricamente, una cartera diversificada de acciones ha ofrecido en torno a 5%-7% real anual en el largo plazo.</p>
  </div>
</Layout>

<script>
  const DEC: Record<string,number> = {USD:2,COP:0,MXN:2,ARS:0,CLP:0,PEN:2,UYU:2,BOB:2,PYG:0,VES:2,CRC:0,DOP:2,GTQ:2,HNL:2,NIO:2,CUP:2,BZD:2,CAD:2,EUR:2};
  function fmt(n: number, m: string) {
    const d = DEC[m] ?? 2;
    return new Intl.NumberFormat('es',{minimumFractionDigits:d,maximumFractionDigits:d}).format(n) + ' ' + m;
  }
  function calcular() {
    const m = (document.getElementById('moneda') as HTMLSelectElement).value;
    const c = parseFloat((document.getElementById('capital') as HTMLInputElement).value) || 0;
    const nom = (parseFloat((document.getElementById('nom') as HTMLInputElement).value) || 0) / 100;
    const inf = (parseFloat((document.getElementById('inf') as HTMLInputElement).value) || 0) / 100;
    const t = parseFloat((document.getElementById('anos') as HTMLInputElement).value) || 0;
    const real = (1 + nom) / (1 + inf) - 1;
    const aprox = nom - inf;
    const valNominal = c * Math.pow(1 + nom, t);
    const valReal = c * Math.pow(1 + real, t);
    document.getElementById('r-real')!.textContent = (real * 100).toFixed(2) + '%';
    document.getElementById('r-aprox')!.textContent = (aprox * 100).toFixed(2) + '%';
    document.getElementById('r-nominal')!.textContent = fmt(valNominal, m);
    document.getElementById('r-valreal')!.textContent = fmt(valReal, m);
    document.getElementById('card')!.style.background = real >= 0 ? '#FF8C42' : '#EF4444';
  }
  ['moneda','capital','nom','inf','anos'].forEach(id => document.getElementById(id)?.addEventListener('input', calcular));
  calcular();
</script>
<style>@media(max-width:600px){div[style*="grid-template-columns:1fr 1fr"]{display:flex!important;flex-direction:column!important;}}</style>
</content>
