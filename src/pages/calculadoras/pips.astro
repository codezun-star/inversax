---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Calculadora de Valor del Pip Forex — EUR/USD, GBP/USD, USD/JPY | Inversax" description="Calcula cuánto vale cada pip en forex según tu par de divisas y tamaño de posición. Tabla de valores para 10, 50 y 100 pips. Herramienta gratuita para traders de Colombia, México, Chile, Perú y toda LATAM.">
  <Fragment slot="head">
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cuánto vale un pip en un lote estándar de EUR/USD?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "En EUR/USD (y cualquier par donde el USD es la divisa cotizada como GBP/USD, AUD/USD, NZD/USD), 1 pip equivale a 10 USD por lote estándar de 100.000 unidades. Con un mini lote (10.000 unidades), el pip vale 1 USD; con un micro lote (1.000 unidades), vale 0.10 USD."
          }
        },
        {
          "@type": "Question",
          "name": "¿Por qué el valor del pip es diferente para USD/JPY?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "En pares con JPY (USD/JPY, EUR/JPY, GBP/JPY), 1 pip es 0.01 (no 0.0001) porque el yen cotiza con solo 2 decimales. El valor monetario varía con el precio: a 150 USD/JPY, 1 pip ≈ 6.67 USD por lote estándar. Por eso la calculadora pide el precio de mercado actual para estos pares."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué es un pipette o punto en forex?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Un pipette (o punto) es el quinto decimal en la cotización de un par — es decir, 1/10 de pip. Muchos brokers modernos como Exness, IC Markets y Pepperstone cotizan con 5 decimales (EUR/USD: 1.08503). El pipette tiene valor monetario pero es tan pequeño (0.001 USD/lote estándar) que solo importa en estrategias de scalping con volúmenes muy altos."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cómo afecta el tamaño de lote al valor del pip?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El valor del pip escala linealmente con el tamaño de la posición. Para EUR/USD: lote estándar (100K unidades) = 10 USD/pip; mini lote (10K) = 1 USD/pip; micro lote (1K) = 0.10 USD/pip; nano lote (100) = 0.01 USD/pip. Si operas 2 lotes estándar, el pip vale 20 USD. Si operas 0.5 lotes, vale 5 USD."
          }
        }
      ]
    }
    </script>
  </Fragment>
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a><span>›</span>
        <a href="/calculadoras" style="text-decoration:none; color:#A8A29E;">Calculadoras</a><span>›</span>
        <span style="color:#57534E;">Valor del Pip</span>
      </div>
      <h1 style="font-size:clamp(22px,4vw,32px); font-weight:800; color:#1A1A1A; margin:0 0 8px; letter-spacing:-0.3px;">Calculadora de Valor del Pip</h1>
      <p style="font-size:15px; color:#57534E; line-height:1.65; margin:0;">Calcula exactamente cuánto vale cada pip según tu par de divisas y tamaño de posición.</p>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:40px 20px;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
      <div style="background:#fff; border:1px solid #E2DDD8; border-radius:14px; padding:28px;">
        <h2 style="font-size:16px; font-weight:700; color:#1A1A1A; margin:0 0 20px;">Parámetros</h2>
        <div style="display:flex; flex-direction:column; gap:16px;">
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Par de divisas</label>
            <select id="par" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="eurusd">EUR/USD</option>
              <option value="gbpusd">GBP/USD</option>
              <option value="usdjpy">USD/JPY</option>
              <option value="usdchf">USD/CHF</option>
              <option value="audusd">AUD/USD</option>
              <option value="usdcad">USD/CAD</option>
              <option value="nzdusd">NZD/USD</option>
              <option value="eurgbp">EUR/GBP</option>
              <option value="eurjpy">EUR/JPY</option>
              <option value="gbpjpy">GBP/JPY</option>
              <option value="xauusd">XAU/USD (Oro)</option>
              <option value="xagusd">XAG/USD (Plata)</option>
            </select>
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Tipo de lote</label>
            <select id="lote-tipo" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="100000">Lote estándar (100,000 unidades)</option>
              <option value="10000">Mini lote (10,000 unidades)</option>
              <option value="1000">Micro lote (1,000 unidades)</option>
              <option value="100">Nano lote (100 unidades)</option>
            </select>
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Número de lotes</label>
            <input id="lotes" type="number" value="1" min="0.01" step="0.01" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Precio de mercado actual</label>
            <input id="precio" type="number" value="1.0850" min="0.0001" step="0.0001" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:14px;">
        <div style="background:#FF8C42; border-radius:14px; padding:24px; color:#fff;">
          <p style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 6px; opacity:0.85;">Valor por pip (USD)</p>
          <p id="pip-valor" style="font-size:36px; font-weight:800; margin:0; letter-spacing:-0.5px;">$0.00</p>
        </div>
        <div style="background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:18px; display:flex; flex-direction:column; gap:10px;">
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Tamaño de posición</span>
            <span id="posicion" style="font-size:13px; font-weight:700; color:#1A1A1A;">0 unidades</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Valor por 10 pips</span>
            <span id="pip-10" style="font-size:13px; font-weight:700; color:#FF8C42;">$0.00</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Valor por 50 pips</span>
            <span id="pip-50" style="font-size:13px; font-weight:700; color:#FF8C42;">$0.00</span>
          </div>
          <div style="height:1px; background:#E2DDD8;"></div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Valor por 100 pips</span>
            <span id="pip-100" style="font-size:13px; font-weight:700; color:#FF8C42;">$0.00</span>
          </div>
        </div>
        <div style="background:#FFF4EC; border:1px solid #FFD4A8; border-radius:10px; padding:14px 16px;">
          <p style="font-size:12px; color:#78716C; line-height:1.6; margin:0;">Para pares con USD como divisa cotizada (EUR/USD, GBP/USD), 1 pip = 0.0001. Para pares JPY, 1 pip = 0.01. El valor está expresado en USD.</p>
        </div>
      </div>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:0 20px 60px;" class="prose">
    <h2>¿Qué es un pip en forex?</h2>
    <p>Un <strong>pip</strong> (Price Interest Point) es la unidad mínima de movimiento de precio en un par de divisas. Para la mayoría de pares con 4 decimales (EUR/USD, GBP/USD, etc.), 1 pip = 0,0001. Para pares con JPY (USD/JPY, EUR/JPY), 1 pip = 0,01, porque el yen cotiza con solo 2 decimales.</p>
    <p>Conocer el valor monetario de cada pip es fundamental en forex: define cuánto ganas o pierdes por cada movimiento del mercado y permite dimensionar correctamente el tamaño de tus posiciones.</p>

    <h2>¿Cómo usar esta calculadora?</h2>
    <ul>
      <li><strong>Par de divisas:</strong> cada par tiene su propia forma de calcular el valor del pip según si el USD es la divisa base o cotizada.</li>
      <li><strong>Tipo de lote:</strong> el tamaño estándar es 100.000 unidades (1 lote). Un mini lote es 10.000 unidades (0.1 lotes), y un micro lote es 1.000 unidades (0.01 lotes). La mayoría de brokers para principiantes, como Exness o XM, permiten operar desde 0.01 lotes.</li>
      <li><strong>Número de lotes:</strong> cuántos lotes operas en esa posición.</li>
      <li><strong>Precio de mercado:</strong> necesario para calcular el valor del pip en pares donde el USD no es la divisa cotizada (como USD/JPY o USD/CHF).</li>
    </ul>

    <h2>¿Por qué importa el valor del pip?</h2>
    <p>Antes de entrar a cualquier operación en forex, debes saber tres cosas: el valor de tu pip, cuántos pips está tu stop loss, y cuánto capital puedes arriesgar. Con estos tres datos, calculas el tamaño correcto de la posición.</p>
    <p>Ejemplo: tienes 1.000 USD en cuenta, quieres arriesgar el 1% (10 USD) y tu stop loss es de 20 pips. Si cada pip vale 1 USD (0.1 lotes en EUR/USD), puedes operar exactamente 0.5 lotes: 20 pips × 1 USD/pip = 20 USD de pérdida máxima. Si reduces a 0.1 lotes: 20 pips × 0.10 USD = 2 USD. Ajusta el tamaño de lote hasta que el riesgo en USD sea exactamente el que deseas.</p>

    <h2>Valor del pip por par (1 lote estándar, aproximado)</h2>
    <ul>
      <li><strong>EUR/USD, GBP/USD, AUD/USD, NZD/USD:</strong> 10 USD por pip</li>
      <li><strong>USD/JPY:</strong> ~9,20 USD por pip (varía con el precio)</li>
      <li><strong>USD/CHF:</strong> ~11 USD por pip (varía con el precio)</li>
      <li><strong>USD/CAD:</strong> ~7,20 USD por pip (varía con el precio)</li>
      <li><strong>XAU/USD (Oro):</strong> 1 USD por 0.01 de movimiento</li>
    </ul>
    <p>Combina esta calculadora con la de <a href="/calculadoras/riesgo-beneficio">riesgo/beneficio</a> para planificar cada operación antes de ejecutarla.</p>
  </div>
</Layout>

<script>
  const PIP_SIZE: Record<string, number> = {
    eurusd: 0.0001, gbpusd: 0.0001, audusd: 0.0001, nzdusd: 0.0001,
    usdchf: 0.0001, usdcad: 0.0001, eurgbp: 0.0001,
    usdjpy: 0.01, eurjpy: 0.01, gbpjpy: 0.01,
    xauusd: 0.01, xagusd: 0.001,
  };
  // For pairs where USD is quote: pip_value = pip_size * lots * lot_size
  // For pairs where USD is base (USD/JPY etc): pip_value = pip_size * lots * lot_size / price
  const USD_BASE = ['usdjpy','usdchf','usdcad'];
  const CROSS_USD_QUOTE = ['eurjpy','gbpjpy'];

  function calcular() {
    const par    = (document.getElementById('par')       as HTMLSelectElement).value;
    const loteT  = parseFloat((document.getElementById('lote-tipo') as HTMLSelectElement).value) || 100000;
    const lotes  = parseFloat((document.getElementById('lotes')     as HTMLInputElement).value) || 1;
    const precio = parseFloat((document.getElementById('precio')    as HTMLInputElement).value) || 1;
    const posicion = lotes * loteT;
    const pip = PIP_SIZE[par] || 0.0001;
    let pipVal = 0;
    if (USD_BASE.includes(par)) {
      pipVal = pip * posicion / precio;
    } else if (CROSS_USD_QUOTE.includes(par)) {
      // e.g. EUR/JPY: pip in JPY, need to convert via current price (approx)
      pipVal = pip * posicion / precio;
    } else {
      pipVal = pip * posicion;
    }
    const f = (n: number) => '$' + n.toFixed(2);
    document.getElementById('pip-valor')!.textContent = f(pipVal);
    document.getElementById('posicion')!.textContent  = posicion.toLocaleString('es') + ' unidades';
    document.getElementById('pip-10')!.textContent    = f(pipVal * 10);
    document.getElementById('pip-50')!.textContent    = f(pipVal * 50);
    document.getElementById('pip-100')!.textContent   = f(pipVal * 100);
  }
  ['par','lote-tipo','lotes','precio'].forEach(id => document.getElementById(id)?.addEventListener('input', calcular));
  calcular();
</script>
<style>@media(max-width:600px){div[style*="grid-template-columns:1fr 1fr"]{display:flex!important;flex-direction:column!important;}}</style>
