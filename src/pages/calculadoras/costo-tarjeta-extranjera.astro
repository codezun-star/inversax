---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Calculadora de Costo de Pago con Tarjeta en Moneda Extranjera — Inversax" description="Calcula el costo real de pagar con tarjeta de crédito o débito en moneda extranjera. Incluye comisión de la red, recargo del banco y tipo de cambio aplicado.">
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a><span>›</span>
        <a href="/calculadoras" style="text-decoration:none; color:#A8A29E;">Calculadoras</a><span>›</span>
        <span style="color:#57534E;">Costo Tarjeta Extranjera</span>
      </div>
      <h1 style="font-size:clamp(22px,4vw,32px); font-weight:800; color:#1A1A1A; margin:0 0 8px; letter-spacing:-0.3px;">Costo de Pago con Tarjeta en Moneda Extranjera</h1>
      <p style="font-size:15px; color:#57534E; line-height:1.65; margin:0;">Descubre cuánto pagas realmente al usar tu tarjeta fuera del país o en tiendas online extranjeras.</p>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:40px 20px;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
      <div style="background:#fff; border:1px solid #E2DDD8; border-radius:14px; padding:28px;">
        <h2 style="font-size:16px; font-weight:700; color:#1A1A1A; margin:0 0 20px;">Detalles del pago</h2>
        <div style="display:flex; flex-direction:column; gap:16px;">
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Monto en moneda extranjera (ej: USD)</label>
            <input id="monto-ext" type="number" value="100" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Tipo de cambio oficial (1 USD = X moneda local)</label>
            <input id="tc" type="number" value="4200" min="0" step="0.01" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Comisión de la red (Visa/Mastercard) %</label>
            <input id="red" type="number" value="1" min="0" step="0.1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Recargo de tu banco emisor (%)</label>
            <input id="banco" type="number" value="3" min="0" step="0.1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Moneda local</label>
            <select id="moneda" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="COP">COP — Peso colombiano</option><option value="MXN">MXN — Peso mexicano</option><option value="ARS">ARS — Peso argentino</option><option value="CLP">CLP — Peso chileno</option><option value="PEN">PEN — Sol peruano</option><option value="UYU">UYU — Peso uruguayo</option><option value="BOB">BOB — Boliviano</option><option value="DOP">DOP — Peso dominicano</option><option value="GTQ">GTQ — Quetzal</option>
            </select>
          </div>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:14px;">
        <div style="background:#8B5CF6; border-radius:14px; padding:24px; color:#fff;">
          <p style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 6px; opacity:0.85;">Total cobrado en moneda local</p>
          <p id="total-local" style="font-size:32px; font-weight:800; margin:0; letter-spacing:-0.5px;">0</p>
        </div>
        <div style="background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:18px; display:flex; flex-direction:column; gap:10px;">
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Base al tipo oficial</span>
            <span id="base" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Comisión red + banco</span>
            <span id="comision" style="font-size:13px; font-weight:700; color:#EF4444;">0</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Tipo de cambio efectivo</span>
            <span id="tc-efectivo" style="font-size:13px; font-weight:700; color:#8B5CF6;">0</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Costo total del recargo</span>
            <span id="costo-pct" style="font-size:13px; font-weight:700; color:#EF4444;">0%</span>
          </div>
        </div>
        <div style="background:#F5F3FF; border:1px solid #DDD6FE; border-radius:10px; padding:14px 16px;">
          <p style="font-size:12px; color:#5b21b6; line-height:1.6; margin:0;">Algunos bancos cobran recargos del 5-8% en compras internacionales. Busca tarjetas sin recargo para viajeros frecuentes.</p>
        </div>
      </div>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:0 20px 60px;" class="prose">
    <h2>Los cargos ocultos de las tarjetas internacionales</h2>
    <p>Cuando pagas con tarjeta en otro país o en una tienda online extranjera, se aplican varios cargos que pueden sumar entre el 3% y el 8% adicional sobre el tipo de cambio oficial. Entenderlos te permite elegir mejor tu método de pago.</p>
    <p>Los dos cargos principales son: la <strong>comisión de la red</strong> (Visa o Mastercard aplican generalmente 1% por conversión de divisa) y el <strong>recargo del banco emisor</strong> (varía por banco, usualmente entre 1.5% y 5%). Algunos bancos además aplican su propio tipo de cambio en lugar del oficial, lo que puede agregar otro 1-2%.</p>
    <h2>Cómo reducir el costo</h2>
    <p>Busca tarjetas diseñadas para viajeros que no cobran recargo por divisas (muchos bancos digitales y neobancos lo ofrecen). Si vas a hacer una compra grande, compara el costo total de pagar con tarjeta vs retirar efectivo local (que tiene su propio cargo de ATM) vs transferencia internacional.</p>
    <p>Usa la <a href="/calculadoras/tipo-cambio-efectivo">calculadora de tipo de cambio efectivo</a> para comparar opciones de cambio.</p>
  </div>
</Layout>

<script>
  const DEC: Record<string,number> = {COP:0,MXN:2,ARS:0,CLP:0,PEN:2,UYU:2,BOB:2,DOP:2,GTQ:2};
  function fmt(n: number, m: string) {
    const d = DEC[m] ?? 2;
    return new Intl.NumberFormat('es',{minimumFractionDigits:d,maximumFractionDigits:d}).format(n) + ' ' + m;
  }
  function calcular() {
    const m = (document.getElementById('moneda') as HTMLSelectElement).value;
    const montoExt = parseFloat((document.getElementById('monto-ext') as HTMLInputElement).value) || 0;
    const tc = parseFloat((document.getElementById('tc') as HTMLInputElement).value) || 0;
    const red = parseFloat((document.getElementById('red') as HTMLInputElement).value) / 100 || 0;
    const banco = parseFloat((document.getElementById('banco') as HTMLInputElement).value) / 100 || 0;
    const baseLocal = montoExt * tc;
    const totalComisiones = red + banco;
    const totalLocal = baseLocal * (1 + totalComisiones);
    const comision = totalLocal - baseLocal;
    const tcEfectivo = montoExt > 0 ? totalLocal / montoExt : 0;
    const costoPct = totalComisiones * 100;
    document.getElementById('total-local')!.textContent = fmt(totalLocal, m);
    document.getElementById('base')!.textContent = fmt(baseLocal, m);
    document.getElementById('comision')!.textContent = '+' + fmt(comision, m);
    document.getElementById('tc-efectivo')!.textContent = tcEfectivo.toLocaleString('es', {maximumFractionDigits:2});
    document.getElementById('costo-pct')!.textContent = '+' + costoPct.toFixed(1) + '%';
  }
  ['monto-ext','tc','red','banco','moneda'].forEach(id => document.getElementById(id)?.addEventListener('input', calcular));
  calcular();
</script>
<style>@media(max-width:600px){div[style*="grid-template-columns:1fr 1fr"]{display:flex!important;flex-direction:column!important;}}</style>
