                <input id="t2" type="number" value="36" min="0" step="0.1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:9px 12px; font-size:14px; font-family:inherit; background:#fff; color:#1A1A1A; outline:none; box-sizing:border-box;" />
              </div>
