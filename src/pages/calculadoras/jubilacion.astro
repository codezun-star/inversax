---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Calculadora de Jubilación — ¿Cuánto Ahorrar para el Retiro? | Inversax" description="Calcula cuánto debes ahorrar mensualmente para jubilarte con la renta que deseas. Para Colombia, México, Chile, Perú y toda Latinoamérica. AFP, AFORE, ONP. 19 monedas.">
  <Fragment slot="head">
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cuánto dinero necesito para jubilarme en Latinoamérica?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Depende de cuánto quieras gastar al mes en el retiro y cuántos años dure. Fórmula: Capital necesario = Renta mensual × (1 − (1+r)^−n) / r, donde r es la tasa mensual y n los meses de retiro. Ejemplo: para vivir con 1.500 USD/mes durante 20 años al 5% anual necesitas acumular ~227.000 USD al momento de jubilarte."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto ahorrar mensualmente para el retiro si empiezo a los 30 años?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Si tienes 30 años, quieres jubilarte a los 65 y vivir con 2.000 USD/mes durante 25 años, necesitas acumular ~340.000 USD. Con un rendimiento del 7% anual y 35 años de ahorro, necesitarías aportar aproximadamente 175 USD/mes. Si empiezas a los 40, esa cifra casi se triplica."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué sistema de pensiones existe en Colombia, México y Chile?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Colombia: puedes elegir entre Colpensiones (beneficio definido) o fondos privados RAIS. México: AFORE, el saldo es tuyo pero la pensión pública es baja. Chile: AFP privadas, el ahorro es individual. Perú: ONP (beneficio definido, baja cobertura) o AFP (contribución definida). En todos los casos, el ahorro privado adicional es fundamental."
          }
        },
        {
          "@type": "Question",
          "name": "¿Debo incluir la pensión del Estado en mi cálculo de jubilación?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "La calculadora no incluye pensión estatal porque varía mucho por país y nivel de cotización. En Latinoamérica, la pensión pública típicamente reemplaza el 30-50% del último salario. Úsala como ingreso complementario restándola de la renta mensual que ingresas en la calculadora para obtener solo el ahorro adicional que necesitas."
          }
        }
      ]
    }
    </script>
  </Fragment>
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:800px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:16px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a><span>›</span>
        <a href="/calculadoras" style="text-decoration:none; color:#A8A29E;">Calculadoras</a><span>›</span>
        <span style="color:#57534E;">Jubilación</span>
      </div>
      <h1 style="font-size:clamp(22px,4vw,32px); font-weight:800; color:#1A1A1A; margin:0 0 8px; letter-spacing:-0.3px;">Calculadora de Jubilación</h1>
      <p style="font-size:15px; color:#57534E; line-height:1.65; margin:0;">Planifica tu retiro: descubre cuánto debes ahorrar hoy para vivir como quieres mañana.</p>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:40px 20px;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
      <div style="background:#fff; border:1px solid #E2DDD8; border-radius:14px; padding:28px;">
        <h2 style="font-size:16px; font-weight:700; color:#1A1A1A; margin:0 0 20px;">Tu situación</h2>
        <div style="display:flex; flex-direction:column; gap:16px;">
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Moneda</label>
            <select id="moneda" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:14px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; cursor:pointer; box-sizing:border-box;">
              <option value="USD">USD — Dólar (EC, PA, SV, PR)</option>
              <option value="COP">COP — Peso colombiano</option>
              <option value="MXN">MXN — Peso mexicano</option>
              <option value="ARS">ARS — Peso argentino</option>
              <option value="CLP">CLP — Peso chileno</option>
              <option value="PEN">PEN — Sol peruano</option>
              <option value="UYU">UYU — Peso uruguayo</option>
              <option value="BOB">BOB — Boliviano</option>
              <option value="PYG">PYG — Guaraní paraguayo</option>
              <option value="VES">VES — Bolívar venezolano</option>
              <option value="CRC">CRC — Colón costarricense</option>
              <option value="DOP">DOP — Peso dominicano</option>
              <option value="GTQ">GTQ — Quetzal guatemalteco</option>
              <option value="HNL">HNL — Lempira hondureño</option>
              <option value="NIO">NIO — Córdoba nicaragüense</option>
              <option value="CUP">CUP — Peso cubano</option>
              <option value="BZD">BZD — Dólar de Belice</option>
              <option value="CAD">CAD — Dólar canadiense</option>
              <option value="EUR">EUR — Euro (España)</option>
            </select>
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Edad actual</label>
            <input id="edad" type="number" value="30" min="18" max="80" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Edad de jubilación deseada</label>
            <input id="jubilacion" type="number" value="65" min="30" max="90" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Renta mensual deseada en retiro</label>
            <input id="renta" type="number" value="2000" min="1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Esperanza de vida estimada</label>
            <input id="vida" type="number" value="85" min="60" max="110" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Rendimiento anual esperado (%)</label>
            <input id="tasa" type="number" value="7" min="0" step="0.1" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
          <div>
            <label style="font-size:13px; font-weight:600; color:#57534E; display:block; margin-bottom:6px;">Ahorro actual acumulado</label>
            <input id="actual" type="number" value="0" min="0" style="width:100%; border:1px solid #E2DDD8; border-radius:8px; padding:10px 14px; font-size:15px; font-family:inherit; background:#F7F7F5; color:#1A1A1A; outline:none; box-sizing:border-box;" />
          </div>
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:14px;">
        <div style="background:#FF8C42; border-radius:14px; padding:24px; color:#fff;">
          <p style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 6px; opacity:0.85;">Ahorro mensual necesario</p>
          <p id="cuota" style="font-size:28px; font-weight:800; margin:0; letter-spacing:-0.5px;">0</p>
        </div>
        <div style="background:#fff; border:1px solid #E2DDD8; border-radius:12px; padding:18px; display:flex; flex-direction:column; gap:10px;">
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Años hasta jubilarse</span>
            <span id="anos-ahorro" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Años de retiro</span>
            <span id="anos-retiro" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Capital necesario al retiro</span>
            <span id="capital-meta" style="font-size:13px; font-weight:700; color:#1A1A1A;">0</span>
          </div>
          <div style="height:1px; background:#E2DDD8;"></div>
          <div style="display:flex; justify-content:space-between;">
            <span style="font-size:13px; color:#57534E;">Proyección de tu ahorro actual</span>
            <span id="actual-proyectado" style="font-size:13px; font-weight:700; color:#22C55E;">0</span>
          </div>
        </div>
        <div style="background:#FFF4EC; border:1px solid #FFD4A8; border-radius:10px; padding:14px 16px;">
          <p style="font-size:12px; color:#78716C; line-height:1.6; margin:0;">Estimación basada en rendimiento nominal. No incluye inflación ni pensión del Estado. Ajusta la tasa hacia abajo para ser más conservador.</p>
        </div>
      </div>
    </div>
  </div>

  <div style="max-width:800px; margin:0 auto; padding:0 20px 60px;" class="prose">
    <h2>¿Por qué planificar la jubilación desde hoy?</h2>
    <p>La jubilación es la meta financiera más importante y también la más ignorada. La razón: se ve lejana. Pero cada año que pospones la planificación tiene un costo enorme por el efecto del interés compuesto. Alguien que empieza a ahorrar para el retiro a los 25 años necesita ahorrar menos de la mitad por mes que alguien que empieza a los 35, para llegar al mismo capital.</p>
    <p>En Latinoamérica, los sistemas de pensiones públicas ofrecen coberturas cada vez más bajas. En muchos países, la pensión pública reemplaza solo el 40-50% del último salario. El resto depende de ti.</p>

    <h2>¿Cómo usar esta calculadora?</h2>
    <ul>
      <li><strong>Edad actual y edad de jubilación:</strong> definen cuántos años tienes para ahorrar. La diferencia determina el plazo de acumulación.</li>
      <li><strong>Renta mensual deseada en retiro:</strong> cuánto dinero quieres tener disponible cada mes durante tu jubilación, en moneda de hoy.</li>
      <li><strong>Esperanza de vida:</strong> define cuántos años durará tu retiro. Sé conservador: usa 85-90 años para estar cubierto. La calculadora asegura que el fondo dure hasta esa edad.</li>
      <li><strong>Rendimiento anual:</strong> la tasa a la que crecerá tu ahorro durante la acumulación y durante el retiro. Usa tasas reales (descontada inflación) para una estimación honesta: 4-6% en dólares.</li>
      <li><strong>Ahorro actual acumulado:</strong> si ya tienes ahorros destinados al retiro (AFP, fondo de pensiones, inversiones propias), inclúyelos. Se proyectarán al valor que tendrán en la fecha de jubilación.</li>
    </ul>

    <h2>¿Cómo interpretar los resultados?</h2>
    <p>El <strong>capital necesario al retiro</strong> es el monto total que debes tener acumulado el día que dejes de trabajar, para poder vivir de las rentas durante toda tu jubilación. Este número puede parecer enorme, pero el objetivo es acumularlo gradualmente durante décadas.</p>
    <p>El <strong>ahorro mensual necesario</strong> es lo que debes separar cada mes desde hoy para llegar a ese capital. Si ya tienes ahorros, la <strong>proyección de tu ahorro actual</strong> muestra cuánto de ese capital ya tienes "cubierto".</p>

    <h2>Sistemas de pensiones por país</h2>
    <ul>
      <li><strong>Chile:</strong> AFP privadas. El ahorro es tuyo, pero la cobertura depende de tu densidad de cotización.</li>
      <li><strong>Colombia:</strong> puedes elegir entre RPM (Colpensiones, beneficio definido) y RAIS (fondos privados, contribución definida).</li>
      <li><strong>México:</strong> IMSS AFORE. El saldo es tuyo pero la pensión pública es baja.</li>
      <li><strong>Perú:</strong> ONP (beneficio definido, baja cobertura) o AFP (contribución definida).</li>
      <li><strong>España:</strong> sistema público de reparto con pensión basada en años cotizados. Complementar con planes privados es recomendable.</li>
    </ul>
    <p>Independientemente del sistema de tu país, este cálculo muestra cuánto necesitas ahorrar <strong>adicionalmente</strong> a lo que aportará el Estado. Para la fase de acumulación, revisa los <a href="/brokers/co">mejores brokers disponibles en tu país</a> para invertir ese ahorro privado.</p>
  </div>
</Layout>

<script>
  const DEC: Record<string,number> = {USD:2,COP:0,MXN:2,ARS:0,CLP:0,PEN:2,UYU:2,BOB:2,PYG:0,VES:2,CRC:0,DOP:2,GTQ:2,HNL:2,NIO:2,CUP:2,BZD:2,CAD:2,EUR:2};
  function fmt(n: number, m: string) {
    const d = DEC[m] ?? 2;
    return new Intl.NumberFormat('es',{minimumFractionDigits:d,maximumFractionDigits:d}).format(n) + ' ' + m;
  }
  function calcular() {
    const m        = (document.getElementById('moneda')    as HTMLSelectElement).value;
    const edad     = parseFloat((document.getElementById('edad')       as HTMLInputElement).value) || 30;
    const jub      = parseFloat((document.getElementById('jubilacion') as HTMLInputElement).value) || 65;
    const renta    = parseFloat((document.getElementById('renta')      as HTMLInputElement).value) || 0;
    const vida     = parseFloat((document.getElementById('vida')       as HTMLInputElement).value) || 85;
    const r        = parseFloat((document.getElementById('tasa')       as HTMLInputElement).value) || 0;
    const actual   = parseFloat((document.getElementById('actual')     as HTMLInputElement).value) || 0;
    const anosAhorro = Math.max(0, jub - edad);
    const anosRetiro = Math.max(0, vida - jub);
    const rm = r / 100 / 12;
    // Capital needed at retirement to sustain monthly income
    let capitalMeta = 0;
    if (rm === 0) {
      capitalMeta = renta * anosRetiro * 12;
    } else {
      const nRet = anosRetiro * 12;
      capitalMeta = renta * (1 - Math.pow(1 + rm, -nRet)) / rm;
    }
    // Projection of current savings at retirement
    const nAhorro = anosAhorro * 12;
    const actualProyectado = actual * Math.pow(1 + rm, nAhorro);
    const faltante = Math.max(0, capitalMeta - actualProyectado);
    // Monthly contribution needed
    let cuota = 0;
    if (nAhorro === 0) {
      cuota = faltante;
    } else if (rm === 0) {
      cuota = faltante / nAhorro;
    } else {
      cuota = faltante * rm / (Math.pow(1 + rm, nAhorro) - 1);
    }
    document.getElementById('cuota')!.textContent            = fmt(cuota, m);
    document.getElementById('anos-ahorro')!.textContent      = anosAhorro + ' años';
    document.getElementById('anos-retiro')!.textContent      = anosRetiro + ' años';
    document.getElementById('capital-meta')!.textContent     = fmt(capitalMeta, m);
    document.getElementById('actual-proyectado')!.textContent = fmt(actualProyectado, m);
  }
  ['moneda','edad','jubilacion','renta','vida','tasa','actual'].forEach(id => document.getElementById(id)?.addEventListener('input', calcular));
  calcular();
</script>
<style>@media(max-width:600px){div[style*="grid-template-columns:1fr 1fr"]{display:flex!important;flex-direction:column!important;}}</style>
