---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const post = await getEntry('blog', slug);

if (!post) return Astro.redirect('/blog');

const { Content } = await render(post);

const categorias: Record<string, string> = {
  brokers: 'Brokers',
  guias: 'Guías',
  analisis: 'Análisis',
  general: 'General',
};

const pageUrl = 'https://inversax.com/blog/' + post.slug;
const waUrl = 'https://wa.me/?text=' + encodeURIComponent(post.data.titulo + ' — ' + pageUrl);
const xUrl = 'https://x.com/intent/tweet?url=' + encodeURIComponent(pageUrl) + '&text=' + encodeURIComponent(post.data.titulo);

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.titulo,
  description: post.data.descripcion ?? '',
  author: { '@type': 'Organization', name: post.data.autor ?? 'Equipo Inversax' },
  publisher: {
    '@type': 'Organization',
    name: 'Inversax',
    url: 'https://inversax.com',
    logo: { '@type': 'ImageObject', url: 'https://inversax.com/og/home.png' },
  },
  datePublished: post.data.fecha ?? '',
  dateModified: post.data.fecha ?? '',
  url: 'https://inversax.com/blog/' + post.slug,
  mainEntityOfPage: { '@type': 'WebPage', '@id': 'https://inversax.com/blog/' + post.slug },
});

const faqSchema = post.data.faq ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: post.data.faq.map((f: { pregunta: string; respuesta: string }) => ({
    '@type': 'Question',
    name: f.pregunta,
    acceptedAnswer: { '@type': 'Answer', text: f.respuesta },
  })),
}) : null;
---

<Layout
  title={`${post.data.titulo} — Inversax`}
  description={post.data.descripcion ?? ''}
  ogType="article"
>
  <script slot="head" is:inline type="application/ld+json" set:html={articleSchema} />
  {faqSchema && <script slot="head" is:inline type="application/ld+json" set:html={faqSchema} />}
  <!-- Header artículo -->
  <div style="background:#fff; border-bottom:1px solid #E2DDD8; padding:40px 20px 32px;">
    <div style="max-width:720px; margin:0 auto;">
      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#A8A29E; margin-bottom:20px; flex-wrap:wrap;">
        <a href="/" style="text-decoration:none; color:#A8A29E;">Inicio</a>
        <span>›</span>
        <a href="/blog" style="text-decoration:none; color:#A8A29E;">Blog</a>
        <span>›</span>
        <span style="color:#57534E; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:200px;">{post.data.titulo}</span>
      </div>

      <div style="display:flex; align-items:center; gap:8px; margin-bottom:14px; flex-wrap:wrap;">
        {post.data.categoria && (
          <span style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; background:#FFF4EC; color:#FF8C42; padding:3px 10px; border-radius:5px;">
            {categorias[post.data.categoria] ?? post.data.categoria}
          </span>
        )}
        {post.data.pais && (
          <span style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; background:#F0EDE7; color:#78716C; padding:3px 10px; border-radius:5px;">
            {post.data.pais.toUpperCase()}
          </span>
        )}
      </div>

      <h1 style="font-size:clamp(22px, 4vw, 34px); font-weight:800; color:#1A1A1A; margin:0 0 12px; line-height:1.2; letter-spacing:-0.4px;">
        {post.data.titulo}
      </h1>

      {post.data.descripcion && (
        <p style="font-size:16px; color:#57534E; line-height:1.65; margin:0 0 16px;">{post.data.descripcion}</p>
      )}

      <div style="display:flex; align-items:center; gap:16px; flex-wrap:wrap;">
        <span style="font-size:13px; color:#A8A29E;">
          Por <strong style="color:#57534E;">{post.data.autor}</strong>
        </span>
        {post.data.fecha && (
          <span style="font-size:13px; color:#A8A29E;">{post.data.fecha}</span>
        )}
      </div>
    </div>
  </div>

  <!-- Contenido -->
  <div style="max-width:720px; margin:0 auto; padding:40px 20px 60px;">
    <div class="prose"><Content /></div>

    <!-- Compartir -->
    <div style="margin-top:40px; padding-top:28px; border-top:1px solid #E2DDD8;">
      <p style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#A8A29E; margin:0 0 12px;">Compartir artículo</p>
      <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
        <a
          href={waUrl}
          target="_blank"
          rel="noopener noreferrer"
          style="display:inline-flex; align-items:center; gap:7px; font-size:13px; font-weight:600; color:#fff; background:#25D366; padding:9px 16px; border-radius:8px; text-decoration:none;"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          WhatsApp
        </a>
        <a
          href={xUrl}
          target="_blank"
          rel="noopener noreferrer"
          style="display:inline-flex; align-items:center; gap:7px; font-size:13px; font-weight:600; color:#fff; background:#1A1A1A; padding:9px 16px; border-radius:8px; text-decoration:none;"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          X
        </a>
        <button
          id="copy-link-btn"
          style="display:inline-flex; align-items:center; gap:7px; font-size:13px; font-weight:600; color:#57534E; background:#F0EDE7; border:none; padding:9px 16px; border-radius:8px; cursor:pointer;"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="2" width="6" height="4" rx="1"></rect>
            <path d="M17 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
          </svg>
          <span id="copy-link-label">Copiar link</span>
        </button>
      </div>
    </div>

    <!-- CTA brokers -->
    <div style="margin-top:40px; background:#FFF4EC; border:1px solid #FFD4A8; border-radius:12px; padding:24px;">
      <p style="font-size:15px; font-weight:700; color:#1A1A1A; margin:0 0 6px;">
        ¿Buscas el mejor broker para tu país?
      </p>
      <p style="font-size:13px; color:#78716C; line-height:1.55; margin:0 0 14px;">
        Compara todos los brokers disponibles por país, regulación, depósito mínimo y más.
      </p>
      <a href="/brokers" class="btn-primary btn-sm" style="font-size:14px; padding:11px 20px; border-radius:9px;">
        Ver comparador de brokers
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>

    <!-- Volver -->
    <div style="margin-top:24px;">
      <a href="/blog" style="display:inline-flex; align-items:center; gap:6px; font-size:13px; color:#78716C; text-decoration:none;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Volver al blog
      </a>
    </div>
  </div>
</Layout>

<script is:inline>
  var btn = document.getElementById('copy-link-btn');
  var label = document.getElementById('copy-link-label');
  if (btn && label) {
    btn.addEventListener('click', function () {
      navigator.clipboard.writeText(window.location.href).then(function () {
        label.textContent = 'Copiado';
        setTimeout(function () { label.textContent = 'Copiar link'; }, 2000);
      });
    });
  }
</script>
