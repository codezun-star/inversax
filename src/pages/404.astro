---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada — Inversax" description="La página que buscas no existe.">
  <div style="min-height:60vh; display:flex; align-items:center; justify-content:center; padding:40px 20px;">
    <div style="text-align:center; max-width:400px;">
      <div style="font-size:64px; font-weight:800; color:#E2DDD8; line-height:1; margin-bottom:16px;">404</div>
      <h1 style="font-size:22px; font-weight:700; color:#1A1A1A; margin:0 0 10px;">Página no encontrada</h1>
      <p style="font-size:15px; color:#78716C; line-height:1.65; margin:0 0 28px;">
        La página que buscas no existe o fue movida.
      </p>
      <div style="display:flex; flex-wrap:wrap; gap:10px; justify-content:center;">
        <a href="/" style="background:#FF8C42; color:#fff; font-size:14px; font-weight:700; padding:11px 22px; border-radius:9px; text-decoration:none;">Ir al inicio</a>
        <a href="/brokers" style="background:#F7F7F5; color:#1A1A1A; font-size:14px; font-weight:600; padding:11px 22px; border-radius:9px; text-decoration:none; border:1px solid #E2DDD8;">Ver brokers</a>
      </div>
    </div>
  </div>
</Layout>
