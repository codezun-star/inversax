---
import Layout from '../../layouts/Layout.astro';
import { paises, getPais } from '../../lib/paises';
import { getBrokersByPais } from '../../lib/brokers';

export function getStaticPaths() {
  return paises.map((p) => ({ params: { pais: p.codigo } }));
}

const { pais: codigoPais } = Astro.params;
const pais = getPais(codigoPais);
if (!pais) return Astro.redirect('/brokers');

const todos = getBrokersByPais(codigoPais);
const recomendado = todos[0];
const brokersList = [
  recomendado,
  ...todos.filter((b) => b.id !== recomendado?.id).sort((a, b) => b.calificacion - a.calificacion),
];

function stars(r: number): string {
  const full = Math.floor(r);
  const half = r % 1 >= 0.5;
  const empty = 5 - full - (half ? 1 : 0);
  const svgFull  = '<svg width="14" height="14" viewBox="0 0 24 24" fill="#FF8C42" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>';
  const svgEmpty = '<svg width="14" height="14" viewBox="0 0 24 24" fill="#E2DDD8" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>';
  return svgFull.repeat(full) + (half ? svgFull : '') + svgEmpty.repeat(empty);
}

const nivelLabel: Record<string,string> = { principiante:'Principiante', intermedio:'Intermedio', avanzado:'Avanzado', todos:'Todos los niveles' };
const nivelColor: Record<string,string> = { principiante:'#22C55E', intermedio:'#3B82F6', avanzado:'#8B5CF6', todos:'#FF8C42' };

// Pre-compute all per-broker display data to avoid template literals in JSX
// Países donde la mayoría de brokers internacionales tienen restricciones
const paisesRestringidos: Record<string, string> = {
  cu: 'Cuba está sujeta a sanciones internacionales que limitan severamente el acceso a servicios financieros extranjeros. Las opciones de brokers son muy escasas y pueden cambiar sin previo aviso.',
};
const avisoRestriccion = paisesRestringidos[codigoPais] ?? null;

// Schema.org JSON-LD — ItemList of FinancialService
const schemaJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Mejores brokers para invertir en ' + pais.nombre + ' 2026',
  description: 'Comparativa de los ' + brokersList.length + ' mejores brokers disponibles en ' + pais.nombre + ' en 2026.',
  numberOfItems: brokersList.length,
  itemListElement: brokersList.map((b, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'FinancialService',
      name: b.nombre,
      description: b.descripcion,
      url: b.afiliado,
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: String(b.calificacion),
        bestRating: '5',
        worstRating: '1',
        ratingCount: '1',
      },
    },
  })),
});

const brokersData = brokersList.map((b, i) => {
  const isTop   = i === 0;
  const nc      = nivelColor[b.nivelUsuario] ?? '#FF8C42';
  const deposit = b.depositoMinimo === null ? 'Sin mínimo'
                : b.depositoMinimo === 0    ? 'Sin mínimo'
                : '$' + b.depositoMinimo + ' ' + b.monedaDeposito;
  return {
    b, i, isTop, nc, deposit,
    starsHtml:    stars(b.calificacion),
    // CSS custom props string — only dynamic inline style needed
    cssVars: '--bc:' + b.color + '; --bcbg:' + b.colorBg + '; --nc:' + nc,
    // Extra computed display values
    depositHighlight: b.depositoMinimo === null || b.depositoMinimo === 0 || (b.depositoMinimo !== null && b.depositoMinimo <= 10),
    tableRowBg: i === 0 ? '#FFFBF7' : '#fff',
    tableBadge: i === 0 ? '#FF8C42' : 'transparent',
    tableBadgeText: i === 0 ? '#fff' : 'transparent',
  };
});
---

<Layout
  title={'Mejores brokers en ' + pais.nombre + ' 2026 — Inversax'}
  description={'Comparativa de los ' + brokersList.length + ' mejores brokers para invertir en ' + pais.nombre + ' en 2026. Regulación, depósito mínimo, spreads y métodos de pago locales.'}
>
  <script slot="head" is:inline type="application/ld+json" set:html={schemaJson} />

<!-- HERO -->
<div class="hero-dark">
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Inicio</a>
      <span>›</span>
      <a href="/brokers">Brokers</a>
      <span>›</span>
      <span class="bc-current">{pais.nombre}</span>
    </nav>

    <div class="hero-inner">
      <div>
        <div class="location-pill">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#FF8C42" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>{pais.nombre} · {pais.moneda}</span>
        </div>
        <h1>Mejores brokers<br/>para invertir en {pais.nombre}</h1>
        <p class="hero-sub">{pais.descripcion}</p>
      </div>

      <div class="hero-stats">
        <div class="stat-box">
          <p class="stat-num">{brokersList.length}</p>
          <p class="stat-label">Brokers</p>
        </div>
        <div class="stat-box">
          <p class="stat-num white">{pais.moneda}</p>
          <p class="stat-label">Moneda</p>
        </div>
        <div class="stat-box">
          <p class="stat-num-sm">{pais.metodosPago.slice(0,2).join(' · ')}</p>
          <p class="stat-label">Métodos de pago</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- BROKER CARDS -->
<div class="container" style="padding-top:40px; padding-bottom:60px;">

  {avisoRestriccion && (
    <div style="background:#FEF9EC; border:1px solid #F5D87A; border-radius:12px; padding:16px 20px; margin-bottom:28px; display:flex; align-items:flex-start; gap:12px;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#B45309" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:1px;">
        <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
        <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
      </svg>
      <p style="font-size:13px; color:#92400E; line-height:1.65; margin:0;">
        <strong style="color:#78350F;">Aviso importante para {pais.nombre}:</strong> {avisoRestriccion}
      </p>
    </div>
  )}

  <div class="cards-list">

    {brokersData.map(({ b, i, isTop, nc, deposit, starsHtml, cssVars, depositHighlight }) => (
      <article class={'broker-card' + (isTop ? ' is-top' : '')} style={cssVars}>

        {(b.badge || isTop) && (
          <div class="card-badge">
            {isTop && (
              <svg width="12" height="12" viewBox="0 0 24 24" fill="#fff" stroke="none">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            )}
            <span>{isTop ? '#1 Recomendado para ' + pais.nombre : b.badge}</span>
          </div>
        )}

        <div class="card-body">
          <!-- Logo + nombre + rating -->
          <div class="card-header">
            <div class="logo-wrap">
              <img
                src={b.logo}
                alt={'Logo ' + b.nombre}
                width="38" height="38"
                loading={i < 2 ? 'eager' : 'lazy'}
              />
            </div>
            <div class="card-title-group">
              <div class="card-title-row">
                <h2>{b.nombre}</h2>
                <span class="nivel-badge">{nivelLabel[b.nivelUsuario]}</span>
                <span class="tipo-badge">{b.tipo}</span>
              </div>
              <p class="tagline">{b.tagline}</p>
            </div>
            <div class="rating-block">
              <span class="rating-num">{b.calificacion}</span>
              <div class="stars-row" set:html={starsHtml} />
              <span class="rating-sub">sobre 5</span>
            </div>
          </div>

          <p class="card-desc">{b.descripcion}</p>

          <!-- Stats -->
          <div class="stats-grid">
            <div class={'stat-item' + (depositHighlight ? ' stat-hl' : '')}>
              <span class="stat-item-label">Depósito mínimo</span>
              <span class={'stat-item-val' + (depositHighlight ? ' hl' : '')}>{deposit}</span>
            </div>
            <div class="stat-item">
              <span class="stat-item-label">Spread desde</span>
              <span class="stat-item-val">{b.spread}</span>
            </div>
            <div class="stat-item">
              <span class="stat-item-label">Apalancamiento</span>
              <span class="stat-item-val">{b.apalancamientoMax}</span>
            </div>
            <div class="stat-item">
              <span class="stat-item-label">Fundado</span>
              <span class="stat-item-val">{b.fundado + ' · ' + b.sede}</span>
            </div>
          </div>

          <!-- Regulación + Plataformas -->
          <div class="two-cols">
            <div>
              <p class="section-label">Regulado por</p>
              <div class="pill-group">
                {b.regulacion.map((r) => <span class="reg-pill">{r}</span>)}
              </div>
            </div>
            <div>
              <p class="section-label">Plataformas</p>
              <div class="pill-group">
                {b.plataformas.map((p) => <span class="plat-pill">{p}</span>)}
              </div>
            </div>
          </div>

          <!-- Pros + Contras -->
          <div class="two-cols pros-contras">
            <div class="pros-box">
              <p class="section-label">Lo mejor</p>
              {b.pros.map((pro) => (
                <div class="check-row">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{pro}</span>
                </div>
              ))}
            </div>
            <div class="contras-box">
              <p class="section-label">A tener en cuenta</p>
              {b.contras.map((con) => (
                <div class="check-row">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                  <span>{con}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Activos -->
          <div class="activos-section">
            <p class="section-label">Activos disponibles</p>
            <div class="pill-group">
              {b.tiposActivos.map((a) => <span class="activo-pill">{a}</span>)}
            </div>
          </div>

          <!-- CTA -->
          <div class="cta-row">
            <a href={b.afiliado} target="_blank" rel="noopener noreferrer sponsored" class="cta-btn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              Abrir cuenta en {b.nombre}
            </a>
            <span class="cta-note">Cuenta demo gratuita disponible · Enlace de afiliado</span>
          </div>
        </div>
      </article>
    ))}
  </div>

  <!-- TABLA COMPARATIVA -->
  <div class="table-section">
    <h2 class="table-title">Comparativa rápida — {pais.nombre}</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Broker</th>
            <th>Calificación</th>
            <th>Depósito mín.</th>
            <th>Spread</th>
            <th>Nivel</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {brokersData.map(({ b, i, nc, deposit }) => (
            <tr class={i === 0 ? 'row-top' : ''}>
              <td class="td-broker">
                <img src={b.logo} alt={b.nombre} width="22" height="22" loading="lazy" />
                <span>{b.nombre}</span>
                {i === 0 && <span class="top-tag">Top</span>}
              </td>
              <td class="td-center td-rating">{b.calificacion}</td>
              <td class="td-center td-deposit">{deposit}</td>
              <td class="td-center td-spread">{b.spread}</td>
              <td class="td-center">
                <span class="nivel-badge-sm">{nivelLabel[b.nivelUsuario]}</span>
              </td>
              <td class="td-right">
                <a href={b.afiliado} target="_blank" rel="noopener noreferrer sponsored" class="table-cta">
                  Abrir cuenta
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <div class="disclaimer">
    <p><strong>Aviso de afiliados:</strong> Inversax puede recibir compensación cuando abres una cuenta a través de nuestros enlaces. Esto no afecta nuestras recomendaciones. El trading de CFDs implica riesgo significativo de pérdida de capital. Verifica la regulación vigente en {pais.nombre} antes de abrir una cuenta.</p>
  </div>
</div>

</Layout>

<style>
  /* ── Layout ── */
  .hero-dark { background: linear-gradient(135deg, #1A1A1A 0%, #2D2520 100%); padding: 48px 20px 40px; border-bottom: 1px solid #2D2826; }
  .container  { max-width: 1000px; margin: 0 auto; padding: 0 20px; }
  .breadcrumb { display: flex; align-items: center; gap: 6px; font-size: 13px; color: #6B6460; margin-bottom: 24px; flex-wrap: wrap; }
  .breadcrumb a { color: #6B6460; text-decoration: none; }
  .bc-current { color: #C7BFB5; }
  .hero-inner { display: flex; align-items: flex-start; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
  .location-pill { display: inline-flex; align-items: center; gap: 7px; background: rgba(255,140,66,0.12); border: 1px solid rgba(255,140,66,0.25); border-radius: 20px; padding: 5px 14px; margin-bottom: 16px; font-size: 12px; font-weight: 600; color: #FF8C42; }
  h1 { font-size: clamp(24px, 4vw, 38px); font-weight: 800; color: #fff; margin: 0 0 10px; letter-spacing: -0.5px; line-height: 1.1; }
  .hero-sub { font-size: 15px; color: #A09890; line-height: 1.65; margin: 0; max-width: 440px; }
  .hero-stats { display: flex; gap: 12px; flex-wrap: wrap; }
  .stat-box { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 16px 20px; min-width: 100px; text-align: center; }
  .stat-num { font-size: 26px; font-weight: 800; color: #FF8C42; margin: 0; line-height: 1; }
  .stat-num.white { color: #fff; }
  .stat-num-sm { font-size: 13px; font-weight: 700; color: #fff; margin: 0 0 2px; line-height: 1.3; }
  .stat-label { font-size: 12px; color: #6B6460; margin: 4px 0 0; font-weight: 500; }

  /* ── Cards list ── */
  .cards-list { display: flex; flex-direction: column; gap: 20px; }

  .broker-card {
    background: linear-gradient(160deg, #ffffff 0%, #fdfcfb 100%);
    border: 1px solid #E2DDD8;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 6px rgba(0,0,0,0.04), 0 1px 2px rgba(0,0,0,0.02), inset 0 1px 0 rgba(255,255,255,0.9);
    position: relative;
    transition: transform 0.24s cubic-bezier(0.4,0,0.2,1), box-shadow 0.24s cubic-bezier(0.4,0,0.2,1);
  }
  .broker-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 44px rgba(0,0,0,0.09), 0 6px 14px rgba(0,0,0,0.05), inset 0 1px 0 rgba(255,255,255,0.9);
  }
  .broker-card.is-top {
    border: 2px solid var(--bc);
    box-shadow: 0 4px 20px rgba(0,0,0,0.06), 0 0 0 4px var(--bcbg), inset 0 1px 0 rgba(255,255,255,0.9);
  }
  .broker-card.is-top:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 44px rgba(0,0,0,0.1), 0 0 0 4px var(--bcbg), 0 6px 16px rgba(0,0,0,0.06), inset 0 1px 0 rgba(255,255,255,0.9);
  }

  /* Badge */
  .card-badge { background: var(--bc); display: flex; align-items: center; gap: 6px; padding: 7px 20px; }
  .card-badge span { font-size: 11px; font-weight: 700; color: #fff; text-transform: uppercase; letter-spacing: 0.07em; }

  /* Body */
  .card-body { padding: 24px 28px; }

  /* Header */
  .card-header { display: flex; align-items: flex-start; gap: 16px; margin-bottom: 18px; flex-wrap: wrap; }
  .logo-wrap { width: 54px; height: 54px; border-radius: 12px; background: var(--bcbg); border: 1px solid color-mix(in srgb, var(--bc) 20%, transparent); display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0; }
  .logo-wrap img { width: 36px; height: 36px; object-fit: contain; }
  .card-title-group { flex: 1; min-width: 0; }
  .card-title-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 4px; }
  .card-title-row h2 { font-size: 20px; font-weight: 800; color: #1A1A1A; margin: 0; }
  .nivel-badge { font-size: 10px; font-weight: 700; color: var(--nc); background: color-mix(in srgb, var(--nc) 12%, transparent); padding: 2px 9px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap; }
  .tipo-badge { font-size: 10px; font-weight: 600; color: #78716C; background: #F0EDE7; padding: 2px 9px; border-radius: 4px; white-space: nowrap; }
  .tagline { font-size: 13px; color: #78716C; margin: 0; font-style: italic; }
  .rating-block { text-align: right; flex-shrink: 0; }
  .rating-num { font-size: 28px; font-weight: 800; color: var(--bc); line-height: 1; display: block; }
  .stars-row { display: flex; align-items: center; gap: 1px; justify-content: flex-end; margin: 3px 0 2px; }
  .rating-sub { font-size: 10px; color: #A8A29E; }

  .card-desc { font-size: 14px; color: #3D3D3D; line-height: 1.7; margin: 0 0 20px; padding-bottom: 20px; border-bottom: 1px solid #F0EDE7; }

  /* Stats */
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 10px; margin-bottom: 20px; }
  .stat-item { background: linear-gradient(150deg, #F8F8F6, #F3F0EC); border: 1px solid #EDEAE5; border-radius: 10px; padding: 12px 14px; }
  .stat-item.stat-hl { background: linear-gradient(150deg, #FFF7F0, #FFF0E4); border-color: #FFD4A8; }
  .stat-item-label { display: block; font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: #A8A29E; font-weight: 600; margin-bottom: 5px; }
  .stat-item-val { font-size: 13px; font-weight: 700; color: #1A1A1A; }
  .stat-item-val.hl { color: #FF8C42; }

  /* Two-col sections */
  .two-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 18px; }
  .section-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.07em; color: #A8A29E; font-weight: 700; margin: 0 0 8px; }
  .pill-group { display: flex; flex-wrap: wrap; gap: 5px; }
  .reg-pill  { font-size: 11px; font-weight: 700; background: var(--bcbg); color: var(--bc); padding: 3px 9px; border-radius: 5px; border: 1px solid color-mix(in srgb, var(--bc) 15%, transparent); }
  .plat-pill { font-size: 11px; font-weight: 600; background: #F0EDE7; color: #57534E; padding: 3px 9px; border-radius: 5px; }

  /* Pros / Contras */
  .pros-box { background: var(--bcbg); border-radius: 10px; padding: 14px 16px; }
  .contras-box { background: #FAFAF8; border: 1px solid #F0EDE7; border-radius: 10px; padding: 14px 16px; }
  .check-row { display: flex; align-items: flex-start; gap: 7px; margin-bottom: 7px; }
  .check-row:last-child { margin-bottom: 0; }
  .check-row svg { flex-shrink: 0; margin-top: 2px; }
  .check-row span { font-size: 12px; color: #3D3D3D; line-height: 1.5; }

  /* Activos */
  .activos-section { margin-bottom: 20px; }
  .activo-pill { font-size: 12px; color: #1A1A1A; background: #F7F7F5; border: 1px solid #E2DDD8; padding: 4px 11px; border-radius: 6px; font-weight: 500; }

  /* CTA */
  .cta-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, #FF9A55 0%, #FF8C42 45%, #FF7428 100%);
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    padding: 13px 24px;
    border-radius: 10px;
    text-decoration: none;
    white-space: nowrap;
    position: relative;
    overflow: hidden;
    box-shadow: 0 2px 6px rgba(255,140,66,0.35), 0 1px 2px rgba(0,0,0,0.08), inset 0 1px 0 rgba(255,255,255,0.2);
    transition: transform 0.18s cubic-bezier(0.4,0,0.2,1), box-shadow 0.18s cubic-bezier(0.4,0,0.2,1);
  }
  .cta-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.24) 50%, transparent 100%);
    transform: translateX(-120%);
    transition: transform 0.55s ease;
    pointer-events: none;
  }
  .cta-btn:hover::after { transform: translateX(120%); }
  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(255,140,66,0.48), 0 2px 6px rgba(0,0,0,0.08), inset 0 1px 0 rgba(255,255,255,0.2);
  }
  .cta-btn:active { transform: translateY(0) scale(0.98); }
