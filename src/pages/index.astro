---
import Layout from '../layouts/Layout.astro';
import { paises } from '../lib/paises';
import { brokers } from '../lib/brokers';

const paisesGrid = paises.slice(0, 12);
const topBrokers = [...brokers].sort((a, b) => b.calificacion - a.calificacion).slice(0, 4);

const calculadoras = [
  {
    titulo: 'Interés Compuesto',
    descripcion: 'Calcula el crecimiento real de tu inversión con reinversión.',
    href: '/calculadoras/interes-compuesto',
    svgPath: 'M22 12h-4l-3 9L9 3l-3 9H2',
    color: '#FF8C42',
  },
  {
    titulo: 'Salario Neto',
    descripcion: 'Descubre cuánto recibes realmente después de impuestos.',
    href: '/calculadoras/salario-neto',
    svgPath: 'M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6',
    color: '#22C55E',
  },
  {
    titulo: 'Conversión de Divisas',
    descripcion: 'Convierte entre USD, EUR, COP, MXN, CLP y más.',
    href: '/calculadoras/conversion-divisas',
    svgPath: 'M8 3H5a2 2 0 00-2 2v3m18 0V5a2 2 0 00-2-2h-3m0 18h3a2 2 0 002-2v-3M3 16v3a2 2 0 002 2h3',
    color: '#3B82F6',
  },
];
---

<Layout
  title="Inversax — Comparador de Brokers para Latinoamérica 2026"
  description="Encuentra el mejor broker para tu país. Comparamos regulación, spreads, depósito mínimo y métodos de pago para Colombia, México, Chile y más."
>

<!-- ── HERO ────────────────────────────────────────── -->
<section style="background:linear-gradient(135deg, #1A1A1A 0%, #2D2520 100%); padding:72px 20px 64px; border-bottom:1px solid #2D2826;">
  <div style="max-width:900px; margin:0 auto; text-align:center;">
    <div style="display:inline-flex; align-items:center; gap:7px; background:rgba(255,140,66,0.12); border:1px solid rgba(255,140,66,0.3); border-radius:20px; padding:6px 16px; margin-bottom:22px;">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="#FF8C42" stroke="none">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
      <span style="font-size:12px; font-weight:600; color:#FF8C42;">{paises.length} países · {brokers.length} brokers · Actualizado 2026</span>
    </div>

    <h1 style="font-size:clamp(30px,6vw,54px); font-weight:800; color:#fff; line-height:1.1; margin:0 0 18px; letter-spacing:-1px;">
      Encuentra el mejor broker<br/>
      <span style="color:#FF8C42;">para tu país</span>
    </h1>

    <p style="font-size:clamp(15px,2vw,18px); color:#A09890; line-height:1.65; margin:0 0 36px; max-width:540px; margin-left:auto; margin-right:auto;">
      Comparamos regulación, spreads, depósito mínimo y métodos de pago locales para que inviertas con confianza.
    </p>

    <div style="display:flex; flex-wrap:wrap; gap:10px; justify-content:center; margin-bottom:48px;">
      <a href="/brokers" class="btn-primary btn-lg">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
        </svg>
        Buscar por mi país
      </a>
      <a href="/calculadoras" style="display:inline-flex; align-items:center; gap:8px; background:rgba(255,255,255,0.06); color:#fff; font-size:15px; font-weight:600; padding:14px 24px; border-radius:10px; text-decoration:none; border:1px solid rgba(255,255,255,0.12);">
        Calculadoras
      </a>
    </div>

    <!-- Logos strip de brokers -->
    <div style="display:flex; align-items:center; justify-content:center; gap:6px; flex-wrap:wrap;">
      <span style="font-size:11px; color:#6B6460; font-weight:600; text-transform:uppercase; letter-spacing:0.07em; margin-right:4px;">Incluye:</span>
      {brokers.map((b) => (
        <div style={`display:flex; align-items:center; gap:6px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.07); border-radius:7px; padding:5px 10px;`}>
          <img src={b.logo} alt={b.nombre} width="18" height="18" style="width:18px;height:18px;object-fit:contain;border-radius:3px;" loading="eager" />
          <span style="font-size:12px; font-weight:600; color:#C7BFB5;">{b.nombre}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── TOP BROKERS ──────────────────────────────────── -->
<section style="background:#fff; border-bottom:1px solid #E2DDD8; padding:56px 20px;">
  <div style="max-width:1000px; margin:0 auto;">
    <div style="display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:8px; margin-bottom:28px;">
      <div>
        <h2 style="font-size:22px; font-weight:800; color:#1A1A1A; margin:0 0 4px; letter-spacing:-0.3px;">Brokers mejor valorados</h2>
        <p style="font-size:14px; color:#78716C; margin:0;">Seleccionados por seguridad, spreads y experiencia de usuario en 2026</p>
      </div>
      <a href="/brokers" style="font-size:13px; font-weight:600; color:#FF8C42; text-decoration:none;">Ver por país →</a>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(220px,1fr)); gap:14px;">
      {topBrokers.map((b, i) => (
        <div
          class="broker-mini-card"
          style={'border:' + (i === 0 ? '2px solid ' + b.color : '1px solid #E2DDD8') + '; border-radius:14px; padding:20px; position:relative; display:flex; flex-direction:column; gap:12px;'}
        >
          {i === 0 && (
            <div style={`position:absolute; top:-1px; left:50%; transform:translateX(-50%); background:${b.color}; color:#fff; font-size:9px; font-weight:800; padding:3px 10px; border-radius:0 0 7px 7px; letter-spacing:0.07em; text-transform:uppercase; white-space:nowrap;`}>
              Nº1 Más valorado
            </div>
          )}

          <div style="display:flex; align-items:center; gap:12px;">
            <div style={`width:44px; height:44px; border-radius:10px; background:${b.colorBg}; border:1px solid ${b.color}22; display:flex; align-items:center; justify-content:center; overflow:hidden; flex-shrink:0;`}>
              <img src={b.logo} alt={b.nombre} width="30" height="30" style="width:30px;height:30px;object-fit:contain;" loading="lazy"
                onerror={`this.style.display='none';this.parentNode.innerHTML='<span style="font-size:16px;font-weight:800;color:${b.color};">${b.nombre[0]}</span>'`} />
            </div>
            <div style="flex:1; min-width:0;">
              <p style="font-size:15px; font-weight:800; color:#1A1A1A; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{b.nombre}</p>
              <p style="font-size:11px; color:#78716C; margin:0;">{b.tipo}</p>
            </div>
            <div style={`font-size:18px; font-weight:800; color:${b.color}; flex-shrink:0;`}>{b.calificacion}</div>
          </div>

          <p style="font-size:12px; color:#57534E; line-height:1.55; margin:0;">{b.tagline}</p>

          <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px;">
            <div style="background:#F7F7F5; border-radius:7px; padding:8px 10px;">
              <p style="font-size:9px; text-transform:uppercase; letter-spacing:0.06em; color:#A8A29E; font-weight:700; margin:0 0 2px;">Depósito</p>
              <p style="font-size:12px; font-weight:700; color:#1A1A1A; margin:0;">{b.depositoMinimo === null ? 'Sin min.' : `$${b.depositoMinimo}`}</p>
            </div>
            <div style="background:#F7F7F5; border-radius:7px; padding:8px 10px;">
              <p style="font-size:9px; text-transform:uppercase; letter-spacing:0.06em; color:#A8A29E; font-weight:700; margin:0 0 2px;">Spread</p>
              <p style="font-size:12px; font-weight:700; color:#1A1A1A; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{b.spread.replace('Desde ', '')}</p>
            </div>
          </div>

          <a
            href="/brokers"
            class="btn-primary btn-sm"
            style={'display:block; text-align:center; background:' + (i === 0 ? 'linear-gradient(135deg,#FF9A55,#FF8C42,#FF7428)' : 'linear-gradient(135deg,#2D2D2D,#1A1A1A)') + '; padding:10px; border-radius:8px;'}
          >
            Ver para mi país →
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── BROKERS POR PAÍS ─────────────────────────────── -->
<section style="padding:56px 20px; background:#F7F7F5;">
  <div style="max-width:1000px; margin:0 auto;">
    <div style="display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:8px; margin-bottom:28px;">
      <div>
        <h2 style="font-size:22px; font-weight:800; color:#1A1A1A; margin:0 0 4px; letter-spacing:-0.3px;">Por país</h2>
        <p style="font-size:14px; color:#78716C; margin:0;">Disponibilidad, métodos de pago y broker recomendado según tu ubicación</p>
      </div>
      <a href="/brokers" style="font-size:13px; font-weight:600; color:#FF8C42; text-decoration:none;">Ver todos →</a>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(175px,1fr)); gap:9px;">
      {paisesGrid.map((p) => {
        const top = brokers.filter((b) => b.paises.includes(p.codigo)).sort((a, b) => b.calificacion - a.calificacion)[0];
        const count = brokers.filter((b) => b.paises.includes(p.codigo)).length;
        return (
          <a
            href={`/brokers/${p.codigo}`}
            class="card-lift"
            style="padding:16px; border-radius:11px;"
          >
            <div style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:8px;">
              <div>
                <p style="font-size:14px; font-weight:800; color:#1A1A1A; margin:0 0 2px;">{p.nombre}</p>
                <p style="font-size:11px; color:#A8A29E; margin:0; font-weight:600;">{count} brokers</p>
              </div>
              {top && (
                <img src={top.logo} alt={top.nombre} width="22" height="22"
                  style="width:22px;height:22px;object-fit:contain;border-radius:4px;flex-shrink:0;" loading="lazy" />
              )}
            </div>
            <div style="display:flex; align-items:center; justify-content:space-between;">
              <span style="font-size:11px; color:#78716C; font-weight:600;">{p.moneda}</span>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#FF8C42" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>

<!-- ── CALCULADORAS ─────────────────────────────────── -->
<section style="padding:56px 20px; background:#fff; border-top:1px solid #E2DDD8;">
  <div style="max-width:1000px; margin:0 auto;">
    <div style="display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:8px; margin-bottom:28px;">
      <div>
        <h2 style="font-size:22px; font-weight:800; color:#1A1A1A; margin:0 0 4px; letter-spacing:-0.3px;">Calculadoras financieras</h2>
        <p style="font-size:14px; color:#78716C; margin:0;">Herramientas para planificar tu inversión antes de abrir una cuenta</p>
      </div>
      <a href="/calculadoras" style="font-size:13px; font-weight:600; color:#FF8C42; text-decoration:none;">Ver todas →</a>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(260px,1fr)); gap:12px;">
      {calculadoras.map((c) => (
        <a
          href={c.href}
          class="card-lift"
          style="display:flex; align-items:center; gap:16px; padding:20px; border-radius:12px;"
        >
          <div style={`width:44px; height:44px; background:${c.color}18; border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0;`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={c.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={c.svgPath}></path>
            </svg>
          </div>
          <div style="flex:1; min-width:0;">
            <p style="font-size:14px; font-weight:700; color:#1A1A1A; margin:0 0 3px;">{c.titulo}</p>
            <p style="font-size:12px; color:#78716C; margin:0; line-height:1.5;">{c.descripcion}</p>
          </div>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#C7BFB5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ── CTA FINAL ────────────────────────────────────── -->
<section style="background:linear-gradient(135deg, #1A1A1A 0%, #2D2520 100%); padding:64px 20px; margin-bottom:-80px;">
  <div style="max-width:560px; margin:0 auto; text-align:center;">
    <h2 style="font-size:clamp(22px,4vw,34px); font-weight:800; color:#fff; margin:0 0 12px; letter-spacing:-0.4px;">
      ¿Listo para empezar a invertir?
    </h2>
    <p style="font-size:15px; color:#A09890; line-height:1.65; margin:0 0 28px;">
      Elige el broker correcto para tu país y comienza con confianza.
    </p>
    <a href="/brokers" class="btn-primary btn-lg" style="padding:14px 32px;">
      Ver comparador de brokers
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
      </svg>
    </a>
  </div>
</section>

</Layout>

<style>
  .broker-mini-card {
    background: linear-gradient(158deg, #ffffff 0%, #fdfcfb 100%);
    box-shadow: 0 2px 6px rgba(0,0,0,0.04), inset 0 1px 0 rgba(255,255,255,0.9);
    transition: transform 0.22s cubic-bezier(0.4,0,0.2,1), box-shadow 0.22s cubic-bezier(0.4,0,0.2,1);
  }
  .broker-mini-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 36px rgba(0,0,0,0.1), 0 4px 10px rgba(0,0,0,0.05), inset 0 1px 0 rgba(255,255,255,0.9);
  }
</style>
